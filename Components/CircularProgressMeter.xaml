<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="WinCarePro.Components.CircularProgressMeter"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
        <!-- Background outer soft glow -->
        <Ellipse Width="190" Height="190" Fill="#05FFFFFF" Stroke="#10FFFFFF" StrokeThickness="1"/>

        <!-- Custom Styled Progress Ring -->
        <ProgressRing x:Name="HealthProgressRing" 
                      Width="170" 
                      Height="170" 
                      Maximum="100" 
                      IsIndeterminate="False"
                      Background="#15FFFFFF" />

        <!-- Center content labels -->
        <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="2">
            <TextBlock x:Name="ScoreLabel" 
                       Text="100"
                       FontSize="48" 
                       FontWeight="ExtraBold" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,-4" />
            
            <TextBlock x:Name="StatusLabel" 
                       Text="Optimal"
                       FontSize="13" 
                       FontWeight="Bold" 
                       HorizontalAlignment="Center" />
            
            <TextBlock Text="System Health" 
                       FontSize="10.5" 
                       FontWeight="SemiBold" 
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" 
                       HorizontalAlignment="Center" />
        </StackPanel>
    </Grid>
</UserControl>
