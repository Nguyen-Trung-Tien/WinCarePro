<?xml version="1.0" encoding="utf-8"?>
<UserControl
    x:Class="WinCarePro.Components.ToastNotification"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Width="340"
    Margin="0,0,0,8"
    Opacity="0">

    <UserControl.Resources>
        <Storyboard x:Name="PulseAnimation" RepeatBehavior="Forever" AutoReverse="True">
            <DoubleAnimation Storyboard.TargetName="StatusAccentBar"
                             Storyboard.TargetProperty="Opacity"
                             From="1.0" To="0.3" Duration="0:0:0.8"/>
            <DoubleAnimation Storyboard.TargetName="StatusIcon"
                             Storyboard.TargetProperty="Opacity"
                             From="1.0" To="0.3" Duration="0:0:0.8"/>
        </Storyboard>
    </UserControl.Resources>

    <Border x:Name="ContainerBorder"
            Background="{ThemeResource SystemControlTransientBackgroundBrush}"
            BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="12"
            Translation="0,2,8">
        <Grid>
            <!-- Columns: Accent Bar, Content Area -->
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Status Indicator Left Accent Bar -->
            <Border x:Name="StatusAccentBar"
                    Grid.Column="0"
                    Width="6"
                    CornerRadius="12,0,0,12"
                    HorizontalAlignment="Left"/>

            <!-- Main Content Container Grid -->
            <Grid Grid.Column="1" Padding="12,12,12,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="28"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="24"/>
                </Grid.ColumnDefinitions>

                <!-- Icon -->
                <FontIcon x:Name="StatusIcon"
                          Grid.Column="0"
                          FontSize="16"
                          VerticalAlignment="Top"
                          HorizontalAlignment="Left"
                          Margin="0,2,0,0"/>

                <!-- Text Info -->
                <StackPanel Grid.Column="1" Margin="8,0,8,0" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,0,0,2">
                        <TextBlock x:Name="TitleTextBlock"
                                   FontWeight="Bold"
                                   FontSize="12.5"
                                   TextWrapping="Wrap"
                                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        <Border x:Name="RepeatBadge"
                                Background="{ThemeResource SystemAccentColor}"
                                CornerRadius="8"
                                Padding="6,1"
                                VerticalAlignment="Center"
                                Visibility="Collapsed">
                            <TextBlock x:Name="RepeatCountText"
                                       Text="1"
                                       FontSize="9"
                                       FontWeight="Bold"
                                       Foreground="White" />
                        </Border>
                    </StackPanel>
                    <TextBlock x:Name="DescTextBlock"
                               FontSize="11"
                               Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Contextual Action Button -->
                <Button x:Name="ActionBtn"
                        Grid.Column="2"
                        Margin="4,0,8,0"
                        Padding="8,4"
                        FontSize="11"
                        FontWeight="SemiBold"
                        CornerRadius="6"
                        VerticalAlignment="Center"
                        Style="{StaticResource AccentButtonStyle}"
                        Visibility="Collapsed"/>

                <!-- Close Button -->
                <Button x:Name="CloseBtn"
                        Grid.Column="3"
                        Style="{StaticResource DateTimeFlyoutCalendarButtonStyle}"
                        Width="24"
                        Height="24"
                        CornerRadius="12"
                        VerticalAlignment="Top">
                    <FontIcon Glyph="&#xE711;" FontSize="10" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </Button>
            </Grid>
        </Grid>
    </Border>
</UserControl>
