<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinCarePro.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <NavigationView x:Name="NavView" PaneDisplayMode="Left" SelectionChanged="OnNavSelectionChanged" IsBackButtonVisible="Collapsed" Header="Dashboard" IsSettingsVisible="True" OpenPaneLength="280">
            <NavigationView.PaneHeader>
                <StackPanel Padding="20,24,16,16" Spacing="4">
                    <TextBlock Text="WinCare Pro" FontWeight="ExtraBold" FontSize="20" CharacterSpacing="1" />
                    <Border Background="#207F56D9" HorizontalAlignment="Left" Padding="6,2" CornerRadius="4">
                        <TextBlock Text="Version 1.0.3" FontSize="9.5" FontWeight="Bold" Foreground="#FF7F56D9"/>
                    </Border>
                </StackPanel>
            </NavigationView.PaneHeader>

            <NavigationView.PaneFooter>
                <StackPanel Padding="20,16,16,24" Spacing="6">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Ellipse Width="8" Height="8" Fill="#FF10B981" VerticalAlignment="Center"/>
                        <TextBlock Text="System Shield Active" FontSize="12" FontWeight="SemiBold" Foreground="#FF10B981" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </NavigationView.PaneFooter>

            <NavigationView.MenuItems>
                <!-- Dashboard -->
                <NavigationViewItem Content="Dashboard" Tag="Dashboard">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;" Foreground="#FF7F56D9" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                
                <NavigationViewItemSeparator />

                <!-- Cleanup & Care -->
                <NavigationViewItemHeader Content="Care &amp; Clean" />
                <NavigationViewItem Content="Junk Cleaner" Tag="Junk">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xEA99;" Foreground="Orange" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="App Uninstaller" Tag="Uninstaller">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE75C;" Foreground="Crimson" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Network Center" Tag="Network">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE774;" Foreground="DodgerBlue" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="System Repair" Tag="Repair">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE780;" Foreground="Tomato" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                
                <NavigationViewItemSeparator />

                <!-- Optimization & Diagnostics -->
                <NavigationViewItemHeader Content="System Tuning" />
                <NavigationViewItem Content="System Optimizer" Tag="Optimizer">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE945;" Foreground="MediumPurple" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Startup &amp; Services" Tag="Startup">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7B5;" Foreground="Gold" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Process Manager" Tag="Process">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE8F1;" Foreground="Teal" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Disk Tools" Tag="Disk">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7F1;" Foreground="DeepSkyBlue" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                <NavigationViewItem Content="Software Updater" Tag="Updater">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE777;" Foreground="HotPink" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                

            </NavigationView.MenuItems>

            <!-- Navigation Frame Content Area -->
            <Frame x:Name="ContentFrame" Margin="0,4,0,0">
                <Frame.ContentTransitions>
                    <TransitionCollection>
                        <NavigationThemeTransition />
                    </TransitionCollection>
                </Frame.ContentTransitions>
            </Frame>
        </NavigationView>
    </Grid>
</Page>
