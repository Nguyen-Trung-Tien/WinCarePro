<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinCarePro.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <!-- OpenPaneLength set to 260px, CompactPaneLength to 72px -->
        <NavigationView x:Name="NavView" PaneDisplayMode="Left" SelectionChanged="OnNavSelectionChanged" IsBackButtonVisible="Collapsed" Header="Dashboard" IsSettingsVisible="True" OpenPaneLength="260" CompactPaneLength="72">
            <NavigationView.PaneHeader>
                <StackPanel Padding="20,24,16,16" Spacing="4">
                    <TextBlock Text="WinCare Pro 2.0" FontWeight="ExtraBold" FontSize="18" CharacterSpacing="1" />
                    <Border Background="#207F56D9" HorizontalAlignment="Left" Padding="6,2" CornerRadius="4">
                        <TextBlock Text="ENTERPRISE EDITION" FontSize="8.5" FontWeight="Bold" Foreground="#FF7F56D9"/>
                    </Border>
                </StackPanel>
            </NavigationView.PaneHeader>

            <NavigationView.PaneFooter>
                <StackPanel Padding="20,16,16,24" Spacing="6">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <Ellipse Width="8" Height="8" Fill="#FF10B981" VerticalAlignment="Center"/>
                        <TextBlock Text="PC Health Secured" FontSize="11" FontWeight="SemiBold" Foreground="#FF10B981" VerticalAlignment="Center"/>
                    </StackPanel>
                </StackPanel>
            </NavigationView.PaneFooter>

            <NavigationView.MenuItems>
                <!-- Dashboard View -->
                <NavigationViewItem Content="Dashboard" Tag="Dashboard">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE80F;" Foreground="#FF7F56D9" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                
                <NavigationViewItemSeparator />

                <!-- CARE & CLEAN -->
                <NavigationViewItemHeader Content="CARE &amp; CLEAN" />
                
                <NavigationViewItem Content="Junk Cleaner" Tag="Junk">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xEA99;" Foreground="Orange" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="App Uninstaller" Tag="Uninstall">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE74D;" Foreground="Red" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="Network Center" Tag="Network">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE774;" Foreground="DodgerBlue" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="System Repair" Tag="Repair">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE90F;" Foreground="Teal" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="Security Shield" Tag="Security">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE727;" Foreground="MediumSpringGreen" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItemSeparator />

                <!-- SYSTEM TUNING -->
                <NavigationViewItemHeader Content="SYSTEM TUNING" />

                <NavigationViewItem Content="System Optimizer" Tag="Optimizer">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE945;" Foreground="MediumPurple" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="Startup &amp; Services" Tag="Startup">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7B5;" Foreground="Gold" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="Process Manager" Tag="Process">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE9D9;" Foreground="DeepSkyBlue" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="Disk Tools" Tag="Disk">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE7F1;" Foreground="SkyBlue" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="Hardware Center" Tag="Hardware">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE950;" Foreground="MediumAquamarine" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="Registry Center" Tag="Registry">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xEDA2;" Foreground="Tomato" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="Software Updater" Tag="Updater">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE75C;" Foreground="Crimson" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="Driver Updater" Tag="Driver">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xEDA0;" Foreground="Gold" />
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

            </NavigationView.MenuItems>

            <!-- Navigation Frame Content Area -->
            <Frame x:Name="ContentFrame" Margin="0,4,0,0">
                <Frame.ContentTransitions>
                    <TransitionCollection>
                        <NavigationThemeTransition />
                    </TransitionCollection>
                </Frame.ContentTransitions>
            </Frame>
        </NavigationView>
    </Grid>
</Page>
