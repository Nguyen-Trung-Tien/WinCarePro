<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="WinCarePro.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:WinCarePro"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="WinCarePro"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" KeyboardAcceleratorPlacementMode="Hidden">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom Title Bar Grid — v3.0 Nova -->
        <Grid x:Name="TitleBarGrid" Grid.Row="0" Height="56" Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />  <!-- Logo & Brand -->
                <ColumnDefinition Width="*" />     <!-- Drag Area & Search -->
                <ColumnDefinition Width="Auto" />  <!-- Right Controls -->
            </Grid.ColumnDefinitions>

            <!-- Drag Area Canvas (Acts as window drag region) -->
            <Grid x:Name="AppTitleDragArea" Grid.ColumnSpan="3" Background="Transparent" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" />

            <!-- Brand (Left) — v3.0 with version badge -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Padding="16,0" VerticalAlignment="Center" Spacing="8" Canvas.ZIndex="10">
                <Image Source="ms-appx:///Assets/Square44x44Logo.scale-200.png" Width="20" Height="20" VerticalAlignment="Center" Stretch="Uniform"/>
                <TextBlock Text="WinCare Pro" FontFamily="Segoe UI Variable Display" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                <Border Background="#207F56D9" CornerRadius="6" Padding="6,2" VerticalAlignment="Center">
                    <TextBlock Text="v3.3.1" FontSize="10" FontWeight="Bold" Foreground="#FF7F56D9" VerticalAlignment="Center"/>
                </Border>
            </StackPanel>

            <!-- Search (Center) -->
            <Grid Grid.Column="1" HorizontalAlignment="Stretch" VerticalAlignment="Center" MaxWidth="420" Margin="16,0" Height="36" Canvas.ZIndex="10">
                <AutoSuggestBox x:Name="SearchBox" 
                                PlaceholderText="Search tools, settings, apps... (Ctrl + F)" 
                                QueryIcon="Find" 
                                CornerRadius="18" 
                                HorizontalAlignment="Stretch" 
                                VerticalAlignment="Center" 
                                QuerySubmitted="OnSearchQuerySubmitted"
                                TextChanged="OnSearchTextChanged"
                                SuggestionChosen="OnSearchSuggestionChosen">
                    <AutoSuggestBox.ItemTemplate>
                        <DataTemplate x:DataType="local:SearchItem">
                            <Grid Padding="4" ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <FontIcon Grid.Column="0" Glyph="{Binding IconGlyph}" FontSize="16" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding Title}" FontWeight="Bold" FontSize="12.5" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                                    <TextBlock Text="{Binding Description}" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextWrapping="NoWrap"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </AutoSuggestBox.ItemTemplate>
                </AutoSuggestBox>
            </Grid>

            <!-- Controls (Right) — Clock + Notification Bell + Theme -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Padding="0,0,142,0" Spacing="4" VerticalAlignment="Center" Canvas.ZIndex="10">

                <!-- Live Clock -->
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center" Margin="0,0,8,0">
                    <FontIcon Glyph="&#xE787;" FontSize="13" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ClockText" Text="--:--" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" VerticalAlignment="Center" FontFamily="Segoe UI Variable Display"/>
                </StackPanel>

                <!-- Separator -->
                <Border Width="1" Height="20" Background="{ThemeResource ControlStrokeColorDefaultBrush}" Margin="4,0" VerticalAlignment="Center" Opacity="0.5"/>

                <!-- Theme Switcher -->
                <Button x:Name="ThemeButton" Style="{StaticResource DateTimeFlyoutCalendarButtonStyle}" Width="36" Height="36" CornerRadius="18" Padding="0" Click="ThemeButton_Click">
                    <FontIcon x:Name="ThemeIcon" Glyph="&#xE706;" FontSize="15" />
                </Button>
                
                <!-- Notification Bell -->
                <Button x:Name="NotificationButton" Style="{StaticResource DateTimeFlyoutCalendarButtonStyle}" Width="36" Height="36" CornerRadius="18" Padding="0" Click="NotificationButton_Click">
                    <Grid>
                        <FontIcon Glyph="&#xEA8F;" FontSize="15" />
                        <!-- Red dot badge -->
                        <Border x:Name="NotificationBadge" Background="Red" Width="8" Height="8" CornerRadius="4" VerticalAlignment="Top" HorizontalAlignment="Right" Margin="4,-2,-2,4" Visibility="Collapsed" />
                    </Grid>
                </Button>

                <!-- Exit App Button (Off Button) -->
                <Button x:Name="ExitAppButton" Style="{StaticResource DateTimeFlyoutCalendarButtonStyle}" Width="36" Height="36" CornerRadius="18" Padding="0" Click="ExitAppButton_Click">
                    <FontIcon Glyph="&#xE7E8;" FontSize="15" Foreground="#FFEF4444" />
                </Button>
            </StackPanel>
        </Grid>

        <!-- Main Frame -->
        <Frame x:Name="RootFrame" Grid.Row="1" />

        <!-- Dynamic Toast Notification Container -->
        <ScrollViewer Grid.Row="0" Grid.RowSpan="2"
                      VerticalAlignment="Bottom"
                      HorizontalAlignment="Right"
                      Margin="0,0,24,24"
                      VerticalScrollBarVisibility="Hidden"
                      HorizontalScrollBarVisibility="Disabled"
                      Width="360"
                      MaxHeight="500"
                      Canvas.ZIndex="2000">
            <StackPanel x:Name="ToastContainer" Spacing="10" VerticalAlignment="Bottom" />
        </ScrollViewer>

        <!-- Exit Overlay Grid (Premium Glassmorphism Backdrop) -->
        <Grid x:Name="ExitOverlayGrid" Grid.Row="0" Grid.RowSpan="2" Visibility="Collapsed" Canvas.ZIndex="1000" Opacity="0">
            <Grid.Resources>
                <Storyboard x:Name="FadeInExitOverlay">
                    <DoubleAnimation Storyboard.TargetName="ExitOverlayGrid" Storyboard.TargetProperty="Opacity" From="0" To="1" Duration="0:0:0.5">
                        <DoubleAnimation.EasingFunction>
                            <CubicEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation Storyboard.TargetName="ExitOverlayContent" Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)" From="40" To="0" Duration="0:0:0.6">
                        <DoubleAnimation.EasingFunction>
                            <CircleEase EasingMode="EaseOut"/>
                        </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                </Storyboard>
            </Grid.Resources>

            <!-- Background Ambient Glowing Mesh -->
            <Grid x:Name="AmbientGlowContainer">
                <!-- Outer Radial Glow Circle 1 -->
                <Ellipse Width="450" Height="450" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.12">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#FF7F56D9" Offset="0" />
                            <GradientStop Color="Transparent" Offset="1" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
                <!-- Outer Radial Glow Circle 2 -->
                <Ellipse Width="350" Height="350" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="100,50,0,0" Opacity="0.08">
                    <Ellipse.Fill>
                        <RadialGradientBrush>
                            <GradientStop Color="#FF00C1EE" Offset="0" />
                            <GradientStop Color="Transparent" Offset="1" />
                        </RadialGradientBrush>
                    </Ellipse.Fill>
                </Ellipse>
                
                <!-- Frosted Glass Acrylic Layer -->
                <Border BorderThickness="0">
                    <Border.BackgroundSizing>OuterBorderEdge</Border.BackgroundSizing>
                    <Border.Background>
                        <AcrylicBrush TintColor="#050508" TintOpacity="0.80" FallbackColor="#050508"/>
                    </Border.Background>
                </Border>
            </Grid>
            
            <StackPanel x:Name="ExitOverlayContent" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="32">
                <StackPanel.RenderTransform>
                    <TranslateTransform Y="40" />
                </StackPanel.RenderTransform>
                
                <!-- Premium Custom Spinner Ring -->
                <Grid Width="72" Height="72" HorizontalAlignment="Center">
                    <!-- Pulsing outer ring -->
                    <Ellipse Width="72" Height="72" Stroke="#307F56D9" StrokeThickness="2" />
                    <!-- Indeterminate loader -->
                    <ProgressRing IsActive="True" Width="56" Height="56" Foreground="{StaticResource PrimaryAccentGradient}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
                
                <StackPanel Spacing="12" HorizontalAlignment="Center">
                    <TextBlock x:Name="ExitOverlayTitle" Text="Shutting Down" FontSize="26" FontWeight="ExtraBold" FontFamily="Segoe UI Variable Display" HorizontalAlignment="Center" Foreground="White" CharacterSpacing="1"/>
                    <TextBlock x:Name="ExitOverlayMessage" Text="Closing database connections and freeing resources..." FontSize="14.5" Foreground="#FFA0A0B5" HorizontalAlignment="Center" FontWeight="Normal"/>
                    <TextBlock Text="Please don't turn off your computer or close the app" FontSize="11" Foreground="#FF5B5B73" HorizontalAlignment="Center" FontWeight="Light" Margin="0,4,0,0"/>
                </StackPanel>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
