<?xml version="1.0" encoding="utf-8" ?>
<Window
    x:Class="WinCarePro.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:WinCarePro"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Title="WinCarePro"
    mc:Ignorable="d">
    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Custom Title Bar Grid -->
        <Grid x:Name="TitleBarGrid" Grid.Row="0" Height="56" Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" /> <!-- Logo & Brand -->
                <ColumnDefinition Width="*" />    <!-- Drag Area & Search -->
                <ColumnDefinition Width="Auto" /> <!-- Right Controls -->
            </Grid.ColumnDefinitions>

            <!-- Drag Area Canvas (Acts as window drag region) -->
            <Grid x:Name="AppTitleDragArea" Grid.ColumnSpan="3" Background="Transparent" VerticalAlignment="Stretch" HorizontalAlignment="Stretch" />

            <!-- Brand (Left) -->
            <StackPanel Grid.Column="0" Orientation="Horizontal" Padding="16,0" VerticalAlignment="Center" Spacing="8" Canvas.ZIndex="10">
                <Image Source="ms-appx:///Assets/Square44x44Logo.scale-200.png" Width="20" Height="20" VerticalAlignment="Center" Stretch="Uniform"/>
                <TextBlock Text="WinCare Pro" FontFamily="Segoe UI Variable Display" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Search (Center) -->
            <Grid Grid.Column="1" HorizontalAlignment="Center" VerticalAlignment="Center" Width="420" Height="36" Canvas.ZIndex="10">
                <AutoSuggestBox x:Name="SearchBox" PlaceholderText="Search tools, settings, apps... (Ctrl + F)" QueryIcon="Find" CornerRadius="18" Width="420" Height="34" HorizontalAlignment="Center" VerticalAlignment="Center" QuerySubmitted="OnSearchQuerySubmitted"/>
            </Grid>

            <!-- Controls (Right) -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Padding="0,0,142,0" Spacing="8" VerticalAlignment="Center" Canvas.ZIndex="10">

                <!-- Theme Switcher -->
                <Button x:Name="ThemeButton" Style="{StaticResource DateTimeFlyoutCalendarButtonStyle}" Width="36" Height="36" CornerRadius="18" Padding="0" Click="ThemeButton_Click">
                    <FontIcon x:Name="ThemeIcon" Glyph="&#xE706;" FontSize="15" />
                </Button>
            </StackPanel>
        </Grid>

        <!-- Main Frame -->
        <Frame x:Name="RootFrame" Grid.Row="1" />


    </Grid>
</Window>
