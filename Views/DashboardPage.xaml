<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinCarePro.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:WinCarePro.ViewModels"
    xmlns:local="using:WinCarePro.Views"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="System Dashboard" Style="{ThemeResource TitleTextBlockStyle}" FontWeight="Bold" />
            <TextBlock Text="Monitor and optimize your Windows operating system in one click." Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
        </StackPanel>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid RowSpacing="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>

                <!-- Column 1: Health Status & Resources -->
                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="24">
                    <!-- Health Gauge Card -->
                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="24">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <!-- Circular Progress -->
                            <Grid Grid.Column="0" Width="180" Height="180" Margin="0,0,24,0">
                                <ProgressRing Value="{x:Bind ViewModel.HealthScore, Mode=OneWay}" Width="160" Height="160" Foreground="{ThemeResource SystemAccentColor}" Background="{ThemeResource ControlStrokeColorDefaultBrush}" />
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                    <TextBlock Text="{x:Bind ViewModel.HealthScore, Mode=OneWay}" Style="{ThemeResource HeaderTextBlockStyle}" FontWeight="ExtraBold" HorizontalAlignment="Center" />
                                    <TextBlock Text="Health Score" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Grid>

                            <!-- Score status description -->
                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="8">
                                <TextBlock Text="Your System Health Status" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="SemiBold" />
                                <TextBlock Text="{x:Bind GetStatusText(ViewModel.HealthScore), Mode=OneWay}" Style="{ThemeResource BodyTextBlockStyle}" FontWeight="Bold" Foreground="{ThemeResource SystemAccentColor}" />
                                <TextBlock Text="A scan verifies diagnostic alerts, junk file volumes, startup overhead, and available security fixes. Optimize now to clean garbage files and improve loading speeds." TextWrapping="Wrap" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                
                                <StackPanel Orientation="Horizontal" Margin="0,12,0,0" Spacing="12">
                                    <Button Content="Scan System" Style="{StaticResource DefaultButtonStyle}" Click="OnScanClick" IsEnabled="{x:Bind IsNot(ViewModel.IsScanning), Mode=OneWay}" Padding="16,8" CornerRadius="8" />
                                    <Button Content="Optimize Now" Style="{StaticResource AccentButtonStyle}" Click="OnOptimizeClick" Visibility="{x:Bind GetOptimizeVisibility(ViewModel.HasScanned, ViewModel.IsScanning), Mode=OneWay}" IsEnabled="{x:Bind IsNot(ViewModel.IsOptimizing), Mode=OneWay}" Padding="16,8" CornerRadius="8" />
                                    <ProgressRing IsActive="{x:Bind GetProgressRingActive(ViewModel.IsScanning, ViewModel.IsOptimizing), Mode=OneWay}" Width="24" Height="24" Margin="8,0,0,0" />
                                </StackPanel>
                                <TextBlock Text="{x:Bind ViewModel.ScanStatus, Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Realtime Resource Metrics (2x2 Grid) -->
                    <Grid RowSpacing="12" ColumnSpacing="12">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- CPU Card -->
                        <Border Grid.Row="0" Grid.Column="0" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="6">
                                <TextBlock Text="CPU Processor Load" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                <Grid>
                                    <TextBlock Text="{x:Bind FormatPercent(ViewModel.CpuUsage), Mode=OneWay}" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="Bold" HorizontalAlignment="Left" />
                                </Grid>
                                <ProgressBar Value="{x:Bind ViewModel.CpuUsage, Mode=OneWay}" Maximum="100" Height="6" Foreground="{ThemeResource SystemAccentColor}" CornerRadius="3" />
                            </StackPanel>
                        </Border>

                        <!-- Memory (RAM) Card -->
                        <Border Grid.Row="0" Grid.Column="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Memory (RAM) Footprint" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                <TextBlock Text="{x:Bind FormatPercent(ViewModel.RamUsage), Mode=OneWay}" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="Bold" />
                                <ProgressBar Value="{x:Bind ViewModel.RamUsage, Mode=OneWay}" Maximum="100" Height="6" Foreground="{ThemeResource SystemAccentColor}" CornerRadius="3" />
                            </StackPanel>
                        </Border>

                        <!-- GPU Card -->
                        <Border Grid.Row="1" Grid.Column="0" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Graphics Card (GPU) Load" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                <TextBlock Text="{x:Bind FormatPercent(ViewModel.GpuUsage), Mode=OneWay}" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="Bold" />
                                <ProgressBar Value="{x:Bind ViewModel.GpuUsage, Mode=OneWay}" Maximum="100" Height="6" Foreground="{ThemeResource SystemAccentColor}" CornerRadius="3" />
                            </StackPanel>
                        </Border>

                        <!-- Storage Card -->
                        <Border Grid.Row="1" Grid.Column="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="6">
                                <TextBlock Text="System Disk Activity" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                <TextBlock Text="{x:Bind FormatPercent(ViewModel.DiskUsage), Mode=OneWay}" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="Bold" />
                                <ProgressBar Value="{x:Bind ViewModel.DiskUsage, Mode=OneWay}" Maximum="100" Height="6" Foreground="{ThemeResource SystemAccentColor}" CornerRadius="3" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>

                <!-- Column 2: Quick Recommendations -->
                <Border Grid.Row="0" Grid.Column="1" Margin="16,0,0,0" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,16" Spacing="4">
                            <TextBlock Text="Smart AI Advice" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="Bold" />
                            <TextBlock Text="Suggested actions based on scanning diagnostics:" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                        </StackPanel>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="12">
                                <!-- If recommendations empty -->
                                <TextBlock Text="No recommendations. Run a full scan to evaluate your PC health." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" Visibility="{x:Bind GetVisibility(ViewModel.Recommendations.Count), Mode=OneWay}" Margin="0,16,0,0" TextAlignment="Center" />
                                
                                <ItemsControl ItemsSource="{x:Bind ViewModel.Recommendations, Mode=OneWay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource ControlAltFillColorSecondaryBrush}" CornerRadius="6" Margin="0,0,0,8" Padding="12">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <FontIcon Glyph="&#xE7BA;" FontSize="16" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Center" Margin="0,0,12,0" />
                                                    <TextBlock Grid.Column="1" Text="{x:Bind}" TextWrapping="Wrap" Style="{ThemeResource CaptionTextBlockStyle}" VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Row 1, Col Span 2: Detailed Audits Table -->
                <Border Grid.Row="1" Grid.ColumnSpan="2" Margin="0,24,0,0" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Diagnostics Discoveries" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="Bold" Margin="0,0,0,16" />

                        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.DiagnosticItems, Mode=OneWay}" SelectionMode="None" IsItemClickEnabled="False">
                            <ListView.HeaderTemplate>
                                <DataTemplate>
                                    <Grid Padding="12,6" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="200" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="200" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Category" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="1" Text="Check Name" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="2" Text="Description" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="3" Text="Status" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.HeaderTemplate>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:DiagnosticResult" xmlns:models="using:WinCarePro.Models">
                                    <Grid Padding="12" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="200" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="200" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{x:Bind Category}" VerticalAlignment="Center" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind CheckName}" VerticalAlignment="Center" Style="{ThemeResource CaptionTextBlockStyle}" FontWeight="Bold" />
                                        <TextBlock Grid.Column="2" Text="{x:Bind Description}" TextWrapping="Wrap" VerticalAlignment="Center" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" Margin="0,0,12,0"/>
                                        <StackPanel Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                                            <FontIcon Glyph="{x:Bind local:DashboardPage.GetStatusIcon(IsHealthy)}" Foreground="{x:Bind local:DashboardPage.GetStatusColor(IsHealthy)}" FontSize="14" />
                                            <TextBlock Text="{x:Bind local:DashboardPage.GetStatusLabel(IsHealthy)}" Foreground="{x:Bind local:DashboardPage.GetStatusColor(IsHealthy)}" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
