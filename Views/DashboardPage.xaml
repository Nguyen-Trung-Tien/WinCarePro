<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinCarePro.Views.DashboardPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:WinCarePro.ViewModels"
    xmlns:local="using:WinCarePro.Views"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
    mc:Ignorable="d"
    NavigationCacheMode="Enabled">

    <Grid Padding="24">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="LayoutVisualStates">
                <!-- Wide Layout: Viewport Width >= 960px -->
                <VisualState x:Name="WideState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="960" />
                    </VisualState.StateTriggers>
                </VisualState>
                <!-- Narrow Layout: Viewport Width < 960px -->
                <VisualState x:Name="NarrowState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <!-- Stack parent columns -->
                        <Setter Target="LeftPanel.(Grid.ColumnSpan)" Value="2" />
                        <Setter Target="RecommendationsCard.(Grid.Row)" Value="1" />
                        <Setter Target="RecommendationsCard.(Grid.Column)" Value="0" />
                        <Setter Target="RecommendationsCard.(Grid.ColumnSpan)" Value="2" />
                        <Setter Target="AuditsCard.(Grid.Row)" Value="2" />
                        <Setter Target="AuditsCard.(Grid.Column)" Value="0" />
                        <Setter Target="AuditsCard.(Grid.ColumnSpan)" Value="2" />

                        <!-- Stack Health Gauge Card elements vertically & center -->
                        <Setter Target="GaugeRingGrid.(Grid.Row)" Value="0" />
                        <Setter Target="GaugeRingGrid.(Grid.Column)" Value="0" />
                        <Setter Target="GaugeRingGrid.(Grid.RowSpan)" Value="1" />
                        <Setter Target="GaugeRingGrid.(Grid.ColumnSpan)" Value="2" />
                        <Setter Target="GaugeRingGrid.HorizontalAlignment" Value="Center" />
                        <Setter Target="GaugeRingGrid.Margin" Value="0,0,0,16" />
                        <Setter Target="GaugeDescPanel.(Grid.Row)" Value="1" />
                        <Setter Target="GaugeDescPanel.(Grid.Column)" Value="0" />
                        <Setter Target="GaugeDescPanel.(Grid.RowSpan)" Value="1" />
                        <Setter Target="GaugeDescPanel.(Grid.ColumnSpan)" Value="2" />
                        <Setter Target="GaugeDescPanel.HorizontalAlignment" Value="Center" />
                        <Setter Target="GaugeDescPanel.VerticalAlignment" Value="Center" />

                        <!-- Stack Resource Metrics Grid 2x2 to 4x1 -->
                        <Setter Target="CpuCard.(Grid.Row)" Value="0" />
                        <Setter Target="CpuCard.(Grid.Column)" Value="0" />
                        <Setter Target="CpuCard.(Grid.ColumnSpan)" Value="2" />
                        <Setter Target="RamCard.(Grid.Row)" Value="1" />
                        <Setter Target="RamCard.(Grid.Column)" Value="0" />
                        <Setter Target="RamCard.(Grid.ColumnSpan)" Value="2" />
                        <Setter Target="GpuCard.(Grid.Row)" Value="2" />
                        <Setter Target="GpuCard.(Grid.Column)" Value="0" />
                        <Setter Target="GpuCard.(Grid.ColumnSpan)" Value="2" />
                        <Setter Target="DiskCard.(Grid.Row)" Value="3" />
                        <Setter Target="DiskCard.(Grid.Column)" Value="0" />
                        <Setter Target="DiskCard.(Grid.ColumnSpan)" Value="2" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid.ChildrenTransitions>
            <TransitionCollection>
                <EntranceThemeTransition FromHorizontalOffset="0" FromVerticalOffset="20" />
            </TransitionCollection>
        </Grid.ChildrenTransitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Page Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="System Dashboard" FontSize="28" FontWeight="ExtraBold" CharacterSpacing="-10" />
                <TextBlock Text="Real-time performance monitors, AI diagnostics, and one-click optimization." Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" Margin="0,4,0,0" />
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <Grid x:Name="ContentGrid" RowSpacing="24" ColumnSpacing="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" x:Name="Col0" />
                    <ColumnDefinition Width="2*" x:Name="Col1" />
                </Grid.ColumnDefinitions>

                <!-- Column 1: Health Status & Resources -->
                <StackPanel x:Name="LeftPanel" Grid.Row="0" Grid.Column="0" Spacing="24">
                    <!-- Health Gauge Card (Neon Glow Border) -->
                    <Border Style="{StaticResource NeonGlowBorderStyle}" Padding="28">
                        <Grid x:Name="HealthGaugeGrid">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" x:Name="GaugeCol0" />
                                <ColumnDefinition Width="*" x:Name="GaugeCol1" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" x:Name="GaugeRow0" />
                                <RowDefinition Height="Auto" x:Name="GaugeRow1" />
                            </Grid.RowDefinitions>

                            <!-- Circular Progress -->
                            <Grid x:Name="GaugeRingGrid" Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" Width="180" Height="180" Margin="0,0,28,0">
                                <!-- Background ring track -->
                                <Ellipse Width="154" Height="154" Stroke="{ThemeResource ControlStrokeColorDefaultBrush}" StrokeThickness="8" HorizontalAlignment="Center" VerticalAlignment="Center" Opacity="0.5"/>
                                <ProgressRing Value="{x:Bind ViewModel.HealthScore, Mode=OneWay}" Width="160" Height="160" Foreground="{x:Bind GetHealthScoreBrush(ViewModel.HealthScore), Mode=OneWay}" Background="Transparent" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="2">
                                    <TextBlock Text="{x:Bind ViewModel.HealthScore, Mode=OneWay}" FontSize="44" FontWeight="ExtraBold" HorizontalAlignment="Center" Foreground="{x:Bind GetHealthScoreBrush(ViewModel.HealthScore), Mode=OneWay}" CharacterSpacing="-20"/>
                                    <TextBlock Text="Health Score" FontSize="11" FontWeight="Bold" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Grid>

                            <!-- Score status description -->
                            <StackPanel x:Name="GaugeDescPanel" Grid.Row="0" Grid.Column="1" Grid.RowSpan="2" VerticalAlignment="Center" Spacing="12">
                                <TextBlock Text="System Health Overview" FontSize="20" FontWeight="Bold" />
                                <Border Background="{x:Bind GetHealthScoreBadgeBackground(ViewModel.HealthScore), Mode=OneWay}" HorizontalAlignment="Left" Padding="12,6" CornerRadius="6">
                                    <TextBlock Text="{x:Bind GetStatusText(ViewModel.HealthScore), Mode=OneWay}" FontSize="12" FontWeight="Bold" Foreground="{x:Bind GetHealthScoreBrush(ViewModel.HealthScore), Mode=OneWay}" />
                                </Border>
                                <TextBlock Text="A scan verifies diagnostic alerts, junk file volumes, startup overhead, and available security fixes. Optimize now to clean garbage files and improve loading speeds." TextWrapping="Wrap" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" LineHeight="18" />
                                
                                <StackPanel Orientation="Horizontal" Margin="0,8,0,0" Spacing="12">
                                    <Button Content="Scan System" Style="{StaticResource DefaultButtonStyle}" Click="OnScanClick" IsEnabled="{x:Bind IsNot(ViewModel.IsScanning), Mode=OneWay}" Padding="20,10" CornerRadius="8" FontWeight="SemiBold" />
                                    <Button Content="Optimize Now" Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" Click="OnOptimizeClick" Visibility="{x:Bind GetOptimizeVisibility(ViewModel.HasScanned, ViewModel.IsScanning), Mode=OneWay}" IsEnabled="{x:Bind IsNot(ViewModel.IsOptimizing), Mode=OneWay}" Padding="20,10" CornerRadius="8" FontWeight="SemiBold" />
                                    <ProgressRing IsActive="{x:Bind GetProgressRingActive(ViewModel.IsScanning, ViewModel.IsOptimizing), Mode=OneWay}" Width="24" Height="24" Margin="8,0,0,0" />
                                </StackPanel>
                                
                                <StackPanel Visibility="{x:Bind GetProgressVisibility(ViewModel.IsScanning), Mode=OneWay}" Spacing="6" Margin="0,4,0,0">
                                    <ProgressBar Value="{x:Bind ViewModel.ScanProgress, Mode=OneWay}" Maximum="100" Height="6" Foreground="{ThemeResource SystemAccentColor}" CornerRadius="3" />
                                </StackPanel>
                                
                                <TextBlock Text="{x:Bind ViewModel.ScanStatus, Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Realtime Resource Metrics (2x2 Grid) -->
                    <Grid RowSpacing="16" ColumnSpacing="16" x:Name="MetricsGrid">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" x:Name="MetricsRow0" />
                            <RowDefinition Height="Auto" x:Name="MetricsRow1" />
                            <RowDefinition Height="Auto" x:Name="MetricsRow2" />
                            <RowDefinition Height="Auto" x:Name="MetricsRow3" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" x:Name="MetricsCol0" />
                            <ColumnDefinition Width="*" x:Name="MetricsCol1" />
                        </Grid.ColumnDefinitions>

                        <!-- CPU Card -->
                        <Border x:Name="CpuCard" Grid.Row="0" Grid.Column="0" Grid.RowSpan="1" Grid.ColumnSpan="1" Style="{StaticResource ModernCardStyle}" Padding="20">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="6" Grid.Column="0">
                                        <TextBlock Text="CPU Processor Load" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                        <TextBlock Text="{x:Bind FormatPercent(ViewModel.CpuUsage), Mode=OneWay}" FontSize="24" FontWeight="ExtraBold" />
                                        <ProgressBar Value="{x:Bind ViewModel.CpuUsage, Mode=OneWay}" Maximum="100" Height="6" Foreground="{StaticResource CpuAccentBrush}" Background="{StaticResource CpuTrackBrush}" CornerRadius="3" Margin="0,4,0,0" />
                                    </StackPanel>
                                    <Border Grid.Column="1" Width="44" Height="44" Background="#15F59E0B" CornerRadius="22" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="12,0,0,0">
                                        <FontIcon Glyph="&#xE7F4;" FontSize="18" Foreground="{StaticResource CpuAccentBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    </Border>
                                </Grid>
                                <!-- CPU Temperature -->
                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,8,0,0">
                                    <FontIcon Glyph="&#xE9CA;" FontSize="12" Foreground="{StaticResource CpuAccentBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="{x:Bind ViewModel.CpuTempFormatted, Mode=OneWay}" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Memory (RAM) Card -->
                        <Border x:Name="RamCard" Grid.Row="0" Grid.Column="1" Grid.RowSpan="1" Grid.ColumnSpan="1" Style="{StaticResource ModernCardStyle}" Padding="20">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="6" Grid.Column="0">
                                        <TextBlock Text="Memory (RAM) Footprint" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                        <TextBlock Text="{x:Bind FormatPercent(ViewModel.RamUsage), Mode=OneWay}" FontSize="24" FontWeight="ExtraBold" />
                                        <ProgressBar Value="{x:Bind ViewModel.RamUsage, Mode=OneWay}" Maximum="100" Height="6" Foreground="{StaticResource RamAccentBrush}" Background="{StaticResource RamTrackBrush}" CornerRadius="3" Margin="0,4,0,0" />
                                    </StackPanel>
                                    <Border Grid.Column="1" Width="44" Height="44" Background="#153B82F6" CornerRadius="22" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="12,0,0,0">
                                        <FontIcon Glyph="&#xE950;" FontSize="18" Foreground="{StaticResource RamAccentBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    </Border>
                                </Grid>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" Spacing="6" Grid.Column="0" VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE950;" FontSize="12" Foreground="{StaticResource RamAccentBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{x:Bind ViewModel.RamCapacityFormatted, Mode=OneWay}" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Boost" Style="{StaticResource DefaultButtonStyle}" Padding="12,4" Height="28" CornerRadius="6" FontSize="11" FontWeight="Bold" Click="OnBoostRamClick" IsEnabled="{x:Bind IsNot(ViewModel.IsOptimizing), Mode=OneWay}" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- GPU Card -->
                        <Border x:Name="GpuCard" Grid.Row="1" Grid.Column="0" Grid.RowSpan="1" Grid.ColumnSpan="1" Style="{StaticResource ModernCardStyle}" Padding="20">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="6" Grid.Column="0">
                                        <TextBlock Text="Graphics Card (GPU) Load" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                        <TextBlock Text="{x:Bind FormatPercent(ViewModel.GpuUsage), Mode=OneWay}" FontSize="24" FontWeight="ExtraBold" />
                                        <ProgressBar Value="{x:Bind ViewModel.GpuUsage, Mode=OneWay}" Maximum="100" Height="6" Foreground="{StaticResource GpuAccentBrush}" Background="{StaticResource GpuTrackBrush}" CornerRadius="3" Margin="0,4,0,0" />
                                    </StackPanel>
                                    <Border Grid.Column="1" Width="44" Height="44" Background="#158B5CF6" CornerRadius="22" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="12,0,0,0">
                                        <FontIcon Glyph="&#xE9F5;" FontSize="18" Foreground="{StaticResource GpuAccentBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    </Border>
                                </Grid>
                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="0,8,0,0">
                                    <FontIcon Glyph="&#xE9F5;" FontSize="12" Foreground="{StaticResource GpuAccentBrush}" VerticalAlignment="Center"/>
                                    <TextBlock Text="Active Monitoring" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <!-- Storage Card -->
                        <Border x:Name="DiskCard" Grid.Row="1" Grid.Column="1" Grid.RowSpan="1" Grid.ColumnSpan="1" Style="{StaticResource ModernCardStyle}" Padding="20">
                            <StackPanel>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Spacing="6" Grid.Column="0">
                                        <TextBlock Text="System Disk Activity" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                        <TextBlock Text="{x:Bind FormatPercent(ViewModel.DiskUsage), Mode=OneWay}" FontSize="24" FontWeight="ExtraBold" />
                                        <ProgressBar Value="{x:Bind ViewModel.DiskUsage, Mode=OneWay}" Maximum="100" Height="6" Foreground="{StaticResource DiskAccentBrush}" Background="{StaticResource DiskTrackBrush}" CornerRadius="3" Margin="0,4,0,0" />
                                    </StackPanel>
                                    <Border Grid.Column="1" Width="44" Height="44" Background="#1510B981" CornerRadius="22" VerticalAlignment="Center" HorizontalAlignment="Center" Margin="12,0,0,0">
                                        <FontIcon Glyph="&#xE7F1;" FontSize="18" Foreground="{StaticResource DiskAccentBrush}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    </Border>
                                </Grid>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal" Spacing="6" Grid.Column="0" VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xEA99;" FontSize="12" Foreground="{StaticResource DiskAccentBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Text="{x:Bind ViewModel.JunkFileSize, Mode=OneWay}" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="Clean" Style="{StaticResource DefaultButtonStyle}" Padding="12,4" Height="28" CornerRadius="6" FontSize="11" FontWeight="Bold" Click="OnCleanDiskClick" IsEnabled="{x:Bind IsNot(ViewModel.IsOptimizing), Mode=OneWay}" />
                                </Grid>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Performance Trend Chart Card -->
                    <Border Style="{StaticResource ModernCardStyle}" Padding="20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <StackPanel Grid.Row="0" Margin="0,0,0,16" Spacing="4">
                                <TextBlock Text="Performance Trend History" FontSize="16" FontWeight="Bold" />
                                <TextBlock Text="Rolling history of resource load levels (CPU, RAM, GPU, Disk)" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                            </StackPanel>
                            <lvc:CartesianChart
                                Grid.Row="1"
                                Height="200"
                                Series="{x:Bind ViewModel.PerformanceSeries, Mode=OneWay}"
                                XAxes="{x:Bind ViewModel.XAxes, Mode=OneWay}"
                                YAxes="{x:Bind ViewModel.YAxes, Mode=OneWay}"
                                TooltipFindingStrategy="CompareAll" />
                        </Grid>
                    </Border>

                    <!-- v3.0: Quick Stats Strip -->
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource QuickStatCardStyle}">
                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE916;" FontSize="12" Foreground="{StaticResource GpuAccentBrush}"/>
                                    <TextBlock Text="Uptime" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                </StackPanel>
                                <TextBlock Text="{x:Bind ViewModel.SystemUptime, Mode=OneWay}" FontSize="13" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource QuickStatCardStyle}">
                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE774;" FontSize="12" Foreground="DodgerBlue"/>
                                    <TextBlock Text="Network" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                </StackPanel>
                                <TextBlock Text="{x:Bind ViewModel.NetworkStatus, Mode=OneWay}" FontSize="13" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource QuickStatCardStyle}">
                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xE71D;" FontSize="12" Foreground="MediumPurple"/>
                                    <TextBlock Text="Apps" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                </StackPanel>
                                <TextBlock Text="{x:Bind ViewModel.InstalledAppsCount, Mode=OneWay}" FontSize="13" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="3" Style="{StaticResource QuickStatCardStyle}">
                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="6">
                                    <FontIcon Glyph="&#xEA99;" FontSize="12" Foreground="Orange"/>
                                    <TextBlock Text="Junk" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                </StackPanel>
                                <TextBlock Text="{x:Bind ViewModel.JunkFileSize, Mode=OneWay}" FontSize="13" FontWeight="Bold"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>

                <!-- Column 2: Quick Recommendations -->
                <Border x:Name="RecommendationsCard" Grid.Row="0" Grid.Column="1" Grid.RowSpan="1" Grid.ColumnSpan="1" Style="{StaticResource ModernCardStyle}" Padding="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Margin="0,0,0,16" Spacing="4">
                            <TextBlock Text="Smart AI Advice" FontSize="18" FontWeight="Bold" />
                            <TextBlock Text="Suggested actions based on scanning diagnostics:" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                        </StackPanel>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="12">
                                <!-- If recommendations empty -->
                                <TextBlock Text="No recommendations. Run a full scan to evaluate your PC health." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" Visibility="{x:Bind GetVisibility(ViewModel.Recommendations.Count), Mode=OneWay}" Margin="0,16,0,0" TextAlignment="Center" />
                                
                                <ItemsControl ItemsSource="{x:Bind ViewModel.Recommendations, Mode=OneWay}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate x:DataType="x:String">
                                            <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource ControlAltFillColorSecondaryBrush}" CornerRadius="10" Margin="0,0,0,10" Padding="14">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>
                                                    <Border Width="28" Height="28" Background="#157F56D9" CornerRadius="14" VerticalAlignment="Center" Margin="0,0,12,0">
                                                        <FontIcon Glyph="&#xE7BA;" FontSize="12" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                    </Border>
                                                    <TextBlock Grid.Column="1" Text="{x:Bind}" TextWrapping="Wrap" FontSize="12" LineHeight="16" VerticalAlignment="Center" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Row 1, Col Span 2: Detailed Audits Table -->
                <Border x:Name="AuditsCard" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Style="{StaticResource ModernCardStyle}" Padding="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Diagnostics Discoveries" FontSize="18" FontWeight="Bold" Margin="0,0,0,16" />

                        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.DiagnosticItems, Mode=OneWay}" SelectionMode="None" IsItemClickEnabled="False">
                            <ListView.ItemContainerTransitions>
                                <TransitionCollection>
                                    <AddDeleteThemeTransition />
                                    <RepositionThemeTransition />
                                </TransitionCollection>
                            </ListView.ItemContainerTransitions>
                            <ListView.HeaderTemplate>
                                <DataTemplate>
                                    <Grid Padding="12,8" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.2*" />
                                            <ColumnDefinition Width="1.8*" />
                                            <ColumnDefinition Width="4*" />
                                            <ColumnDefinition Width="1.5*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Category" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" TextWrapping="Wrap" />
                                        <TextBlock Grid.Column="1" Text="Check Name" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" TextWrapping="Wrap" />
                                        <TextBlock Grid.Column="2" Text="Description" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" TextWrapping="Wrap" />
                                        <TextBlock Grid.Column="3" Text="Status" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Left" TextWrapping="Wrap" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.HeaderTemplate>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:DiagnosticResult" xmlns:models="using:WinCarePro.Models">
                                    <Grid Padding="12,10" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.2*" />
                                            <ColumnDefinition Width="1.8*" />
                                            <ColumnDefinition Width="4*" />
                                            <ColumnDefinition Width="1.5*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="{x:Bind Category}" VerticalAlignment="Center" FontSize="12.5" TextWrapping="Wrap" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind CheckName}" VerticalAlignment="Center" FontSize="12.5" FontWeight="SemiBold" TextWrapping="Wrap" />
                                        <TextBlock Grid.Column="2" Text="{x:Bind Description}" TextWrapping="Wrap" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" Margin="0,0,16,0" LineHeight="16"/>
                                        <Grid Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Left">
                                            <!-- Status badge: shown when item is healthy -->
                                            <Border Background="{x:Bind local:DashboardPage.GetStatusBadgeBg(IsHealthy)}" CornerRadius="6" Padding="10,5" Visibility="{x:Bind local:DashboardPage.GetStatusBadgeVisibility(IsHealthy), Mode=OneWay}">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <FontIcon Glyph="{x:Bind local:DashboardPage.GetStatusIcon(IsHealthy)}" Foreground="{x:Bind local:DashboardPage.GetStatusColor(IsHealthy)}" FontSize="11" VerticalAlignment="Center" />
                                                    <TextBlock Text="{x:Bind local:DashboardPage.GetStatusLabel(IsHealthy)}" Foreground="{x:Bind local:DashboardPage.GetStatusColor(IsHealthy)}" FontWeight="Bold" FontSize="11" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Border>
                                            <!-- Fix button: shown when item is unhealthy -->
                                            <Button Content="Fix Now" Style="{StaticResource DefaultButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" Padding="12,5" Height="28" CornerRadius="6" FontSize="11" FontWeight="Bold" Visibility="{x:Bind local:DashboardPage.GetFixButtonVisibility(IsHealthy), Mode=OneWay}" Click="OnFixItemClick" />
                                        </Grid>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
