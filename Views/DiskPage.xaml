<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinCarePro.Views.DiskPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:WinCarePro.Engines"
    xmlns:vm="using:WinCarePro.ViewModels"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Pivot x:Name="DiskPivot" SelectionChanged="OnPivotSelectionChanged">
            <!-- Tab 1: Disk Overview -->
            <PivotItem Header="Disk Overview">
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Margin="0,0,0,16" Style="{StaticResource ModernCardStyle}" Padding="16">
                        <TextBlock Text="Local storage volumes health, physical S.M.A.R.T attributes, and hardware controllers status." FontSize="12.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                    </Border>

                    <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Drives, Mode=OneWay}" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:DriveHealthInfo">
                                <Border Style="{StaticResource ModernCardStyle}" Margin="0,0,0,12" Padding="20">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Border Width="44" Height="44" Background="#1510B981" CornerRadius="22" VerticalAlignment="Center" Margin="0,0,16,0">
                                            <FontIcon Glyph="&#xE7F1;" FontSize="18" Foreground="{ThemeResource SystemAccentColor}" />
                                        </Border>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                                            <TextBlock Text="{x:Bind Model}" FontWeight="Bold" FontSize="15" />
                                            <StackPanel Orientation="Horizontal" Spacing="16">
                                                <TextBlock Text="{x:Bind Name}" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                                <TextBlock Text="{x:Bind Interface}" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                                <TextBlock Text="{x:Bind TemperatureFormatted}" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right" Spacing="4">
                                            <Border Background="#2010B981" CornerRadius="4" Padding="8,4" HorizontalAlignment="Right">
                                                <TextBlock Text="{x:Bind HealthStatus}" FontWeight="Bold" FontSize="11" Foreground="#FF10B981" />
                                            </Border>
                                            <TextBlock Text="S.M.A.R.T Status: OK" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" HorizontalAlignment="Right" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </PivotItem>

            <!-- Tab 2: Disk Space Analyzer -->
            <PivotItem Header="Space Analyzer">
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Margin="0,0,0,16" Style="{StaticResource ModernCardStyle}" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Header="Analysis Target Folder" Text="{x:Bind ViewModel.StorageScanPath, Mode=TwoWay}" Width="380" CornerRadius="6" VerticalAlignment="Center" HorizontalAlignment="Left"/>
                            <Button Grid.Column="1" Content="Analyze Folder" Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" Click="OnAnalyzeClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" VerticalAlignment="Bottom"/>
                        </Grid>
                    </Border>

                    <Grid Grid.Row="1" ColumnSpacing="20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="320" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource ModernCardStyle}" Padding="16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Allocation Directory Weight (Double-click card to Zoom In)" FontSize="15" FontWeight="Bold" Margin="0,0,0,12" />

                                <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.StorageItems, Mode=OneWay}" SelectionMode="None">
                                    <ListView.ItemTemplate>
                                        <DataTemplate x:DataType="models:StorageItem">
                                            <Grid Padding="8,10" BorderThickness="0,0,0,1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" DoubleTapped="StorageItem_DoubleTapped" Background="Transparent">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <FontIcon Glyph="{x:Bind IconGlyph}" FontSize="14" Foreground="{ThemeResource SystemAccentColor}" Margin="0,0,12,0"/>
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind Name}" FontWeight="Bold" FontSize="13"/>
                                                    <TextBlock Text="{x:Bind Path}" FontSize="10" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                                </StackPanel>
                                                <TextBlock Grid.Column="2" Text="{x:Bind SizeFormatted}" FontWeight="Bold" FontSize="13" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Center"/>
                                            </Grid>
                                        </DataTemplate>
                                    </ListView.ItemTemplate>
                                </ListView>
                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource ModernCardStyle}" Padding="16">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Grid.Row="0" Text="Operations log" FontSize="15" FontWeight="Bold" Margin="0,0,0,12" />
                                <TextBox Grid.Row="1" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" FontFamily="Consolas" FontSize="11.5" Text="{x:Bind ViewModel.ConsoleOutput, Mode=OneWay}" Background="#0A0E1A" Foreground="#00F2FE" BorderThickness="0" CornerRadius="6" Padding="8" />
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </PivotItem>

            <!-- Tab 3: Duplicate Finder -->
            <PivotItem Header="Duplicate Finder">
                <Grid Margin="0,16,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Margin="0,0,0,16" Style="{StaticResource ModernCardStyle}" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Find identical files (MD5 / SHA-256) and execute one-click smart batch deletion." FontSize="12.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <Button Content="Scan Duplicates" Click="OnScanDuplicatesClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}"/>
                                <Button Content="Delete Pre-Selected" Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" Click="OnDeleteDuplicatesClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}"/>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource ModernCardStyle}" Padding="16">
                        <ListView ItemsSource="{x:Bind ViewModel.DuplicateGroups, Mode=OneWay}" SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="vm:StorageDuplicateGroup">
                                    <StackPanel Margin="0,0,0,16">
                                        <TextBlock Text="{x:Bind SizeFormatted}" FontWeight="Bold" FontSize="13" Foreground="{ThemeResource SystemAccentColor}" Margin="4,0,0,6"/>
                                        <ItemsControl ItemsSource="{x:Bind Items}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate x:DataType="vm:StorageDuplicateItem">
                                                    <Grid Padding="24,4" BorderThickness="0,0,0,1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto" />
                                                            <ColumnDefinition Width="*" />
                                                            <ColumnDefinition Width="Auto" />
                                                        </Grid.ColumnDefinitions>
                                                        <CheckBox IsChecked="{x:Bind IsSelectedForDeletion, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,8,0" MinWidth="20" />
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{x:Bind Name}" FontWeight="Bold" FontSize="12"/>
                                                            <TextBlock Text="{x:Bind Path}" FontSize="10" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="2" Text="{x:Bind LastModified}" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" VerticalAlignment="Center"/>
                                                    </Grid>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>
                </Grid>
            </PivotItem>
        </Pivot>
    </Grid>
</Page>
