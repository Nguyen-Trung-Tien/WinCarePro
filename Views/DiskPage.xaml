<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinCarePro.Views.DiskPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:engines="using:WinCarePro.Engines"
    xmlns:local="using:WinCarePro.Views"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Disk Tools &amp; Health Monitoring" Style="{ThemeResource TitleTextBlockStyle}" FontWeight="Bold" />
            <TextBlock Text="Track drive SMART details, locate duplicate files, clean empty directories, and analyze storage allocations." Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
        </StackPanel>

        <!-- Main Body Pivots -->
        <Pivot Grid.Row="1">
            <!-- Drives Health Tab -->
            <PivotItem Header="Drive Health (SMART)">
                <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="0,12,12,12" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <ListView Grid.Row="0" ItemsSource="{x:Bind ViewModel.Drives, Mode=OneWay}" SelectionMode="None">
                            <ListView.HeaderTemplate>
                                <DataTemplate>
                                    <Grid Padding="12,6" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="150" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Device Name" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="1" Text="Model" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="2" Text="SMART Status" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="3" Text="Temperature" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="4" Text="Interface Type" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="5" Text="Chkdsk Repair" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.HeaderTemplate>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="engines:DriveHealthInfo">
                                    <Grid Padding="12" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="150" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" VerticalAlignment="Center" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind Model}" VerticalAlignment="Center" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                        
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="6">
                                            <FontIcon Glyph="&#xE73E;" Foreground="{x:Bind local:DiskPage.GetHealthColor(HealthStatus), Mode=OneWay}" FontSize="12" />
                                            <TextBlock Text="{x:Bind HealthStatus}" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{x:Bind local:DiskPage.GetHealthColor(HealthStatus), Mode=OneWay}" />
                                        </StackPanel>

                                        <TextBlock Grid.Column="3" Text="{x:Bind local:DiskPage.FormatTemp(Temperature), Mode=OneWay}" VerticalAlignment="Center" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{x:Bind local:DiskPage.GetTempColor(Temperature), Mode=OneWay}" FontWeight="SemiBold" />
                                        <TextBlock Grid.Column="4" Text="{x:Bind Interface}" VerticalAlignment="Center" Style="{ThemeResource CaptionTextBlockStyle}" />

                                        <Button Grid.Column="5" Content="Run CHKDSK" Click="OnRunChkdskClick" Tag="{x:Bind Name}" IsEnabled="{Binding DataContext.IsNotBusy, ElementName=RootPage}" CornerRadius="4" FontSize="11" Padding="8,4" HorizontalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        
                        <Button Grid.Row="1" Content="Refresh Drive Info" Style="{StaticResource AccentButtonStyle}" Click="OnRefreshDrivesClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" Margin="0,12,0,0" Padding="12,6" CornerRadius="6" />
                    </Grid>
                </Border>
            </PivotItem>

            <!-- Storage Analysis Tab -->
            <PivotItem Header="Storage Analyzer">
                <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="0,12,12,12" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" ColumnSpacing="12" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{x:Bind ViewModel.StorageScanPath, Mode=TwoWay}" PlaceholderText="Enter Directory (e.g. C:\Users\Admin\Downloads)" CornerRadius="6" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Content="Analyze Folder" Style="{StaticResource AccentButtonStyle}" Click="OnAnalyzeClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="6" Padding="16,8" />
                        </Grid>

                        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.StorageItems, Mode=OneWay}" SelectionMode="None">
                            <ListView.HeaderTemplate>
                                <DataTemplate>
                                    <Grid Padding="12,6" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="50" />
                                            <ColumnDefinition Width="300" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Type" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="1" Text="Item Name" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="2" Text="Size" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="3" Text="Absolute Path" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.HeaderTemplate>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="engines:StorageItem">
                                    <Grid Padding="12" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="50" />
                                            <ColumnDefinition Width="300" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <FontIcon Glyph="{x:Bind local:DiskPage.GetTypeIcon(IsDirectory)}" Foreground="{ThemeResource SystemAccentColor}" FontSize="14" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind Name}" FontWeight="SemiBold" VerticalAlignment="Center" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="2" Text="{x:Bind SizeFormatted}" FontWeight="Bold" VerticalAlignment="Center" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="3" Text="{x:Bind Path}" VerticalAlignment="Center" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </PivotItem>

            <!-- Duplicate Files Tab -->
            <PivotItem Header="Duplicate Finder">
                <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="0,12,12,12" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" ColumnSpacing="12" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{x:Bind ViewModel.StorageScanPath, Mode=TwoWay}" PlaceholderText="Enter Directory to scan duplicates" CornerRadius="6" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Content="Scan Duplicates" Style="{StaticResource AccentButtonStyle}" Click="OnFindDuplicatesClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="6" Padding="16,8" />
                        </Grid>

                        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Duplicates, Mode=OneWay}" SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="engines:DuplicateFileGroup">
                                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource ControlAltFillColorSecondaryBrush}" CornerRadius="6" Margin="0,0,0,8" Padding="12">
                                        <StackPanel Spacing="6">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <FontIcon Glyph="&#xE71B;" Foreground="Orange" FontSize="14" />
                                                <TextBlock Text="{x:Bind local:DiskPage.FormatDuplicateGroupSize(SizeFormatted), Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}" FontWeight="Bold" />
                                            </StackPanel>
                                            <ItemsControl ItemsSource="{x:Bind FilePaths}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="x:String">
                                                        <TextBlock Text="{x:Bind}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" Margin="22,2,0,2" TextWrapping="Wrap" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </PivotItem>

            <!-- Clean Empty Folders Tab -->
            <PivotItem Header="Empty Folders Cleaner">
                <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="0,12,12,12" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" RowSpacing="12" Margin="0,0,0,16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock Text="Remove empty directories to clean up file trees and folder hierarchies." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" Margin="0,0,0,8"/>
                            <TextBox Grid.Row="1" Grid.Column="0" Text="{x:Bind ViewModel.EmptyFolderRootPath, Mode=TwoWay}" PlaceholderText="Enter Directory to clean empty directories" CornerRadius="6" VerticalAlignment="Center" />
                            <Button Grid.Row="1" Grid.Column="1" Content="Clean Empty Folders" Style="{StaticResource AccentButtonStyle}" Click="OnCleanEmptyClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" Margin="12,0,0,0" CornerRadius="6" Padding="16,8" />
                        </Grid>

                        <TextBox Grid.Row="1" Text="{x:Bind ViewModel.ConsoleOutput, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" FontFamily="Consolas" FontSize="11" Background="{ThemeResource ControlAltFillColorSecondaryBrush}" BorderThickness="0" CornerRadius="6" ScrollViewer.VerticalScrollBarVisibility="Auto" />
                    </Grid>
                </Border>
            </PivotItem>
        </Pivot>
    </Grid>
</Page>
