<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinCarePro.Views.DiskPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:engines="using:WinCarePro.Engines"
    xmlns:local="using:WinCarePro.Views"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.ChildrenTransitions>
            <TransitionCollection>
                <EntranceThemeTransition FromHorizontalOffset="0" FromVerticalOffset="20" />
            </TransitionCollection>
        </Grid.ChildrenTransitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <StackPanel>
                <TextBlock Text="Disk Tools &amp; Health Monitoring" FontSize="28" FontWeight="ExtraBold" CharacterSpacing="-10" />
                <TextBlock Text="Track drive SMART details, locate duplicate files, clean empty directories, and analyze storage allocations." Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" Margin="0,4,0,0" />
            </StackPanel>
        </Grid>

        <!-- Main Body Pivots -->
        <Pivot Grid.Row="1">
            <!-- Drives Health Tab -->
            <PivotItem Header="Drive Health (SMART)">
                <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="0,16,16,16" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <ListView Grid.Row="0" ItemsSource="{x:Bind ViewModel.Drives, Mode=OneWay}" SelectionMode="None">
                            <ListView.ItemContainerTransitions>
                                <TransitionCollection>
                                    <AddDeleteThemeTransition />
                                    <RepositionThemeTransition />
                                </TransitionCollection>
                            </ListView.ItemContainerTransitions>
                            <ListView.HeaderTemplate>
                                <DataTemplate>
                                    <Grid Padding="12,8" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="160" />
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="150" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Device Name" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="1" Text="Model" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="2" Text="SMART Status" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="3" Text="Temperature" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="4" Text="Interface Type" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="5" Text="Chkdsk Repair" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.HeaderTemplate>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="engines:DriveHealthInfo" xmlns:engines="using:WinCarePro.Engines">
                                    <Grid Padding="12,10" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="160" />
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="150" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{x:Bind Name}" FontWeight="Bold" FontSize="13.5" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind Model}" VerticalAlignment="Center" FontSize="12.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                        
                                        <!-- Health Badge -->
                                        <Border Grid.Column="2" Background="{x:Bind local:DiskPage.GetHealthBadgeBg(HealthStatus), Mode=OneWay}" CornerRadius="6" Padding="10,5" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE73E;" Foreground="{x:Bind local:DiskPage.GetHealthColor(HealthStatus), Mode=OneWay}" FontSize="11" VerticalAlignment="Center" />
                                                <TextBlock Text="{x:Bind HealthStatus}" FontWeight="Bold" FontSize="11" Foreground="{x:Bind local:DiskPage.GetHealthColor(HealthStatus), Mode=OneWay}" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Border>

                                        <!-- Temperature Badge -->
                                        <Border Grid.Column="3" Background="{x:Bind local:DiskPage.GetTempBadgeBg(Temperature), Mode=OneWay}" CornerRadius="6" Padding="10,5" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind local:DiskPage.FormatTemp(Temperature), Mode=OneWay}" FontWeight="Bold" FontSize="11" Foreground="{x:Bind local:DiskPage.GetTempColor(Temperature), Mode=OneWay}" />
                                        </Border>

                                        <TextBlock Grid.Column="4" Text="{x:Bind Interface}" VerticalAlignment="Center" FontSize="12.5" />

                                        <Button Grid.Column="5" Content="Run CHKDSK" Click="OnRunChkdskClick" Tag="{x:Bind Name}" IsEnabled="{Binding DataContext.IsNotBusy, ElementName=RootPage}" CornerRadius="6" FontSize="11" Padding="10,5" HorizontalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                        
                        <Button Grid.Row="1" Content="Refresh Drive Info" Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" Click="OnRefreshDrivesClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" Margin="0,12,0,0" Padding="14,7" CornerRadius="6" FontWeight="SemiBold" />
                    </Grid>
                </Border>
            </PivotItem>

            <!-- Storage Analysis Tab -->
            <PivotItem Header="Storage Analyzer">
                <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="0,16,16,16" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" ColumnSpacing="12" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{x:Bind ViewModel.StorageScanPath, Mode=TwoWay}" PlaceholderText="Enter Directory (e.g. C:\Users\Admin\Downloads)" CornerRadius="6" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Content="Analyze Folder" Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" Click="OnAnalyzeClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="6" Padding="18,8" FontWeight="Bold" />
                        </Grid>

                        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.StorageItems, Mode=OneWay}" SelectionMode="None">
                            <ListView.ItemContainerTransitions>
                                <TransitionCollection>
                                    <AddDeleteThemeTransition />
                                    <RepositionThemeTransition />
                                </TransitionCollection>
                            </ListView.ItemContainerTransitions>
                            <ListView.HeaderTemplate>
                                <DataTemplate>
                                    <Grid Padding="12,8" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60" />
                                            <ColumnDefinition Width="300" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Type" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="1" Text="Item Name" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="2" Text="Size" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="3" Text="Absolute Path" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.HeaderTemplate>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="engines:StorageItem" xmlns:engines="using:WinCarePro.Engines">
                                    <Grid Padding="12,10" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="60" />
                                            <ColumnDefinition Width="300" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <Border Width="30" Height="30" Background="#107F56D9" CornerRadius="6" VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <FontIcon Glyph="{x:Bind local:DiskPage.GetTypeIcon(IsDirectory)}" Foreground="{ThemeResource SystemAccentColor}" FontSize="14" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                        </Border>
                                        <TextBlock Grid.Column="1" Text="{x:Bind Name}" FontWeight="Bold" FontSize="13.5" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="2" Text="{x:Bind SizeFormatted}" FontWeight="Bold" FontSize="13.5" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="3" Text="{x:Bind Path}" VerticalAlignment="Center" FontSize="12.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </PivotItem>

            <!-- Duplicate Files Tab -->
            <PivotItem Header="Duplicate Finder">
                <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="0,16,16,16" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" ColumnSpacing="12" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{x:Bind ViewModel.StorageScanPath, Mode=TwoWay}" PlaceholderText="Enter Directory to scan duplicates" CornerRadius="6" VerticalAlignment="Center" />
                            <Button Grid.Column="1" Content="Scan Duplicates" Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" Click="OnFindDuplicatesClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="6" Padding="18,8" FontWeight="Bold" />
                        </Grid>

                        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Duplicates, Mode=OneWay}" SelectionMode="None">
                            <ListView.ItemContainerTransitions>
                                <TransitionCollection>
                                    <AddDeleteThemeTransition />
                                    <RepositionThemeTransition />
                                </TransitionCollection>
                            </ListView.ItemContainerTransitions>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="engines:DuplicateFileGroup" xmlns:engines="using:WinCarePro.Engines">
                                    <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource ControlAltFillColorSecondaryBrush}" CornerRadius="10" Margin="0,0,0,10" Padding="14">
                                        <StackPanel Spacing="8">
                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <Border Width="24" Height="24" Background="#15FF8C00" CornerRadius="12">
                                                    <FontIcon Glyph="&#xE71B;" Foreground="Orange" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                </Border>
                                                <TextBlock Text="{x:Bind local:DiskPage.FormatDuplicateGroupSize(SizeFormatted), Mode=OneWay}" FontSize="13.5" FontWeight="Bold" Foreground="Orange" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <ItemsControl ItemsSource="{x:Bind FilePaths}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate x:DataType="x:String">
                                                        <TextBlock Text="{x:Bind}" FontSize="12.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" Margin="32,2,0,2" TextWrapping="Wrap" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </PivotItem>

            <!-- Clean Empty Folders Tab -->
            <PivotItem Header="Empty Folders Cleaner">
                <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="0,16,16,16" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" RowSpacing="12" Margin="0,0,0,16">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            
                            <TextBlock Text="Remove empty directories to clean up file trees and folder hierarchies." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" Margin="0,0,0,8"/>
                            <TextBox Grid.Row="1" Grid.Column="0" Text="{x:Bind ViewModel.EmptyFolderRootPath, Mode=TwoWay}" PlaceholderText="Enter Directory to clean empty directories" CornerRadius="6" VerticalAlignment="Center" />
                            <Button Grid.Row="1" Grid.Column="1" Content="Clean Empty Folders" Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" Click="OnCleanEmptyClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" Margin="12,0,0,0" CornerRadius="6" Padding="18,8" FontWeight="Bold" />
                        </Grid>

                        <!-- Terminal Output Console -->
                        <Grid Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            
                            <!-- Header Title Bar -->
                            <Border Grid.Row="0" Background="#1E293B" CornerRadius="12,12,0,0" Padding="12,10" BorderBrush="#447F56D9" BorderThickness="1.5,1.5,1.5,0">
                                <Grid>
                                    <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                        <Ellipse Width="10" Height="10" Fill="#FFEF4444" />
                                        <Ellipse Width="10" Height="10" Fill="#FFF59E0B" />
                                        <Ellipse Width="10" Height="10" Fill="#FF10B981" />
                                        <TextBlock Text="Empty Folder Cleaner Output" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="8,0,0,0" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <FontIcon Glyph="&#xE756;" FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </Border>
                            
                            <TextBox Grid.Row="1" Text="{x:Bind ViewModel.ConsoleOutput, Mode=OneWay}" Style="{StaticResource DarkTerminalStyle}" CornerRadius="0,0,12,12" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" ScrollViewer.VerticalScrollBarVisibility="Auto" />
                        </Grid>
                    </Grid>
                </Border>
            </PivotItem>
        </Pivot>
    </Grid>
</Page>
