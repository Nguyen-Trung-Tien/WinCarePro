<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinCarePro.Views.DriverPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:WinCarePro.Models"
    xmlns:vm="using:WinCarePro.ViewModels"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="4">
                <TextBlock Text="Driver Updater" FontSize="26" FontWeight="ExtraBold" CharacterSpacing="-0.5" />
                <TextBlock Text="Scan and verify hardware drivers, firmware updates, and motherboard controller status." FontSize="13" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button Content="Scan Drivers" Click="OnScanDriversClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}"/>
                <Button Content="Run Driver Wizard" Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" Click="OnRunDriverWizardClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}"/>
            </StackPanel>
        </Grid>

        <!-- Content Split -->
        <Grid Grid.Row="1" ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="340" />
            </Grid.ColumnDefinitions>

            <!-- Left: Driver List -->
            <Border Grid.Column="0" Style="{StaticResource ModernCardStyle}" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Hardware Classification Drivers" FontSize="15" FontWeight="Bold" Margin="0,0,0,12" />

                    <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Drivers, Mode=OneWay}" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:DriverInfo">
                                <Grid Padding="4,6" BorderThickness="0,0,0,1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="100" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox IsChecked="{x:Bind IsSelected, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,12,0" MinWidth="20" Visibility="{x:Bind HasUpdate, Converter={StaticResource BooleanToVisibilityConverter}}" />
                                    
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Name}" FontWeight="Bold" FontSize="12.5"/>
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <TextBlock Text="{x:Bind DeviceClass}" FontSize="10" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                            <TextBlock Text="{x:Bind Provider}" FontSize="10" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                        </StackPanel>
                                    </StackPanel>

                                    <TextBlock Grid.Column="2" Text="{x:Bind DriverVersion}" FontSize="11.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,16,0"/>
                                    <TextBlock Grid.Column="3" Text="{x:Bind UpdateStatus}" FontSize="11.5" FontWeight="SemiBold" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- Right: Wizard Stepper Panel -->
            <Border Grid.Column="1" Style="{StaticResource ModernCardStyle}" Padding="20">
                <StackPanel Spacing="20">
                    <TextBlock Text="Driver Wizard Installation" FontSize="16" FontWeight="Bold" />
                    
                    <StackPanel Spacing="10" Margin="0,8,0,0">
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border Width="20" Height="20" CornerRadius="10" Background="{x:Bind GetStepBg(ViewModel.DriverWizardStep, 1), Mode=OneWay}" VerticalAlignment="Center">
                                <TextBlock Text="1" FontSize="10" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Scan component firmware" FontSize="12" FontWeight="{x:Bind GetStepWeight(ViewModel.DriverWizardStep, 1), Mode=OneWay}" VerticalAlignment="Center"/>
                        </StackPanel>
                        
                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border Width="20" Height="20" CornerRadius="10" Background="{x:Bind GetStepBg(ViewModel.DriverWizardStep, 2), Mode=OneWay}" VerticalAlignment="Center">
                                <TextBlock Text="2" FontSize="10" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Download installer binaries" FontSize="12" FontWeight="{x:Bind GetStepWeight(ViewModel.DriverWizardStep, 2), Mode=OneWay}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border Width="20" Height="20" CornerRadius="10" Background="{x:Bind GetStepBg(ViewModel.DriverWizardStep, 3), Mode=OneWay}" VerticalAlignment="Center">
                                <TextBlock Text="3" FontSize="10" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Compile &amp; Install firmware" FontSize="12" FontWeight="{x:Bind GetStepWeight(ViewModel.DriverWizardStep, 3), Mode=OneWay}" VerticalAlignment="Center"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="10">
                            <Border Width="20" Height="20" CornerRadius="10" Background="{x:Bind GetStepBg(ViewModel.DriverWizardStep, 4), Mode=OneWay}" VerticalAlignment="Center">
                                <TextBlock Text="4" FontSize="10" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <TextBlock Text="Verify active hardware threads" FontSize="12" FontWeight="{x:Bind GetStepWeight(ViewModel.DriverWizardStep, 4), Mode=OneWay}" VerticalAlignment="Center"/>
                        </StackPanel>
                    </StackPanel>

                    <ProgressBar Value="{x:Bind ViewModel.ProgressPercent, Mode=OneWay}" Maximum="100" Height="8" CornerRadius="4" Foreground="{StaticResource PrimaryAccentGradient}" Margin="0,12,0,0"/>
                    <TextBlock Text="{x:Bind ViewModel.ProgressMessage, Mode=OneWay}" FontSize="12" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
