<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinCarePro.Views.HardwarePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:WinCarePro.ViewModels"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <StackPanel Spacing="4">
                <TextBlock Text="Hardware Monitoring Engine" FontSize="26" FontWeight="ExtraBold" CharacterSpacing="-0.5" />
                <TextBlock Text="Bare-metal hardware status, thermal sensors telemetry, and battery wear calculations." FontSize="13" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid RowSpacing="20" ColumnSpacing="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <!-- CPU Diagnostics -->
                <Border Grid.Row="0" Grid.Column="0" Style="{StaticResource ModernCardStyle}" Padding="20">
                    <StackPanel Spacing="16">
                        <TextBlock Text="CPU Diagnostic Array" FontSize="16" FontWeight="Bold" />
                        <TextBlock Text="{x:Bind ViewModel.CpuModel, Mode=OneWay}" FontSize="13.5" FontWeight="SemiBold" Foreground="{ThemeResource SystemAccentColor}"/>
                        
                        <Grid ColumnSpacing="16" RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                                <TextBlock Text="Core Temperature" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.CpuTempFormatted, Mode=OneWay}" FontSize="18" FontWeight="Bold"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                <TextBlock Text="Frequency Speed" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.CpuFreqFormatted, Mode=OneWay}" FontSize="18" FontWeight="Bold"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4">
                                <TextBlock Text="Operational Power" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.CpuPowerFormatted, Mode=OneWay}" FontSize="18" FontWeight="Bold"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                                <TextBlock Text="Core Topology" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.CpuSpecs, Mode=OneWay}" FontSize="12.5" FontWeight="SemiBold" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- GPU Diagnostics -->
                <Border Grid.Row="0" Grid.Column="1" Style="{StaticResource ModernCardStyle}" Padding="20">
                    <StackPanel Spacing="16">
                        <TextBlock Text="GPU Diagnostic Array" FontSize="16" FontWeight="Bold" />
                        <TextBlock Text="{x:Bind ViewModel.GpuModel, Mode=OneWay}" FontSize="13.5" FontWeight="SemiBold" Foreground="{ThemeResource SystemAccentColor}"/>
                        
                        <Grid ColumnSpacing="16" RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                                <TextBlock Text="Junction Temperature" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.GpuTempFormatted, Mode=OneWay}" FontSize="18" FontWeight="Bold"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                <TextBlock Text="Processing Load" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.GpuLoadFormatted, Mode=OneWay}" FontSize="18" FontWeight="Bold"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4">
                                <TextBlock Text="Fan Speed Controller" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.GpuFanRpmFormatted, Mode=OneWay}" FontSize="18" FontWeight="Bold"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- RAM Allocation & Storage Telemetry -->
                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource ModernCardStyle}" Padding="20">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Memory &amp; Storage Layout" FontSize="16" FontWeight="Bold" />
                        
                        <StackPanel Spacing="8">
                            <TextBlock Text="RAM Capacity Mode" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                            <TextBlock Text="{x:Bind ViewModel.RamModel, Mode=OneWay}" FontSize="13" FontWeight="Bold"/>
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="{x:Bind ViewModel.RamCommittedGb, Mode=OneWay}" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                <TextBlock Grid.Column="1" Text="{x:Bind ViewModel.RamCachedGb, Mode=OneWay}" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>

                        <MenuFlyoutSeparator />

                        <StackPanel Spacing="8">
                            <TextBlock Text="Physical Storage Controllers" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                            <TextBlock Text="{x:Bind ViewModel.StorageSummary, Mode=OneWay}" FontSize="12.5" FontWeight="SemiBold" TextWrapping="Wrap"/>
                            <Grid Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="Read: 250 MB/s" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                <TextBlock Grid.Column="1" Text="Write: 180 MB/s" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Battery Health Matrix (Laptops) -->
                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource ModernCardStyle}" Padding="20">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Battery Health Matrix (Laptops)" FontSize="16" FontWeight="Bold" />
                        
                        <Grid ColumnSpacing="16" RowSpacing="12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                                <TextBlock Text="Charge Percentage" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.BatteryPercentFormatted, Mode=OneWay}" FontSize="18" FontWeight="Bold"/>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                                <TextBlock Text="Status Connection" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.BatteryStatus, Mode=OneWay}" FontSize="18" FontWeight="Bold"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Spacing="4">
                                <TextBlock Text="Wear Level Index" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.BatteryWearLevelFormatted, Mode=OneWay}" FontSize="18" FontWeight="Bold"/>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1" Spacing="4">
                                <TextBlock Text="Battery Lifecycle" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.BatteryCycles, Mode=OneWay}" FontSize="18" FontWeight="Bold"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="0" Spacing="4">
                                <TextBlock Text="Design Target" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.BatteryDesignCapacity, Mode=OneWay}" FontSize="13" FontWeight="Bold"/>
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="1" Spacing="4">
                                <TextBlock Text="Full Charge Capacity" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                <TextBlock Text="{x:Bind ViewModel.BatteryFullChargeCapacity, Mode=OneWay}" FontSize="13" FontWeight="Bold"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Motherboard & BIOS Specs -->
                <Border Grid.Row="2" Grid.ColumnSpan="2" Style="{StaticResource ModernCardStyle}" Padding="20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="6">
                            <TextBlock Text="Motherboard Hardware" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                            <TextBlock Text="{x:Bind ViewModel.Motherboard, Mode=OneWay}" FontSize="14" FontWeight="Bold"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="6" HorizontalAlignment="Right">
                            <TextBlock Text="Firmware (BIOS Version)" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                            <TextBlock Text="{x:Bind ViewModel.BiosVersion, Mode=OneWay}" FontSize="14" FontWeight="Bold"/>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
