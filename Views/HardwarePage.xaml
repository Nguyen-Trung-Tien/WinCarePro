<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinCarePro.Views.HardwarePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:WinCarePro.Models"
    xmlns:local="using:WinCarePro.Views"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Hardware &amp; Driver Specifications" Style="{ThemeResource TitleTextBlockStyle}" FontWeight="Bold" />
                <TextBlock Text="View detailed hardware attributes and manage signed device drivers." Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
            </StackPanel>
            <Button Grid.Column="1" Content="Refresh Hardware Info" Style="{StaticResource AccentButtonStyle}" Click="OnRefreshClick" IsEnabled="{x:Bind IsNot(IsLoading), Mode=OneWay}" VerticalAlignment="Center" Padding="16,8" CornerRadius="6" />
        </Grid>

        <!-- Pivot Tabs -->
        <Pivot Grid.Row="1">
            <!-- Hardware Specs Tab -->
            <PivotItem Header="System Specifications">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <Grid RowSpacing="16" ColumnSpacing="16" Margin="0,12,0,0">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- OS Card -->
                        <Border Grid.Row="0" Grid.Column="0" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Operating System" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                <TextBlock Text="{x:Bind Specs.OsVersion, Mode=OneWay}" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="Bold" TextWrapping="Wrap" />
                                <TextBlock Text="{x:Bind FormatUptime(Specs.SystemUptime), Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                            </StackPanel>
                        </Border>

                        <!-- CPU Card -->
                        <Border Grid.Row="0" Grid.Column="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Processor (CPU)" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                <TextBlock Text="{x:Bind Specs.CpuModel, Mode=OneWay}" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="Bold" TextWrapping="Wrap" />
                                <TextBlock Text="{x:Bind GetCpuDetailString(Specs.CpuCores, Specs.CpuThreads, Specs.CpuSpeed), Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                            </StackPanel>
                        </Border>

                        <!-- RAM Card -->
                        <Border Grid.Row="1" Grid.Column="0" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Memory (RAM)" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                <TextBlock Text="{x:Bind FormatRamSize(Specs.RamCapacityGb), Mode=OneWay}" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="Bold" />
                                <TextBlock Text="{x:Bind FormatRamSpeed(Specs.RamSpeed), Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                            </StackPanel>
                        </Border>

                        <!-- GPU Card -->
                        <Border Grid.Row="1" Grid.Column="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Graphics Card (GPU)" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                <TextBlock Text="{x:Bind Specs.GpuModel, Mode=OneWay}" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="Bold" TextWrapping="Wrap" />
                                <TextBlock Text="{x:Bind GetGpuDetailString(Specs.GpuVram, Specs.GpuDriverVersion), Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                            </StackPanel>
                        </Border>

                        <!-- Motherboard Card -->
                        <Border Grid.Row="2" Grid.Column="0" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Motherboard &amp; BIOS" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                <TextBlock Text="{x:Bind GetMotherboardString(Specs.MotherboardManufacturer, Specs.MotherboardModel), Mode=OneWay}" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="Bold" TextWrapping="Wrap" />
                                <TextBlock Text="{x:Bind FormatBiosVersion(Specs.BiosVersion), Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                            </StackPanel>
                        </Border>

                        <!-- Storage Summary Card -->
                        <Border Grid.Row="2" Grid.Column="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Logical Storage Partitions" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                <TextBlock Text="{x:Bind Specs.StorageInfo, Mode=OneWay}" Style="{ThemeResource BodyTextBlockStyle}" FontWeight="SemiBold" TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>
            </PivotItem>

            <!-- Drivers Manager Tab -->
            <PivotItem Header="Signed Kernel Drivers">
                <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="0,12,12,12" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBox x:Name="DriverSearchInput" TextChanged="OnDriverSearchChanged" PlaceholderText="Search drivers by name or provider..." Margin="0,0,0,16" CornerRadius="6" Width="300" HorizontalAlignment="Left" />

                        <ListView Grid.Row="1" ItemsSource="{x:Bind FilteredDrivers, Mode=OneWay}" SelectionMode="None">
                            <ListView.HeaderTemplate>
                                <DataTemplate>
                                    <Grid Padding="12,6" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="300" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Driver / Device Name" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="1" Text="Provider" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="2" Text="Device Class" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="3" Text="Version" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="4" Text="Driver Date" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="5" Text="Update Recommendation" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.HeaderTemplate>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:DriverInfo">
                                    <Grid Padding="12" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="300" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" VerticalAlignment="Center" Style="{ThemeResource CaptionTextBlockStyle}" TextWrapping="NoWrap" Margin="0,0,8,0" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind Provider}" VerticalAlignment="Center" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="2" Text="{x:Bind DeviceClass}" VerticalAlignment="Center" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="3" Text="{x:Bind DriverVersion}" VerticalAlignment="Center" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="4" Text="{x:Bind DriverDate}" VerticalAlignment="Center" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />

                                        <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <FontIcon Glyph="{x:Bind local:HardwarePage.GetUpdateIcon(HasUpdate), Mode=OneWay}" Foreground="{x:Bind local:HardwarePage.GetUpdateColor(HasUpdate), Mode=OneWay}" FontSize="12" />
                                            <TextBlock Text="{x:Bind local:HardwarePage.GetUpdateLabel(HasUpdate, AvailableVersion), Mode=OneWay}" Foreground="{x:Bind local:HardwarePage.GetUpdateColor(HasUpdate), Mode=OneWay}" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </PivotItem>
        </Pivot>

        <ProgressRing Grid.Row="1" IsActive="{x:Bind IsLoading, Mode=OneWay}" Width="48" Height="48" HorizontalAlignment="Center" VerticalAlignment="Center" />
    </Grid>
</Page>
