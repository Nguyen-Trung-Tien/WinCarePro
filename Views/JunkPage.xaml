<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinCarePro.Views.JunkPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:WinCarePro.Models"
    xmlns:local="using:WinCarePro.Views"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.ChildrenTransitions>
            <TransitionCollection>
                <EntranceThemeTransition FromHorizontalOffset="0" FromVerticalOffset="20" />
            </TransitionCollection>
        </Grid.ChildrenTransitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Junk Files Cleaner" FontSize="28" FontWeight="ExtraBold" CharacterSpacing="-10" />
                <TextBlock Text="Reclaim storage space by safely scanning and cleaning temporary caches, logs, and user trash." Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" Margin="0,4,0,0" />
            </StackPanel>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <Button Content="Scan Junk" Style="{StaticResource DefaultButtonStyle}" Click="OnScanClick" IsEnabled="{x:Bind IsNot(ViewModel.IsScanning), Mode=OneWay}" Padding="18,9" CornerRadius="8" FontWeight="SemiBold" />
                <Button Content="Clean Selected" Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" Click="OnCleanClick" IsEnabled="{x:Bind CanClean(ViewModel.IsCleaning, ViewModel.Categories.Count), Mode=OneWay}" Padding="18,9" CornerRadius="8" FontWeight="SemiBold" />
            </StackPanel>
        </Grid>

        <!-- Main Body -->
        <Grid Grid.Row="1" ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <!-- Categories List -->
            <Border Grid.Column="0" Style="{StaticResource ModernCardStyle}" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="Junk Locations" FontSize="18" FontWeight="Bold" Margin="0,0,0,16" />
                    
                    <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}" SelectionMode="None">
                        <ListView.ItemContainerTransitions>
                            <TransitionCollection>
                                <AddDeleteThemeTransition />
                                <RepositionThemeTransition />
                            </TransitionCollection>
                        </ListView.ItemContainerTransitions>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:JunkCategory">
                                <Grid Padding="8,12" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <CheckBox Grid.Column="0" IsChecked="{x:Bind IsSelected, Mode=TwoWay}" Checked="OnSelectionChanged" Unchecked="OnSelectionChanged" VerticalAlignment="Center" Margin="0,0,12,0" />
                                    
                                    <Border Grid.Column="1" Width="38" Height="38" Background="{ThemeResource ControlAltFillColorSecondaryBrush}" CornerRadius="10" Margin="0,0,12,0" VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <FontIcon Glyph="{x:Bind local:JunkPage.GetCategoryIcon(Name)}" Foreground="{x:Bind local:JunkPage.GetCategoryIconColor(Name)}" FontSize="18" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                    </Border>
                                    
                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Text="{x:Bind Name}" FontWeight="Bold" FontSize="13.5" Style="{ThemeResource BodyTextBlockStyle}" />
                                        <TextBlock Text="{x:Bind Description}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" LineHeight="14" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right" Spacing="2">
                                        <TextBlock Text="{x:Bind SizeFormatted}" FontWeight="Bold" Style="{ThemeResource BodyTextBlockStyle}" HorizontalAlignment="Right" Foreground="{ThemeResource SystemAccentColor}" />
                                        <TextBlock Text="{x:Bind local:JunkPage.FormatFilesCount(FileCount), Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" HorizontalAlignment="Right" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- Progress & Actions Status -->
            <Grid Grid.Column="1" RowSpacing="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Status Gauge Card -->
                <Border Grid.Row="0" Style="{StaticResource GradientBorderCardStyle}" Padding="28">
                    <StackPanel Spacing="16" HorizontalAlignment="Center">
                        <!-- Custom Icon Background Circle -->
                        <Border Width="56" Height="56" Background="#157F56D9" CornerRadius="28" HorizontalAlignment="Center">
                            <FontIcon Glyph="&#xE74D;" FontSize="24" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                        </Border>
                        <StackPanel Spacing="4">
                            <TextBlock Text="Total Cleanable Space" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" HorizontalAlignment="Center" />
                            <TextBlock Text="{x:Bind ViewModel.TotalJunkSize, Mode=OneWay}" FontSize="36" FontWeight="ExtraBold" Foreground="{ThemeResource SystemAccentColor}" HorizontalAlignment="Center" CharacterSpacing="-20" />
                        </StackPanel>
                        
                        <ProgressBar Value="{x:Bind ViewModel.ProgressPercent, Mode=OneWay}" Maximum="100" Height="8" CornerRadius="4" Width="220" HorizontalAlignment="Center" Foreground="{StaticResource PrimaryAccentGradient}" />
                        <TextBlock Text="{x:Bind ViewModel.ProgressMessage, Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Recommendation / Warning Warning Card -->
                <Border Grid.Row="1" Style="{StaticResource ModernCardStyle}" Padding="24">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Junk Cleaner Instructions" FontSize="18" FontWeight="Bold" Margin="0,0,0,16" />
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="12">
                                <TextBlock Text="• Cleaning files is entirely safe. Browser caches will rebuild next time you launch Chrome or Edge." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" LineHeight="16" />
                                <TextBlock Text="• Windows Update cache logs are installer backups. Safely clean them if your updates are working." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" LineHeight="16" />
                                <TextBlock Text="• Font and Thumbnail caches are visual previews. Clearing them forces Windows to recreate them, fixing display bugs." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" LineHeight="16" />
                                <TextBlock Text="• DirectX Shader caches stores precompiled graphics shaders. Clearing them helps fix visual stutter in games." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" LineHeight="16" />
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
