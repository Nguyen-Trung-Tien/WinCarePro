<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinCarePro.Views.JunkPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:WinCarePro.Models"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Top Metric Banner -->
        <Border Grid.Row="0" Margin="0,0,0,16" Style="{StaticResource ModernCardStyle}" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <StackPanel Spacing="4">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="Current Junk:" FontSize="16" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.TotalJunkSize, Mode=OneWay}" FontSize="24" FontWeight="Bold" Foreground="{ThemeResource SystemAccentColor}" />
                    </StackPanel>
                    <TextBlock Text="Safe cleanup files. Empty the recycle bin, Windows installers cache, and directx shaders." FontSize="12.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Button Content="Scan Directories" Style="{StaticResource DefaultButtonStyle}" Click="OnScanJunkClick" IsEnabled="{x:Bind IsNot(ViewModel.IsScanning), Mode=OneWay}" Padding="16,8" CornerRadius="6" />
                    <Button Content="Clean Now" Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" Click="OnCleanJunkClick" IsEnabled="{x:Bind CanClean(ViewModel.IsCleaning, ViewModel.Categories.Count), Mode=OneWay}" Padding="18,8" CornerRadius="6" FontWeight="SemiBold" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <!-- Discovery Grid -->
            <Border Grid.Column="0" Style="{StaticResource ModernCardStyle}" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Junk Categories" FontSize="16" FontWeight="Bold" Margin="0,0,0,12" />
                    
                    <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:JunkCategory">
                                <Grid Padding="4,8" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <CheckBox Grid.Column="0" IsChecked="{x:Bind IsSelected, Mode=TwoWay}" Checked="OnJunkSelectionChanged" Unchecked="OnJunkSelectionChanged" VerticalAlignment="Center" Margin="0,0,12,0" />
                                    
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Text="{x:Bind Name}" FontWeight="Bold" FontSize="13" />
                                        <TextBlock Text="{x:Bind Description}" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right" Spacing="2">
                                        <TextBlock Text="{x:Bind SizeFormatted}" FontWeight="Bold" FontSize="13" Foreground="{ThemeResource SystemAccentColor}" />
                                        <TextBlock Text="{x:Bind FileCountFormatted}" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" HorizontalAlignment="Right" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- Progress & Log Viewer -->
            <Grid Grid.Column="1" RowSpacing="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource ModernCardStyle}" Padding="16">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Cleanup Progress" FontWeight="Bold" FontSize="14" />
                        <Grid Height="80" Width="80" HorizontalAlignment="Center">
                            <ProgressRing IsActive="{x:Bind GetProgressRingActive(ViewModel.IsScanning, ViewModel.IsCleaning), Mode=OneWay}" Width="60" Height="60" />
                        </Grid>
                        <ProgressBar Value="{x:Bind ViewModel.ProgressPercent, Mode=OneWay}" Maximum="100" Height="6" CornerRadius="3" Foreground="{StaticResource PrimaryAccentGradient}" />
                        <TextBlock Text="{x:Bind ViewModel.ProgressMessage, Mode=OneWay}" TextWrapping="Wrap" FontSize="12.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextAlignment="Center" />
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource ModernCardStyle}" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Live Operations Trace" FontWeight="Bold" FontSize="14" Margin="0,0,0,8" />
                        <TextBox Grid.Row="1" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" FontFamily="Consolas" FontSize="11.5" Text="{x:Bind ViewModel.ProgressMessage, Mode=OneWay}" Background="#0A0E1A" Foreground="#00F2FE" BorderThickness="0" CornerRadius="6" Padding="8" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
