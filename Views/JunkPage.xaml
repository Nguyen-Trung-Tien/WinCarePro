<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinCarePro.Views.JunkPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:WinCarePro.Models"
    xmlns:local="using:WinCarePro.Views"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Junk Files Cleaner" Style="{ThemeResource TitleTextBlockStyle}" FontWeight="Bold" />
                <TextBlock Text="Reclaim storage space by safely scanning and cleaning temporary caches, logs, and user trash." Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
            </StackPanel>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <Button Content="Scan Junk" Style="{StaticResource DefaultButtonStyle}" Click="OnScanClick" IsEnabled="{x:Bind IsNot(ViewModel.IsScanning), Mode=OneWay}" Padding="16,8" CornerRadius="6" />
                <Button Content="Clean Selected" Style="{StaticResource AccentButtonStyle}" Click="OnCleanClick" IsEnabled="{x:Bind CanClean(ViewModel.IsCleaning, ViewModel.Categories.Count), Mode=OneWay}" Padding="16,8" CornerRadius="6" />
            </StackPanel>
        </Grid>

        <!-- Main Body -->
        <Grid Grid.Row="1" ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <!-- Categories List -->
            <Border Grid.Column="0" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="Junk Locations" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="Bold" Margin="0,0,0,16" />
                    
                    <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:JunkCategory">
                                <Grid Padding="8,12" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    
                                    <CheckBox IsChecked="{x:Bind IsSelected, Mode=TwoWay}" Checked="OnSelectionChanged" Unchecked="OnSelectionChanged" VerticalAlignment="Center" Margin="0,0,12,0" />
                                    
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" Style="{ThemeResource BodyTextBlockStyle}" />
                                        <TextBlock Text="{x:Bind Description}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" />
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right" Spacing="2">
                                        <TextBlock Text="{x:Bind SizeFormatted}" FontWeight="Bold" Style="{ThemeResource BodyTextBlockStyle}" HorizontalAlignment="Right" />
                                        <TextBlock Text="{x:Bind local:JunkPage.FormatFilesCount(FileCount), Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" HorizontalAlignment="Right" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- Progress & Actions Status -->
            <Grid Grid.Column="1" RowSpacing="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Status Gauge Card -->
                <Border Grid.Row="0" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="20">
                    <StackPanel Spacing="16" HorizontalAlignment="Center">
                        <TextBlock Text="Total Cleanable Space" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="Bold" HorizontalAlignment="Center" />
                        <TextBlock Text="{x:Bind ViewModel.TotalJunkSize, Mode=OneWay}" Style="{ThemeResource HeaderTextBlockStyle}" FontWeight="ExtraBold" Foreground="{ThemeResource SystemAccentColor}" HorizontalAlignment="Center" />
                        
                        <ProgressBar Value="{x:Bind ViewModel.ProgressPercent, Mode=OneWay}" Maximum="100" Height="8" CornerRadius="4" Width="200" HorizontalAlignment="Center" Margin="0,8,0,0"/>
                        <TextBlock Text="{x:Bind ViewModel.ProgressMessage, Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Recommendation / Warning Warning Card -->
                <Border Grid.Row="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Junk Cleaner Instructions" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="Bold" Margin="0,0,0,12" />
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="12">
                                <TextBlock Text="• Cleaning files is entirely safe. Browser caches will rebuild next time you launch Chrome or Edge." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" />
                                <TextBlock Text="• Windows Update cache logs are installer backups. Safely clean them if your updates are working." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" />
                                <TextBlock Text="• Font and Thumbnail caches are visual previews. Clearing them forces Windows to recreate them, fixing display bugs." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" />
                                <TextBlock Text="• DirectX Shader caches stores precompiled graphics shaders. Clearing them helps fix visual stutter in games." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" />
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
