<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinCarePro.Views.JunkPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:WinCarePro.Models"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Top Action & Status Banner (Frosted Glassmorphism Card) -->
        <Border Grid.Row="0" Margin="0,0,0,18" Style="{StaticResource GlassmorphismCardStyle}" Padding="20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Left: Big Stat Display -->
                <StackPanel Spacing="6" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="48" Height="48" CornerRadius="24" Background="#207F56D9" Margin="0,0,16,0" HorizontalAlignment="Center" VerticalAlignment="Center">
                        <FontIcon Glyph="&#xEA99;" Foreground="#FF7F56D9" FontSize="20" />
                    </Border>
                    <StackPanel Spacing="2" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <TextBlock Text="Current Garbage Debris:" FontSize="15" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" VerticalAlignment="Bottom" />
                            <TextBlock Text="{x:Bind ViewModel.TotalJunkSize, Mode=OneWay}" FontSize="24" FontWeight="Bold" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Bottom" Margin="0,0,0,-2" />
                        </StackPanel>
                        <TextBlock Text="Safely scan and clean up system logs, cache databases, download installers, and system debris." FontSize="12" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                    </StackPanel>
                </StackPanel>

                <!-- Right: Scan & Clean Actions -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Button Style="{StaticResource DefaultButtonStyle}" Click="OnScanJunkClick" IsEnabled="{x:Bind IsNot(ViewModel.IsScanning), Mode=OneWay}" Padding="16,8" CornerRadius="6">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE721;" FontSize="13" />
                            <TextBlock Text="Scan Directories" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" Click="OnCleanJunkClick" IsEnabled="{x:Bind CanClean(ViewModel.IsCleaning, ViewModel.Categories.Count), Mode=OneWay}" Padding="18,8" CornerRadius="6" FontWeight="SemiBold">
                        <StackPanel Orientation="Horizontal" Spacing="8">
                            <FontIcon Glyph="&#xE74D;" FontSize="13" Foreground="White" />
                            <TextBlock Text="Clean Now" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Main Body: Two Pane Layout -->
        <Grid Grid.Row="1" ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="0.8*" />
            </Grid.ColumnDefinitions>

            <!-- Left Pane: Categories List -->
            <Border Grid.Column="0" Style="{StaticResource ModernCardStyle}" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    
                    <TextBlock Grid.Row="0" Text="Junk Categories" FontSize="16" FontWeight="Bold" Margin="4,0,0,12" />
                    
                    <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}" SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}" SelectionMode="Single">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="0" />
                                <Setter Property="Margin" Value="0,0,0,8" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:JunkCategory">
                                <Border Style="{StaticResource ModernCardStyle}" Padding="12,10" BorderThickness="1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />  <!-- CheckBox -->
                                            <ColumnDefinition Width="Auto" />  <!-- Circle Icon -->
                                            <ColumnDefinition Width="*" />     <!-- Label Details -->
                                            <ColumnDefinition Width="Auto" />  <!-- Size & File Count -->
                                        </Grid.ColumnDefinitions>

                                        <CheckBox Grid.Column="0" IsChecked="{x:Bind IsSelected, Mode=TwoWay}" Checked="OnJunkSelectionChanged" Unchecked="OnJunkSelectionChanged" VerticalAlignment="Center" Margin="0,0,12,0" MinWidth="0" />
                                        
                                        <Border Grid.Column="1" Width="36" Height="36" CornerRadius="18" Background="#157F56D9" Margin="0,0,12,0" VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <FontIcon Glyph="{x:Bind IconGlyph}" Foreground="{x:Bind IconColor}" FontSize="15" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                        </Border>

                                        <StackPanel Grid.Column="2" VerticalAlignment="Center" Spacing="1" Margin="0,0,8,0">
                                            <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{x:Bind Description}" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" MaxLines="2" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>

                                        <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Right" Spacing="1" Margin="4,0,0,0">
                                            <TextBlock Text="{x:Bind SizeFormatted}" FontWeight="Bold" FontSize="13" Foreground="{ThemeResource SystemAccentColor}" HorizontalAlignment="Right" />
                                            <TextBlock Text="{x:Bind FileCountFormatted}" FontSize="10.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" HorizontalAlignment="Right" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- Right Pane: Switchable Details, Progress or Empty State -->
            <Grid Grid.Column="1">
                
                <!-- STATE 1: Empty state (Initial state before scan) -->
                <Border Style="{StaticResource ModernCardStyle}" Padding="24" Visibility="{x:Bind GetEmptyVisibility(ViewModel.SelectedCategory, ViewModel.IsScanning, ViewModel.IsCleaning), Mode=OneWay}">
                    <Grid VerticalAlignment="Center" HorizontalAlignment="Center">
                        <StackPanel Spacing="16" HorizontalAlignment="Center">
                            <Border Width="72" Height="72" CornerRadius="36" Background="#107F56D9" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xEA99;" Foreground="#FF7F56D9" FontSize="32" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Border>
                            
                            <StackPanel Spacing="6" HorizontalAlignment="Center">
                                <TextBlock Text="Scan system to find junk files." FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" TextAlignment="Center" />
                                <TextBlock Text="Perform a quick scan of directories to evaluate safe-to-clean junk files and system caching logs." FontSize="12.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" MaxWidth="280" />
                            </StackPanel>
                            
                            <Button Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" Click="OnScanJunkClick" Padding="20,10" CornerRadius="6" HorizontalAlignment="Center" FontWeight="SemiBold">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE721;" FontSize="13" Foreground="White" />
                                    <TextBlock Text="Scan Directories" VerticalAlignment="Center" />
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- STATE 2: Detailed File Inspector (Idle and item selected) -->
                <Border Style="{StaticResource ModernCardStyle}" Padding="20" Visibility="{x:Bind GetDetailVisibility(ViewModel.SelectedCategory, ViewModel.IsScanning, ViewModel.IsCleaning), Mode=OneWay}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />  <!-- Category details header -->
                            <RowDefinition Height="Auto" />  <!-- Section heading: Top Files -->
                            <RowDefinition Height="*" />     <!-- Files ListView -->
                        </Grid.RowDefinitions>

                        <!-- Header Info Card -->
                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <StackPanel Spacing="4">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="{x:Bind ViewModel.SelectedCategory.IconGlyph, Mode=OneWay}" Foreground="{x:Bind ViewModel.SelectedCategory.IconColor, Mode=OneWay}" FontSize="16" VerticalAlignment="Center" />
                                    <TextBlock Text="{x:Bind ViewModel.SelectedCategory.Name, Mode=OneWay}" FontSize="15" FontWeight="Bold" VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Text="{x:Bind ViewModel.SelectedCategory.Description, Mode=OneWay}" FontSize="12" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" />
                                <TextBlock Text="{x:Bind ViewModel.SelectedCategory.FolderPath, Mode=OneWay}" FontSize="10.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextTrimming="CharacterEllipsis" Margin="0,4,0,0" Opacity="0.8" />
                            </StackPanel>

                            <Button Grid.Column="1" Style="{StaticResource DateTimeFlyoutCalendarButtonStyle}" Width="36" Height="36" CornerRadius="18" Padding="0" ToolTipService.ToolTip="Open Folder Location" Click="OnOpenFolderClick" VerticalAlignment="Top" HorizontalAlignment="Right">
                                <FontIcon Glyph="&#xE8B7;" FontSize="15" />
                            </Button>
                        </Grid>

                        <TextBlock Grid.Row="1" Text="Top Largest Files" FontSize="13" FontWeight="Bold" Margin="4,0,0,8" />

                        <!-- File list scroll viewer -->
                        <ListView Grid.Row="2" ItemsSource="{x:Bind ViewModel.SelectedCategory.TopFiles, Mode=OneWay}" SelectionMode="None">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="4,6" />
                                    <Setter Property="BorderBrush" Value="{ThemeResource ControlStrokeColorDefaultBrush}" />
                                    <Setter Property="BorderThickness" Value="0,0,0,1" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:JunkFileItem">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />  <!-- File icon -->
                                            <ColumnDefinition Width="*" />     <!-- Path info -->
                                            <ColumnDefinition Width="Auto" />  <!-- Size -->
                                        </Grid.ColumnDefinitions>

                                        <FontIcon Grid.Column="0" Glyph="{x:Bind IconGlyph}" Foreground="{x:Bind IconColor}" FontSize="15" Margin="0,0,10,0" VerticalAlignment="Center" />
                                        
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1" Margin="0,0,8,0">
                                            <TextBlock Text="{x:Bind FileName}" FontWeight="SemiBold" FontSize="12" TextTrimming="CharacterEllipsis" />
                                            <TextBlock Text="{x:Bind Path}" FontSize="10" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextTrimming="CharacterEllipsis" />
                                        </StackPanel>

                                        <TextBlock Grid.Column="2" Text="{x:Bind SizeFormatted}" FontSize="11.5" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Right" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>

                <!-- STATE 3: Progress & Log Trace (Visible during scanning or cleaning) -->
                <Grid Visibility="{x:Bind GetProgressVisibility(ViewModel.IsScanning, ViewModel.IsCleaning), Mode=OneWay}" RowSpacing="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Style="{StaticResource ModernCardStyle}" Padding="16">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Cleanup Progress" FontWeight="Bold" FontSize="14" />
                            <Grid Height="80" Width="80" HorizontalAlignment="Center">
                                <ProgressRing IsActive="{x:Bind GetProgressRingActive(ViewModel.IsScanning, ViewModel.IsCleaning), Mode=OneWay}" Width="60" Height="60" />
                            </Grid>
                            <ProgressBar Value="{x:Bind ViewModel.ProgressPercent, Mode=OneWay}" Maximum="100" Height="6" CornerRadius="3" Foreground="{StaticResource PrimaryAccentGradient}" />
                            <TextBlock Text="{x:Bind ViewModel.ProgressMessage, Mode=OneWay}" TextWrapping="Wrap" FontSize="12.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource ModernCardStyle}" Padding="16">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Live Operations Trace" FontWeight="Bold" FontSize="14" Margin="0,0,0,8" />
                            <TextBox Grid.Row="1" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" Style="{StaticResource DarkTerminalStyle}" Text="{x:Bind ViewModel.ProgressMessage, Mode=OneWay}" />
                        </Grid>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
