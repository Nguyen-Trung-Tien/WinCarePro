<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinCarePro.Views.LogsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:database="using:WinCarePro.Database"
    xmlns:local="using:WinCarePro.Views"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Logs Center &amp; Reports Explorer" Style="{ThemeResource TitleTextBlockStyle}" FontWeight="Bold" />
                <TextBlock Text="Review system optimization activities history and compile detailed diagnostic reports." Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
            </StackPanel>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button Content="Refresh Registers" Style="{StaticResource AccentButtonStyle}" Click="OnRefreshClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" Padding="16,8" CornerRadius="6" />
            </StackPanel>
        </Grid>

        <!-- Pivot Tabs -->
        <Pivot Grid.Row="1">
            <!-- Activity Logs Tab -->
            <PivotItem Header="Activity Log History">
                <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="0,12,12,12" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" ColumnSpacing="12" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="200" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <ComboBox x:Name="ModuleFilterCombo" SelectionChanged="OnModuleFilterChanged" PlaceholderText="Filter by Module" CornerRadius="6" VerticalAlignment="Center" Width="180">
                                <ComboBoxItem Content="All Modules" />
                                <ComboBoxItem Content="Junk Cleaner" />
                                <ComboBoxItem Content="System Repair" />
                                <ComboBoxItem Content="Network Repair" />
                                <ComboBoxItem Content="Startup Manager" />
                                <ComboBoxItem Content="Service Manager" />
                                <ComboBoxItem Content="Process Manager" />
                                <ComboBoxItem Content="Disk Tools" />
                                <ComboBoxItem Content="Privacy Center" />
                                <ComboBoxItem Content="Registry Tools" />
                                <ComboBoxItem Content="Backup &amp; Restore" />
                                <ComboBoxItem Content="Software Updater" />
                            </ComboBox>
                            <TextBox Grid.Column="1" Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay}" PlaceholderText="Search action logs..." CornerRadius="6" VerticalAlignment="Center" />
                        </Grid>

                        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Logs, Mode=OneWay}" SelectionMode="None">
                            <ListView.HeaderTemplate>
                                <DataTemplate>
                                    <Grid Padding="12,6" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="150" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Log ID" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="1" Text="Timestamp" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="2" Text="Engine Module" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="3" Text="Executed Action" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="4" Text="Result Status" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.HeaderTemplate>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="database:LogEntry">
                                    <Grid Padding="12" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="150" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{x:Bind Id}" VerticalAlignment="Center" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind local:LogsPage.FormatDateTime(CreatedAt), Mode=OneWay}" VerticalAlignment="Center" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                        <TextBlock Grid.Column="2" Text="{x:Bind Module}" FontWeight="SemiBold" VerticalAlignment="Center" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="3" Text="{x:Bind Action}" VerticalAlignment="Center" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        
                                        <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <FontIcon Glyph="{x:Bind local:LogsPage.GetStatusIcon(Status), Mode=OneWay}" Foreground="{x:Bind local:LogsPage.GetStatusColor(Status), Mode=OneWay}" FontSize="12" />
                                            <TextBlock Text="{x:Bind Status}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{x:Bind local:LogsPage.GetStatusColor(Status), Mode=OneWay}" FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </PivotItem>

            <!-- Exported Reports Tab -->
            <PivotItem Header="System Diagnostic Reports">
                <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="0,12,12,12" Padding="16">
                    <Grid ColumnSpacing="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="3*" />
                        </Grid.ColumnDefinitions>

                        <!-- Compiler -->
                        <StackPanel Grid.Column="0" Spacing="16">
                            <TextBlock Text="Compile Diagnostic Report" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="Bold" />
                            <TextBlock Text="Generates an immediate system configuration sheet, listing hardware specifications and logged optimizations." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" />

                            <ComboBox x:Name="FormatCombo" SelectionChanged="OnFormatChanged" Header="Report Output Format" CornerRadius="6" Width="180">
                                <ComboBoxItem Content="Plain Text (.txt)" Tag="TXT" IsSelected="True" />
                                <ComboBoxItem Content="JSON Structure (.json)" Tag="JSON" />
                            </ComboBox>
                            
                            <Button Content="Generate Diagnostic Report" Style="{StaticResource AccentButtonStyle}" Click="OnGenerateReportClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="6" Padding="12,6" />
                        </StackPanel>

                        <!-- History List -->
                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Generated Reports History" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="Bold" Margin="0,0,0,12" />

                            <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Reports, Mode=OneWay}" SelectionMode="None">
                                <ListView.HeaderTemplate>
                                    <DataTemplate>
                                        <Grid Padding="12,6" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="120" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Report Document Filename" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                            <TextBlock Grid.Column="1" Text="Compiled Timestamp" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                            <TextBlock Grid.Column="2" Text="Operations" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.HeaderTemplate>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="database:ReportEntry">
                                        <Grid Padding="12" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="120" />
                                            </Grid.ColumnDefinitions>

                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind ReportName}" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                                <TextBlock Text="{x:Bind FilePath}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" FontSize="10" TextWrapping="NoWrap" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{x:Bind local:LogsPage.FormatDateTimeShort(CreatedAt), Mode=OneWay}" VerticalAlignment="Center" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                            <Button Grid.Column="2" Content="Open Directory" Click="OnOpenReportFolderClick" Tag="{x:Bind FilePath}" CornerRadius="4" FontSize="11" Padding="8,4" HorizontalAlignment="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Grid>
                </Border>
            </PivotItem>
        </Pivot>
    </Grid>
</Page>
