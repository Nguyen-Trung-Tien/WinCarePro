<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinCarePro.Views.NetworkPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:WinCarePro.Models"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Network Center &amp; Diagnostics" FontSize="28" FontWeight="ExtraBold" CharacterSpacing="-10" />
                <TextBlock Text="Monitor connection quality, query true DNS latency, view active connections, and apply advanced repairs." Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" Margin="0,4,0,0" />
            </StackPanel>
            <Button Grid.Column="1" Click="OnRefreshClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" VerticalAlignment="Center" Padding="18,9" CornerRadius="8" Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE72C;" FontSize="14" Foreground="White" />
                    <TextBlock Text="Refresh Diagnostics" FontWeight="SemiBold" />
                </StackPanel>
            </Button>
        </Grid>

        <!-- Navigation Tabs (Segmented Button Bar) -->
        <Border Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="10" Padding="6" Margin="0,0,0,20">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button x:Name="BtnTabQuality" Grid.Column="0" Content="Connection Quality" Click="OnTabClick" Tag="quality" Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" HorizontalAlignment="Stretch" CornerRadius="6" FontWeight="SemiBold" Padding="0,10" />
                <Button x:Name="BtnTabDns" Grid.Column="1" Content="DNS Optimizer" Click="OnTabClick" Tag="dns" Style="{StaticResource DefaultButtonStyle}" HorizontalAlignment="Stretch" CornerRadius="6" FontWeight="SemiBold" Padding="0,10" />
                <Button x:Name="BtnTabPorts" Grid.Column="2" Content="Active Connections" Click="OnTabClick" Tag="ports" Style="{StaticResource DefaultButtonStyle}" HorizontalAlignment="Stretch" CornerRadius="6" FontWeight="SemiBold" Padding="0,10" />
                <Button x:Name="BtnTabRepairs" Grid.Column="3" Content="Diagnostics &amp; Repairs" Click="OnTabClick" Tag="repairs" Style="{StaticResource DefaultButtonStyle}" HorizontalAlignment="Stretch" CornerRadius="6" FontWeight="SemiBold" Padding="0,10" />
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="2">
            
            <!-- SECTION 1: CONNECTION QUALITY & ADAPTERS -->
            <Grid x:Name="SectionQuality" RowSpacing="20" ColumnSpacing="20" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="0.8*" />
                </Grid.ColumnDefinitions>

                <!-- Top Grid: 6 Core Diagnostics Info Cards -->
                <Grid Grid.Row="0" Grid.ColumnSpan="2" ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Realtime Download -->
                    <Border Grid.Column="0" Style="{StaticResource ModernCardStyle}" Padding="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="32" Height="32" Background="#1500FF66" CornerRadius="16" Margin="0,0,8,0" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE896;" FontSize="14" Foreground="#FF00FF66" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Download" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                <TextBlock Text="{x:Bind FormatMbps(ViewModel.DownloadSpeed), Mode=OneWay}" FontSize="14" FontWeight="Bold" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Realtime Upload -->
                    <Border Grid.Column="1" Style="{StaticResource ModernCardStyle}" Padding="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="32" Height="32" Background="#157F56D9" CornerRadius="16" Margin="0,0,8,0" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE898;" FontSize="14" Foreground="#FF7F56D9" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Upload" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                <TextBlock Text="{x:Bind FormatMbps(ViewModel.UploadSpeed), Mode=OneWay}" FontSize="14" FontWeight="Bold" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Latency -->
                    <Border Grid.Column="2" Style="{StaticResource ModernCardStyle}" Padding="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="32" Height="32" Background="#151E90FF" CornerRadius="16" Margin="0,0,8,0" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xEC9A;" FontSize="14" Foreground="DodgerBlue" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Ping Latency" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                <TextBlock Text="{x:Bind FormatMs(ViewModel.LatencyMs), Mode=OneWay}" FontSize="14" FontWeight="Bold" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Jitter -->
                    <Border Grid.Column="3" Style="{StaticResource ModernCardStyle}" Padding="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="32" Height="32" Background="#15FFA500" CornerRadius="16" Margin="0,0,8,0" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE909;" FontSize="14" Foreground="Orange" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Jitter Telemetry" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                <TextBlock Text="{x:Bind FormatMs(ViewModel.JitterMs), Mode=OneWay}" FontSize="14" FontWeight="Bold" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Public IP -->
                    <Border Grid.Column="4" Style="{StaticResource ModernCardStyle}" Padding="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="32" Height="32" Background="#15708090" CornerRadius="16" Margin="0,0,8,0" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xF137;" FontSize="14" Foreground="SlateGray" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Public IP Address" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                <TextBlock Text="{x:Bind ViewModel.PublicIpAddress, Mode=OneWay}" FontSize="12.5" FontWeight="Bold" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Active DNS -->
                    <Border Grid.Column="5" Style="{StaticResource ModernCardStyle}" Padding="12">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="32" Height="32" Background="#152E8B57" CornerRadius="16" Margin="0,0,8,0" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE815;" FontSize="14" Foreground="MediumSeaGreen" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Active DNS Server" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                <TextBlock Text="{x:Bind ViewModel.CurrentDnsText, Mode=OneWay}" FontSize="11" FontWeight="Bold" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Left Column: Circular Speedometer and Speed Test -->
                <Grid Grid.Row="1" Grid.Column="0" RowSpacing="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Speed Test Tool Card -->
                    <Border Grid.Row="0" Style="{StaticResource ModernCardStyle}" Padding="20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Internet Speed Test (Multi-threaded)" FontSize="16" FontWeight="Bold" />

                            <!-- Premium Circular Speedometer Dial -->
                            <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,16">
                                <!-- Background ring -->
                                <ProgressRing Value="100" IsIndeterminate="False" Width="180" Height="180" Foreground="{ThemeResource SystemControlBackgroundBaseLowBrush}" IsActive="True" Opacity="0.5" />
                                <!-- Active progress ring -->
                                <ProgressRing Value="{x:Bind ViewModel.SpeedProgress, Mode=OneWay}" IsIndeterminate="False" Width="180" Height="180" Foreground="{StaticResource PrimaryAccentGradient}" IsActive="True" />
                                
                                <!-- Speed display in center -->
                                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="2">
                                    <TextBlock Text="DOWNLOAD" FontSize="9" FontWeight="ExtraBold" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" HorizontalAlignment="Center" />
                                    <TextBlock Text="{x:Bind FormatMbps(ViewModel.DownloadSpeedMbps), Mode=OneWay}" FontSize="32" FontWeight="ExtraBold" Foreground="{ThemeResource SystemAccentColor}" HorizontalAlignment="Center" />
                                    
                                    <Border Width="80" Height="1" Background="{ThemeResource ControlStrokeColorDefaultBrush}" Margin="0,4" />
                                    
                                    <TextBlock Text="UPLOAD" FontSize="9" FontWeight="ExtraBold" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" HorizontalAlignment="Center" />
                                    <TextBlock Text="{x:Bind FormatMbps(ViewModel.UploadSpeedMbps), Mode=OneWay}" FontSize="20" FontWeight="Bold" Foreground="MediumSeaGreen" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Grid>

                            <StackPanel Grid.Row="2" Spacing="10">
                                <ProgressBar Value="{x:Bind ViewModel.SpeedProgress, Mode=OneWay}" Maximum="100" Height="6" Foreground="{StaticResource PrimaryAccentGradient}" CornerRadius="3" />
                                <Grid>
                                    <TextBlock Text="Multiple High-Speed CDNs (Range-based)" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" VerticalAlignment="Center" />
                                    <Button Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" Click="OnSpeedTestClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" HorizontalAlignment="Right" Padding="18,8" CornerRadius="6">
                                        <StackPanel Orientation="Horizontal" Spacing="8">
                                            <FontIcon Glyph="&#xE9D2;" FontSize="14" Foreground="White" />
                                            <TextBlock Text="Run Speed Test" FontWeight="SemiBold" />
                                        </StackPanel>
                                    </Button>
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Mini Connection Health metrics -->
                    <Grid Grid.Row="1" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Latency Quality Gauge -->
                        <Border Grid.Column="0" Style="{StaticResource ModernCardStyle}" Padding="12">
                            <StackPanel HorizontalAlignment="Center" Spacing="4">
                                <TextBlock Text="{x:Bind FormatMs(ViewModel.LatencyMs), Mode=OneWay}" FontSize="22" FontWeight="ExtraBold" Foreground="{ThemeResource SystemAccentColor}" HorizontalAlignment="Center" />
                                <TextBlock Text="Avg Ping Latency" FontSize="11" FontWeight="Bold" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <!-- Packet Loss Gauge -->
                        <Border Grid.Column="1" Style="{StaticResource ModernCardStyle}" Padding="12">
                            <StackPanel HorizontalAlignment="Center" Spacing="4">
                                <TextBlock Text="{x:Bind FormatPercent(ViewModel.PacketLossPercent), Mode=OneWay}" FontSize="22" FontWeight="ExtraBold" Foreground="Tomato" HorizontalAlignment="Center" />
                                <TextBlock Text="Packet Loss Rate" FontSize="11" FontWeight="Bold" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <!-- Connection Quality Badge -->
                        <Border Grid.Column="2" Style="{StaticResource ModernCardStyle}" Padding="12">
                            <StackPanel HorizontalAlignment="Center" Spacing="4">
                                <TextBlock Text="{x:Bind ViewModel.ConnectionQuality, Mode=OneWay}" FontSize="22" FontWeight="ExtraBold" Foreground="MediumSeaGreen" HorizontalAlignment="Center" />
                                <TextBlock Text="Link Quality Score" FontSize="11" FontWeight="Bold" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Grid>

                <!-- Right Column: Active Adapters List -->
                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource ModernCardStyle}" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Active Adapters" FontSize="16" FontWeight="Bold" Margin="4,0,0,12" />
                        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Adapters, Mode=OneWay}" SelectionMode="None">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,0,0,10" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:NetworkAdapterInfo">
                                    <Border Background="{ThemeResource ControlAltFillColorSecondaryBrush}" CornerRadius="10" Padding="12" BorderThickness="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}">
                                        <Grid RowSpacing="6">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            
                                            <!-- Top line: Name & Status badge -->
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <FontIcon Glyph="&#xE839;" FontSize="14" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Center" />
                                                    <TextBlock Text="{x:Bind Name}" FontWeight="Bold" FontSize="13" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                                <Border Grid.Column="1" Background="{x:Bind StatusColor}" CornerRadius="4" Padding="6,2">
                                                    <TextBlock Text="{x:Bind Status}" FontSize="9.5" FontWeight="Bold" Foreground="White" />
                                                </Border>
                                            </Grid>

                                            <!-- Middle line: Description & Speed -->
                                            <Grid Grid.Row="1">
                                                <TextBlock Text="{x:Bind Description}" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextTrimming="CharacterEllipsis" HorizontalAlignment="Left" />
                                                <TextBlock Text="{x:Bind Speed}" FontSize="11" FontWeight="Bold" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" HorizontalAlignment="Right" />
                                            </Grid>

                                            <!-- Bottom line: IP & MAC -->
                                            <StackPanel Grid.Row="2" Spacing="2">
                                                <TextBlock Text="{x:Bind IpAddresses}" FontSize="10.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextTrimming="CharacterEllipsis" FontFamily="Consolas" />
                                                <TextBlock Text="{x:Bind MacAddress}" FontSize="9.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" Opacity="0.7" FontFamily="Consolas" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>

            <!-- SECTION 2: DNS OPTIMIZER / BENCHMARK -->
            <Grid x:Name="SectionDns" RowSpacing="20" ColumnSpacing="20" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="0.8*" />
                </Grid.ColumnDefinitions>

                <!-- Top Info Bar (DNS Benchmark Header) -->
                <Border Grid.Row="0" Grid.ColumnSpan="2" Style="{StaticResource GlassmorphismCardStyle}" Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="DNS Query Latency Benchmark &amp; Optimization" FontSize="16" FontWeight="Bold" />
                            <TextBlock Text="Performs live query resolutions of google.com, cloudflare.com, and microsoft.com to compute the most accurate response speeds." FontSize="12.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                        </StackPanel>
                        <Button Grid.Column="1" Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" Click="OnDnsBenchmarkClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" Padding="18,8" CornerRadius="6" VerticalAlignment="Center">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE768;" FontSize="14" Foreground="White" />
                                <TextBlock Text="Start DNS Benchmark" FontWeight="SemiBold" />
                            </StackPanel>
                        </Button>
                    </Grid>
                </Border>

                <!-- DNS Benchmarks Table -->
                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource ModernCardStyle}" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Header Labels -->
                        <Grid Grid.Row="0" Margin="4,0,4,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="1.5*" />
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="DNS Name" FontSize="12.5" FontWeight="Bold" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                            <TextBlock Grid.Column="1" Text="IP Addresses" FontSize="12.5" FontWeight="Bold" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                            <TextBlock Grid.Column="2" Text="Avg Resolution" FontSize="12.5" FontWeight="Bold" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                            <TextBlock Grid.Column="3" Text="Reliability" FontSize="12.5" FontWeight="Bold" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                        </Grid>

                        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.DnsServers, Mode=OneWay}" SelectionMode="None">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,0,0,8" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:DnsServerInfo">
                                    <Border Background="{ThemeResource ControlAltFillColorSecondaryBrush}" CornerRadius="8" Padding="12,10" BorderThickness="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2*" />
                                                <ColumnDefinition Width="1.5*" />
                                                <ColumnDefinition Width="1.2*" />
                                                <ColumnDefinition Width="1.2*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Name and Fastest Badge -->
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                <Border Width="30" Height="30" Background="#157F56D9" CornerRadius="15">
                                                    <FontIcon Glyph="&#xE12B;" FontSize="12" Foreground="#FF7F56D9" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind Name}" FontWeight="Bold" FontSize="13" />
                                                    <Border Visibility="{x:Bind IsFastest, Converter={StaticResource BooleanToVisibilityConverter}}" Background="MediumSeaGreen" CornerRadius="3" Padding="4,1" Margin="0,2,0,0" HorizontalAlignment="Left">
                                                        <TextBlock Text="Fastest" FontSize="9" FontWeight="Bold" Foreground="White" />
                                                    </Border>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- IP details -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                                <TextBlock Text="{x:Bind PrimaryIp}" FontSize="12.5" FontFamily="Consolas" />
                                                <TextBlock Text="{x:Bind SecondaryIp}" FontSize="10.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" FontFamily="Consolas" />
                                            </StackPanel>

                                            <!-- Query Response -->
                                            <TextBlock Grid.Column="2" Text="{x:Bind PingFormatted}" FontSize="14" FontWeight="Bold" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Center" />

                                            <!-- Reliability -->
                                            <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind ReliabilityScore}" FontSize="13" FontWeight="Bold" Foreground="MediumSeaGreen" />
                                                <TextBlock Text="Success" FontSize="9" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                            </StackPanel>

                                            <!-- Apply button -->
                                            <Button Grid.Column="4" Style="{StaticResource DefaultButtonStyle}" Click="OnApplyDnsClick" Tag="{x:Bind}" IsEnabled="{Binding DataContext.ViewModel.IsNotBusy, ElementName=SectionDns}" CornerRadius="6" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <FontIcon Glyph="&#xE8FB;" FontSize="12" />
                                                    <TextBlock Text="Apply DNS" />
                                                </StackPanel>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>

                <!-- Sidebar Recommendation -->
                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource ModernCardStyle}" Padding="20">
                    <StackPanel Spacing="16">
                        <TextBlock Text="DNS Query Diagnostics" FontSize="16" FontWeight="Bold" />
                        
                        <Border Background="{ThemeResource ControlAltFillColorSecondaryBrush}" CornerRadius="10" Padding="14">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Recommended DNS" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                <TextBlock Text="{x:Bind ViewModel.FastestDnsText, Mode=OneWay}" FontSize="18" FontWeight="Bold" Foreground="MediumSeaGreen" />
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Domain Name System (DNS) maps domain names to IP addresses. Having low DNS resolution query latencies is critical for instant web-browsing response speeds, gaming latency stability, and preventing loading delay spikes." FontSize="12.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" LineHeight="18" />
                        <TextBlock Text="* Note: The benchmark tests standard UDP DNS resolving (Port 53) directly. Applying the DNS settings will bind all active local network adapters to the selected static servers." FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" Opacity="0.8" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- SECTION 3: ACTIVE CONNECTIONS (PORTS) -->
            <Border x:Name="SectionPorts" Style="{StaticResource ModernCardStyle}" Padding="20" Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Top Filter bar -->
                    <Grid Grid.Row="0" ColumnSpacing="12" Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox PlaceholderText="Search connections (e.g. chrome, ESTABLISHED, 80)..." Text="{x:Bind ViewModel.ConnectionSearchQuery, Mode=TwoWay}" CornerRadius="6" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Style="{StaticResource DefaultButtonStyle}" Click="OnRefreshConnectionsClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="6" Padding="16,8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE72C;" FontSize="13" />
                                <TextBlock Text="Refresh Connections" />
                            </StackPanel>
                        </Button>
                    </Grid>

                    <!-- Badge Summaries Row -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Margin="0,0,0,16">
                        <Border Background="#157F56D9" CornerRadius="6" Padding="8,4">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="Total Ports:" FontSize="11" Foreground="#FF7F56D9" />
                                <TextBlock Text="{x:Bind ViewModel.Connections.Count, Mode=OneWay}" FontSize="11" FontWeight="Bold" Foreground="#FF7F56D9" />
                            </StackPanel>
                        </Border>
                        <Border Background="#153CB371" CornerRadius="6" Padding="8,4">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="Established:" FontSize="11" Foreground="MediumSeaGreen" />
                                <TextBlock Text="{x:Bind GetEstablishedCount(ViewModel.Connections), Mode=OneWay}" FontSize="11" FontWeight="Bold" Foreground="MediumSeaGreen" />
                            </StackPanel>
                        </Border>
                        <Border Background="#151E90FF" CornerRadius="6" Padding="8,4">
                            <StackPanel Orientation="Horizontal" Spacing="4">
                                <TextBlock Text="Listening:" FontSize="11" Foreground="DodgerBlue" />
                                <TextBlock Text="{x:Bind GetListeningCount(ViewModel.Connections), Mode=OneWay}" FontSize="11" FontWeight="Bold" Foreground="DodgerBlue" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!-- Table Header -->
                    <Grid Grid.Row="2" Margin="8,0,8,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="2.5*" />
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="1.5*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Protocol" FontSize="12.5" FontWeight="Bold" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                        <TextBlock Grid.Column="1" Text="Process / PID" FontSize="12.5" FontWeight="Bold" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                        <TextBlock Grid.Column="2" Text="Local Address" FontSize="12.5" FontWeight="Bold" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                        <TextBlock Grid.Column="3" Text="Foreign Address" FontSize="12.5" FontWeight="Bold" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                        <TextBlock Grid.Column="4" Text="State" FontSize="12.5" FontWeight="Bold" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                    </Grid>

                    <!-- Connections list (UI virtualized via ItemsStackPanel) -->
                    <ListView Grid.Row="3" ItemsSource="{x:Bind ViewModel.Connections, Mode=OneWay}" SelectionMode="None">
                        <ListView.ItemsPanel>
                            <ItemsPanelTemplate>
                                <ItemsStackPanel />
                            </ItemsPanelTemplate>
                        </ListView.ItemsPanel>
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="4,8" />
                                <Setter Property="BorderBrush" Value="{ThemeResource ControlStrokeColorDefaultBrush}" />
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:ActiveConnectionInfo">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*" />
                                        <ColumnDefinition Width="2.5*" />
                                        <ColumnDefinition Width="3*" />
                                        <ColumnDefinition Width="3*" />
                                        <ColumnDefinition Width="1.5*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Protocol -->
                                    <Border Grid.Column="0" Background="#157F56D9" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Protocol}" FontSize="10.5" FontWeight="Bold" Foreground="#FF7F56D9" />
                                    </Border>

                                    <!-- Process name & PID -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                                        <TextBlock Text="{x:Bind ProcessName}" FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{x:Bind Pid}" FontSize="10.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                    </StackPanel>

                                    <!-- Local IP / Port -->
                                    <TextBlock Grid.Column="2" Text="{x:Bind LocalAddress}" FontSize="12.5" FontFamily="Consolas" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />

                                    <!-- Foreign IP / Port -->
                                    <TextBlock Grid.Column="3" Text="{x:Bind ForeignAddress}" FontSize="12.5" FontFamily="Consolas" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />

                                    <!-- Connection State -->
                                    <TextBlock Grid.Column="4" Text="{x:Bind State}" FontSize="12.5" FontWeight="SemiBold" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- SECTION 4: DIAGNOSTICS TERMINAL & REPAIRS -->
            <Grid x:Name="SectionRepairs" ColumnSpacing="20" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="0.8*" />
                </Grid.ColumnDefinitions>

                <!-- Left Column: Diagnostic Terminal Simulator -->
                <Border Style="{StaticResource ModernCardStyle}" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Diagnostics Terminal Console" FontSize="18" FontWeight="Bold" Margin="0,0,0,16" />

                        <Grid Grid.Row="1" ColumnSpacing="12" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="HostInput" Text="{x:Bind ViewModel.TestHost, Mode=TwoWay}" PlaceholderText="Enter Domain or IP (e.g. google.com)" CornerRadius="6" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <Button Click="OnPingClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="6" Padding="12,6">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE724;" FontSize="12" />
                                        <TextBlock Text="Ping" />
                                    </StackPanel>
                                </Button>
                                <Button Click="OnTraceClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="6" Padding="12,6">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE81D;" FontSize="12" />
                                        <TextBlock Text="Trace" />
                                    </StackPanel>
                                </Button>
                                <Button Click="OnDnsLookupClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="6" Padding="12,6">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xE721;" FontSize="12" />
                                        <TextBlock Text="DNS Lookup" />
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>

                        <TextBox Grid.Row="2" Text="{x:Bind ViewModel.ConsoleOutput, Mode=OneWay}" Style="{StaticResource DarkTerminalStyle}" Background="#FF0C0C0E" Foreground="#FF00FF66" BorderBrush="#FF00FF66" FontFamily="Consolas" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" ScrollViewer.VerticalScrollBarVisibility="Auto" Height="400" />
                    </Grid>
                </Border>

                <!-- Right Column: Network Repair Toolkit list -->
                <Border Grid.Column="1" Style="{StaticResource ModernCardStyle}" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Network Repair Toolkit" FontSize="18" FontWeight="Bold" Margin="0,0,0,16" />

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="12">
                                
                                <Button Click="OnRepairClick" Tag="dns" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="6" Padding="12,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Glyph="&#xE12B;" FontSize="18" Foreground="{ThemeResource SystemAccentColor}" Margin="0,0,12,0" VerticalAlignment="Center" Grid.Column="0" />
                                        <StackPanel Spacing="2" Grid.Column="1">
                                            <Grid>
                                                <TextBlock Text="Flush DNS Cache" FontWeight="Bold" FontSize="13.5" HorizontalAlignment="Left" />
                                                <TextBlock Text="Low Risk" FontSize="10.5" Foreground="MediumSeaGreen" FontWeight="Bold" HorizontalAlignment="Right" />
                                            </Grid>
                                            <TextBlock Text="Clears client DNS resolver database to resolve hostname parsing errors." FontSize="11.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <Button Click="OnRepairClick" Tag="winsock" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="6" Padding="12,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Glyph="&#xE167;" FontSize="18" Foreground="{ThemeResource SystemAccentColor}" Margin="0,0,12,0" VerticalAlignment="Center" Grid.Column="0" />
                                        <StackPanel Spacing="2" Grid.Column="1">
                                            <Grid>
                                                <TextBlock Text="Reset Winsock Catalog" FontWeight="Bold" FontSize="13.5" HorizontalAlignment="Left" />
                                                <TextBlock Text="Requires Restart" FontSize="10.5" Foreground="Orange" FontWeight="Bold" HorizontalAlignment="Right" />
                                            </Grid>
                                            <TextBlock Text="Rebuilds network sockets drivers catalog to fix corrupted socket APIs." FontSize="11.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <Button Click="OnRepairClick" Tag="tcpip" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="6" Padding="12,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Glyph="&#xE839;" FontSize="18" Foreground="{ThemeResource SystemAccentColor}" Margin="0,0,12,0" VerticalAlignment="Center" Grid.Column="0" />
                                        <StackPanel Spacing="2" Grid.Column="1">
                                            <Grid>
                                                <TextBlock Text="Reset TCP/IP Stack" FontWeight="Bold" FontSize="13.5" HorizontalAlignment="Left" />
                                                <TextBlock Text="Requires Admin" FontSize="10.5" Foreground="Orange" FontWeight="Bold" HorizontalAlignment="Right" />
                                            </Grid>
                                            <TextBlock Text="Re-initializes TCP/IP parameters to resolve configuration discrepancies." FontSize="11.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <Button Click="OnRepairClick" Tag="optimize" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="6" Padding="12,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Glyph="&#xE7AD;" FontSize="18" Foreground="{ThemeResource SystemAccentColor}" Margin="0,0,12,0" VerticalAlignment="Center" Grid.Column="0" />
                                        <StackPanel Spacing="2" Grid.Column="1">
                                            <Grid>
                                                <TextBlock Text="Optimize Advanced TCP Settings" FontWeight="Bold" FontSize="13.5" HorizontalAlignment="Left" />
                                                <TextBlock Text="Low Risk" FontSize="10.5" Foreground="MediumSeaGreen" FontWeight="Bold" HorizontalAlignment="Right" />
                                            </Grid>
                                            <TextBlock Text="Optimizes TCP Auto-Tuning values for throughput optimization." FontSize="11.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <Button Click="OnRepairClick" Tag="green" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="6" Padding="12,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Glyph="&#xEC5A;" FontSize="18" Foreground="{ThemeResource SystemAccentColor}" Margin="0,0,12,0" VerticalAlignment="Center" Grid.Column="0" />
                                        <StackPanel Spacing="2" Grid.Column="1">
                                            <Grid>
                                                <TextBlock Text="Disable Green/EEE Power Saving" FontWeight="Bold" FontSize="13.5" HorizontalAlignment="Left" />
                                                <TextBlock Text="Temp Disconnect" FontSize="10.5" Foreground="Orange" FontWeight="Bold" HorizontalAlignment="Right" />
                                            </Grid>
                                            <TextBlock Text="Disables Ethernet Energy Saving properties to prevent sudden latency spikes." FontSize="11.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <Button Click="OnRepairClick" Tag="hosts" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="6" Padding="12,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Glyph="&#xE7C3;" FontSize="18" Foreground="{ThemeResource SystemAccentColor}" Margin="0,0,12,0" VerticalAlignment="Center" Grid.Column="0" />
                                        <StackPanel Spacing="2" Grid.Column="1">
                                            <Grid>
                                                <TextBlock Text="Reset Hosts File" FontWeight="Bold" FontSize="13.5" HorizontalAlignment="Left" />
                                                <TextBlock Text="Low Risk" FontSize="10.5" Foreground="MediumSeaGreen" FontWeight="Bold" HorizontalAlignment="Right" />
                                            </Grid>
                                            <TextBlock Text="Clears registry blocks and resets hosts file back to Microsoft defaults." FontSize="11.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <Button Click="OnRepairClick" Tag="iprenew" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="6" Padding="12,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Glyph="&#xE72C;" FontSize="18" Foreground="{ThemeResource SystemAccentColor}" Margin="0,0,12,0" VerticalAlignment="Center" Grid.Column="0" />
                                        <StackPanel Spacing="2" Grid.Column="1">
                                            <Grid>
                                                <TextBlock Text="Release / Renew IP" FontWeight="Bold" FontSize="13.5" HorizontalAlignment="Left" />
                                                <TextBlock Text="Temp Disconnect" FontSize="10.5" Foreground="Orange" FontWeight="Bold" HorizontalAlignment="Right" />
                                            </Grid>
                                            <TextBlock Text="Releases current IPv4 address lease and requests a fresh allocation from DHCP." FontSize="11.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                        </StackPanel>
                                    </Grid>
                                </Button>

                                <Button Click="OnRepairClick" Tag="adapter" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="6" Padding="12,10">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <FontIcon Glyph="&#xE777;" FontSize="18" Foreground="{ThemeResource SystemAccentColor}" Margin="0,0,12,0" VerticalAlignment="Center" Grid.Column="0" />
                                        <StackPanel Spacing="2" Grid.Column="1">
                                            <Grid>
                                                <TextBlock Text="Restart Active Adapter" FontWeight="Bold" FontSize="13.5" HorizontalAlignment="Left" />
                                                <TextBlock Text="Temp Disconnect" FontSize="10.5" Foreground="Orange" FontWeight="Bold" HorizontalAlignment="Right" />
                                            </Grid>
                                            <TextBlock Text="Disables and re-enables all active local network card interfaces." FontSize="11.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                        </StackPanel>
                                    </Grid>
                                </Button>

                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
