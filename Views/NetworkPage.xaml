<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinCarePro.Views.NetworkPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:WinCarePro.Models"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Network Center &amp; Diagnostics" FontSize="28" FontWeight="ExtraBold" CharacterSpacing="-10" />
                <TextBlock Text="Check connectivity stability, test network performance, and repair network configuration adapters." Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" Margin="0,4,0,0" />
            </StackPanel>
            <Button Grid.Column="1" Content="Refresh Diagnostics" Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" Click="OnRefreshClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" VerticalAlignment="Center" Padding="18,9" CornerRadius="8" FontWeight="SemiBold" />
        </Grid>

        <!-- Modern Navigation Tabs (Segmented Button Bar) -->
        <Border Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="10" Padding="6" Margin="0,0,0,20">
            <Grid ColumnSpacing="8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Button x:Name="BtnTabQuality" Grid.Column="0" Content="Connection Quality" Click="OnTabClick" Tag="quality" Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" HorizontalAlignment="Stretch" CornerRadius="6" FontWeight="SemiBold" Padding="0,10" />
                <Button x:Name="BtnTabDns" Grid.Column="1" Content="DNS Optimizer" Click="OnTabClick" Tag="dns" Style="{StaticResource DefaultButtonStyle}" HorizontalAlignment="Stretch" CornerRadius="6" FontWeight="SemiBold" Padding="0,10" />
                <Button x:Name="BtnTabPorts" Grid.Column="2" Content="Active Connections" Click="OnTabClick" Tag="ports" Style="{StaticResource DefaultButtonStyle}" HorizontalAlignment="Stretch" CornerRadius="6" FontWeight="SemiBold" Padding="0,10" />
                <Button x:Name="BtnTabRepairs" Grid.Column="3" Content="Diagnostics &amp; Repairs" Click="OnTabClick" Tag="repairs" Style="{StaticResource DefaultButtonStyle}" HorizontalAlignment="Stretch" CornerRadius="6" FontWeight="SemiBold" Padding="0,10" />
            </Grid>
        </Border>

        <!-- Main Content Area -->
        <Grid Grid.Row="2">
            
            <!-- SECTION 1: CONNECTION QUALITY & ADAPTERS -->
            <Grid x:Name="SectionQuality" RowSpacing="20" ColumnSpacing="20" Visibility="Visible">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="0.8*" />
                </Grid.ColumnDefinitions>

                <!-- Top Grid: 4 Core Diagnostics Info Cards -->
                <Grid Grid.Row="0" Grid.ColumnSpan="2" ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- Internet Status -->
                    <Border Grid.Column="0" Style="{StaticResource ModernCardStyle}" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="36" Height="36" Background="#151E90FF" CornerRadius="18" Margin="0,0,12,0" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE774;" FontSize="16" Foreground="DodgerBlue" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Internet Status" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                <TextBlock Text="{x:Bind ViewModel.InternetStatus, Mode=OneWay}" FontSize="15" FontWeight="Bold" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Gateway address -->
                    <Border Grid.Column="1" Style="{StaticResource ModernCardStyle}" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="36" Height="36" Background="#152E8B57" CornerRadius="18" Margin="0,0,12,0" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE815;" FontSize="16" Foreground="MediumSeaGreen" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Gateway IP Address" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                <TextBlock Text="{x:Bind ViewModel.GatewayAddress, Mode=OneWay}" FontSize="15" FontWeight="Bold" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- DNS Resolution -->
                    <Border Grid.Column="2" Style="{StaticResource ModernCardStyle}" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="36" Height="36" Background="#15FFA500" CornerRadius="18" Margin="0,0,12,0" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xE909;" FontSize="16" Foreground="Orange" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="DNS Resolution" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                <TextBlock Text="{x:Bind ViewModel.DnsStatus, Mode=OneWay}" FontSize="15" FontWeight="Bold" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- IP Address -->
                    <Border Grid.Column="3" Style="{StaticResource ModernCardStyle}" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Width="36" Height="36" Background="#15708090" CornerRadius="18" Margin="0,0,12,0" VerticalAlignment="Center">
                                <FontIcon Glyph="&#xF137;" FontSize="16" Foreground="SlateGray" HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="IP Address Stack" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                <TextBlock Text="{x:Bind ViewModel.IpStatus, Mode=OneWay}" FontSize="12.5" FontWeight="Bold" TextTrimming="CharacterEllipsis" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Left Column: Latency/Loss gauges and Speed Test -->
                <Grid Grid.Row="1" Grid.Column="0" RowSpacing="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>

                        <!-- Latency Quality Gauge -->
                        <Border Grid.Column="0" Style="{StaticResource ModernCardStyle}" Padding="18">
                            <StackPanel HorizontalAlignment="Center" Spacing="8">
                                <Border Width="48" Height="48" CornerRadius="24" Background="#157F56D9" HorizontalAlignment="Center">
                                    <FontIcon Glyph="&#xEC9A;" Foreground="#FF7F56D9" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="{x:Bind FormatMs(ViewModel.LatencyMs), Mode=OneWay}" FontSize="28" FontWeight="ExtraBold" Foreground="{ThemeResource SystemAccentColor}" HorizontalAlignment="Center" />
                                <TextBlock Text="Average Latency" FontSize="12" FontWeight="Bold" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>

                        <!-- Packet Loss Gauge -->
                        <Border Grid.Column="1" Style="{StaticResource ModernCardStyle}" Padding="18">
                            <StackPanel HorizontalAlignment="Center" Spacing="8">
                                <Border Width="48" Height="48" CornerRadius="24" Background="#15EF4444" HorizontalAlignment="Center">
                                    <FontIcon Glyph="&#xEB90;" Foreground="Tomato" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <TextBlock Text="{x:Bind FormatPercent(ViewModel.PacketLossPercent), Mode=OneWay}" FontSize="28" FontWeight="ExtraBold" Foreground="Tomato" HorizontalAlignment="Center" />
                                <TextBlock Text="Packet Loss Rate" FontSize="12" FontWeight="Bold" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Speed Test Tool Card -->
                    <Border Grid.Row="1" Style="{StaticResource ModernCardStyle}" Padding="20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="Internet Speed Test" FontSize="16" FontWeight="Bold" />

                            <Grid Grid.Row="1" HorizontalAlignment="Center" VerticalAlignment="Center">
                                <StackPanel Spacing="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind FormatMbps(ViewModel.DownloadSpeedMbps), Mode=OneWay}" FontSize="46" FontWeight="ExtraBold" Foreground="{ThemeResource SystemAccentColor}" HorizontalAlignment="Center" />
                                    <TextBlock Text="Download Speed" FontSize="13" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" HorizontalAlignment="Center" />
                                </StackPanel>
                            </Grid>

                            <StackPanel Grid.Row="2" Spacing="10">
                                <ProgressBar Value="{x:Bind ViewModel.SpeedProgress, Mode=OneWay}" Maximum="100" Height="8" Foreground="{StaticResource PrimaryAccentGradient}" CornerRadius="4" />
                                <Grid>
                                    <TextBlock Text="Tele2 Speedtest Server (10MB)" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" VerticalAlignment="Center" />
                                    <Button Content="Run Speed Test" Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" Click="OnSpeedTestClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" HorizontalAlignment="Right" Padding="18,8" CornerRadius="6" />
                                </Grid>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>

                <!-- Right Column: Active Adapters List -->
                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource ModernCardStyle}" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Active Adapters" FontSize="16" FontWeight="Bold" Margin="4,0,0,12" />
                        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Adapters, Mode=OneWay}" SelectionMode="None">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,0,0,10" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:NetworkAdapterInfo">
                                    <Border Background="{ThemeResource ControlAltFillColorSecondaryBrush}" CornerRadius="10" Padding="12" BorderThickness="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}">
                                        <Grid RowSpacing="6">
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            
                                            <!-- Top line: Name & Status badge -->
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <FontIcon Glyph="&#xE839;" FontSize="14" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Center" />
                                                    <TextBlock Text="{x:Bind Name}" FontWeight="Bold" FontSize="13" TextTrimming="CharacterEllipsis" />
                                                </StackPanel>
                                                <Border Grid.Column="1" Background="{x:Bind StatusColor}" CornerRadius="4" Padding="6,2">
                                                    <TextBlock Text="{x:Bind Status}" FontSize="9.5" FontWeight="Bold" Foreground="White" />
                                                </Border>
                                            </Grid>

                                            <!-- Middle line: Description & Speed -->
                                            <Grid Grid.Row="1">
                                                <TextBlock Text="{x:Bind Description}" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextTrimming="CharacterEllipsis" HorizontalAlignment="Left" />
                                                <TextBlock Text="{x:Bind Speed}" FontSize="11" FontWeight="Bold" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" HorizontalAlignment="Right" />
                                            </Grid>

                                            <!-- Bottom line: IP & MAC -->
                                            <StackPanel Grid.Row="2" Spacing="2">
                                                <TextBlock Text="{x:Bind IpAddresses}" FontSize="10.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextTrimming="CharacterEllipsis" FontFamily="Consolas" />
                                                <TextBlock Text="{x:Bind MacAddress}" FontSize="9.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" Opacity="0.7" FontFamily="Consolas" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </Grid>

            <!-- SECTION 2: DNS OPTIMIZER / BENCHMARK -->
            <Grid x:Name="SectionDns" RowSpacing="20" ColumnSpacing="20" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="0.8*" />
                </Grid.ColumnDefinitions>

                <!-- Top Info Bar (DNS Benchmark Header) -->
                <Border Grid.Row="0" Grid.ColumnSpan="2" Style="{StaticResource GlassmorphismCardStyle}" Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Spacing="2" VerticalAlignment="Center">
                            <TextBlock Text="DNS Latency Benchmark &amp; Optimization" FontSize="16" FontWeight="Bold" />
                            <TextBlock Text="Pings Google, Cloudflare, Quad9, OpenDNS, and AdGuard servers to identify and configure the fastest response DNS." FontSize="12.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="Start DNS Benchmark" Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" Click="OnDnsBenchmarkClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" Padding="18,8" CornerRadius="6" VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <!-- DNS Benchmarks Table -->
                <Border Grid.Row="1" Grid.Column="0" Style="{StaticResource ModernCardStyle}" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <!-- Header Labels -->
                        <Grid Grid.Row="0" Margin="4,0,4,10">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2.5*" />
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="1.5*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="DNS Name" FontSize="12.5" FontWeight="Bold" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                            <TextBlock Grid.Column="1" Text="IP Addresses" FontSize="12.5" FontWeight="Bold" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                            <TextBlock Grid.Column="2" Text="Ping Delay" FontSize="12.5" FontWeight="Bold" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                        </Grid>

                        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.DnsServers, Mode=OneWay}" SelectionMode="None">
                            <ListView.ItemContainerStyle>
                                <Style TargetType="ListViewItem">
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="Margin" Value="0,0,0,8" />
                                </Style>
                            </ListView.ItemContainerStyle>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:DnsServerInfo">
                                    <Border Background="{ThemeResource ControlAltFillColorSecondaryBrush}" CornerRadius="8" Padding="12,10" BorderThickness="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="2.5*" />
                                                <ColumnDefinition Width="2*" />
                                                <ColumnDefinition Width="1.5*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Name and Fastest Badge -->
                                            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                <Border Width="30" Height="30" Background="#157F56D9" CornerRadius="15">
                                                    <FontIcon Glyph="&#xE12B;" FontSize="12" Foreground="#FF7F56D9" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <StackPanel VerticalAlignment="Center">
                                                    <TextBlock Text="{x:Bind Name}" FontWeight="Bold" FontSize="13" />
                                                    <Border Visibility="{x:Bind IsFastest, Converter={StaticResource BooleanToVisibilityConverter}}" Background="MediumSeaGreen" CornerRadius="3" Padding="4,1" Margin="0,2,0,0" HorizontalAlignment="Left">
                                                        <TextBlock Text="Fastest" FontSize="9" FontWeight="Bold" Foreground="White" />
                                                    </Border>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- IP details -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                                <TextBlock Text="{x:Bind PrimaryIp}" FontSize="12.5" FontFamily="Consolas" />
                                                <TextBlock Text="{x:Bind SecondaryIp}" FontSize="10.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" FontFamily="Consolas" />
                                            </StackPanel>

                                            <!-- Ping Response -->
                                            <TextBlock Grid.Column="2" Text="{x:Bind PingFormatted}" FontSize="14" FontWeight="Bold" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Center" />

                                            <!-- Apply button -->
                                            <Button Grid.Column="3" Content="Apply DNS" Style="{StaticResource DefaultButtonStyle}" Click="OnApplyDnsClick" Tag="{x:Bind}" IsEnabled="{Binding DataContext.IsNot(DataContext.ViewModel.IsBusy), ElementName=SectionDns}" CornerRadius="6" VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>

                <!-- Sidebar Recommendation -->
                <Border Grid.Row="1" Grid.Column="1" Style="{StaticResource ModernCardStyle}" Padding="20">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Optimization Summary" FontSize="16" FontWeight="Bold" />
                        
                        <Border Background="{ThemeResource ControlAltFillColorSecondaryBrush}" CornerRadius="10" Padding="14">
                            <StackPanel Spacing="4">
                                <TextBlock Text="Recommended DNS" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                <TextBlock Text="{x:Bind ViewModel.FastestDnsText, Mode=OneWay}" FontSize="18" FontWeight="Bold" Foreground="MediumSeaGreen" />
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Optimizing your Domain Name System (DNS) speeds up the lookup process when connecting to websites. Choosing a latency-optimized server can drastically reduce web loading delays and gaming ping spikes." FontSize="12.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" LineHeight="18" />
                        <TextBlock Text="* Note: Applying DNS configures all active IPv4 adapters with the chosen static DNS. You can reset back to dynamic server settings via standard network system configurations." FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" Opacity="0.8" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- SECTION 3: ACTIVE CONNECTIONS (PORTS) -->
            <Border x:Name="SectionPorts" Style="{StaticResource ModernCardStyle}" Padding="20" Visibility="Collapsed">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Top Filter bar -->
                    <Grid Grid.Row="0" ColumnSpacing="12" Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox PlaceholderText="Search connections (e.g. chrome, ESTABLISHED, 80)..." Text="{x:Bind ViewModel.ConnectionSearchQuery, Mode=TwoWay}" CornerRadius="6" VerticalAlignment="Center" />
                        <Button Grid.Column="1" Content="Refresh Connections" Style="{StaticResource DefaultButtonStyle}" Click="OnRefreshConnectionsClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="6" Padding="16,8" />
                    </Grid>

                    <!-- Table Header -->
                    <Grid Grid.Row="1" Margin="8,0,8,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="2.5*" />
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="3*" />
                            <ColumnDefinition Width="1.5*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Protocol" FontSize="12.5" FontWeight="Bold" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                        <TextBlock Grid.Column="1" Text="Process / PID" FontSize="12.5" FontWeight="Bold" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                        <TextBlock Grid.Column="2" Text="Local Address" FontSize="12.5" FontWeight="Bold" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                        <TextBlock Grid.Column="3" Text="Foreign Address" FontSize="12.5" FontWeight="Bold" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                        <TextBlock Grid.Column="4" Text="State" FontSize="12.5" FontWeight="Bold" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                    </Grid>

                    <!-- Connections list -->
                    <ListView Grid.Row="2" ItemsSource="{x:Bind ViewModel.Connections, Mode=OneWay}" SelectionMode="None">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                <Setter Property="Padding" Value="4,8" />
                                <Setter Property="BorderBrush" Value="{ThemeResource ControlStrokeColorDefaultBrush}" />
                                <Setter Property="BorderThickness" Value="0,0,0,1" />
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:ActiveConnectionInfo">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1*" />
                                        <ColumnDefinition Width="2.5*" />
                                        <ColumnDefinition Width="3*" />
                                        <ColumnDefinition Width="3*" />
                                        <ColumnDefinition Width="1.5*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Protocol -->
                                    <Border Grid.Column="0" Background="#157F56D9" CornerRadius="4" Padding="6,2" HorizontalAlignment="Left" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Protocol}" FontSize="10.5" FontWeight="Bold" Foreground="#FF7F56D9" />
                                    </Border>

                                    <!-- Process name & PID -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="1">
                                        <TextBlock Text="{x:Bind ProcessName}" FontWeight="SemiBold" FontSize="13" TextTrimming="CharacterEllipsis" />
                                        <TextBlock Text="{x:Bind Pid}" FontSize="10.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                    </StackPanel>

                                    <!-- Local IP / Port -->
                                    <TextBlock Grid.Column="2" Text="{x:Bind LocalAddress}" FontSize="12.5" FontFamily="Consolas" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />

                                    <!-- Foreign IP / Port -->
                                    <TextBlock Grid.Column="3" Text="{x:Bind ForeignAddress}" FontSize="12.5" FontFamily="Consolas" TextTrimming="CharacterEllipsis" VerticalAlignment="Center" />

                                    <!-- Connection State -->
                                    <TextBlock Grid.Column="4" Text="{x:Bind State}" FontSize="12.5" FontWeight="SemiBold" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- SECTION 4: DIAGNOSTICS TERMINAL & REPAIRS -->
            <Grid x:Name="SectionRepairs" ColumnSpacing="20" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.2*" />
                    <ColumnDefinition Width="0.8*" />
                </Grid.ColumnDefinitions>

                <!-- Left Column: Diagnostic Terminal Simulator -->
                <Border Style="{StaticResource ModernCardStyle}" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Diagnostics Terminal" FontSize="18" FontWeight="Bold" Margin="0,0,0,16" />

                        <Grid Grid.Row="1" ColumnSpacing="12" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="HostInput" Text="{x:Bind ViewModel.TestHost, Mode=TwoWay}" PlaceholderText="Enter Domain or IP (e.g. google.com)" CornerRadius="6" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <Button Content="Ping" Click="OnPingClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="6" />
                                <Button Content="Trace" Click="OnTraceClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="6" />
                                <Button Content="DNS Lookup" Click="OnDnsLookupClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="6" />
                            </StackPanel>
                        </Grid>

                        <TextBox Grid.Row="2" Text="{x:Bind ViewModel.ConsoleOutput, Mode=OneWay}" Style="{StaticResource DarkTerminalStyle}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" ScrollViewer.VerticalScrollBarVisibility="Auto" Height="400" />
                    </Grid>
                </Border>

                <!-- Right Column: Network Repair Toolkit list -->
                <Border Grid.Column="1" Style="{StaticResource ModernCardStyle}" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Network Repair Toolkit" FontSize="18" FontWeight="Bold" Margin="0,0,0,16" />

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="12">
                                
                                <Button Click="OnRepairClick" Tag="dns" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="6" Padding="12,10">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="Flush DNS Cache" FontWeight="Bold" FontSize="13.5" />
                                        <TextBlock Text="Clears client DNS resolver database to resolve hostname parsing errors." FontSize="11.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                    </StackPanel>
                                </Button>

                                <Button Click="OnRepairClick" Tag="winsock" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="6" Padding="12,10">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="Reset Winsock Catalog" FontWeight="Bold" FontSize="13.5" />
                                        <TextBlock Text="Rebuilds network sockets drivers catalog to fix corrupted socket APIs." FontSize="11.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                    </StackPanel>
                                </Button>

                                <Button Click="OnRepairClick" Tag="tcpip" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="6" Padding="12,10">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="Reset TCP/IP Stack" FontWeight="Bold" FontSize="13.5" />
                                        <TextBlock Text="Re-initializes TCP/IP parameters to resolve configuration discrepancies." FontSize="11.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                    </StackPanel>
                                </Button>

                                <Button Click="OnRepairClick" Tag="iprenew" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="6" Padding="12,10">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="Release / Renew IP" FontWeight="Bold" FontSize="13.5" />
                                        <TextBlock Text="Releases current IPv4 address lease and requests a fresh allocation from DHCP." FontSize="11.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                    </StackPanel>
                                </Button>

                                <Button Click="OnRepairClick" Tag="adapter" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="6" Padding="12,10">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="Restart Active Adapter" FontWeight="Bold" FontSize="13.5" />
                                        <TextBlock Text="Disables and re-enables all active local network card interfaces." FontSize="11.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                    </StackPanel>
                                </Button>

                                <Button Click="OnRepairClick" Tag="firewall" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="6" Padding="12,10">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="Reset Windows Firewall" FontWeight="Bold" FontSize="13.5" />
                                        <TextBlock Text="Restores Windows Defender Firewall configurations back to out-of-box defaults." FontSize="11.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                    </StackPanel>
                                </Button>

                                <Button Click="OnRepairClick" Tag="proxy" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="6" Padding="12,10">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="Reset Proxy Settings" FontWeight="Bold" FontSize="13.5" />
                                        <TextBlock Text="Clears registry proxy overrides and resets system WinHTTP proxy tunnel settings." FontSize="11.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                    </StackPanel>
                                </Button>

                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Page>
