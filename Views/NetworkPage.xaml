<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinCarePro.Views.NetworkPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Network Center &amp; Diagnostics" Style="{ThemeResource TitleTextBlockStyle}" FontWeight="Bold" />
                <TextBlock Text="Check connectivity stability, test network performance, and repair network configuration adapters." Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
            </StackPanel>
            <Button Grid.Column="1" Content="Refresh Diagnostics" Style="{StaticResource AccentButtonStyle}" Click="OnRefreshClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" VerticalAlignment="Center" Padding="16,8" CornerRadius="6" />
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid RowSpacing="24" ColumnSpacing="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>

                <!-- Row 0, Col 0: Diagnostics Status Overview -->
                <Border Grid.Row="0" Grid.Column="0" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Text="Connectivity Status" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="Bold" Margin="0,0,0,16" />
                        
                        <Grid Grid.Row="1" RowSpacing="12" ColumnSpacing="20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="12">
                                <FontIcon Glyph="&#xE774;" FontSize="20" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Center" />
                                <StackPanel>
                                    <TextBlock Text="Internet Status" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                    <TextBlock Text="{x:Bind ViewModel.InternetStatus, Mode=OneWay}" Style="{ThemeResource BodyTextBlockStyle}" FontWeight="Bold" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="12">
                                <FontIcon Glyph="&#xE815;" FontSize="20" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Center" />
                                <StackPanel>
                                    <TextBlock Text="Gateway IP Address" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                    <TextBlock Text="{x:Bind ViewModel.GatewayAddress, Mode=OneWay}" Style="{ThemeResource BodyTextBlockStyle}" FontWeight="Bold" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Spacing="12">
                                <FontIcon Glyph="&#xE909;" FontSize="20" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Center" />
                                <StackPanel>
                                    <TextBlock Text="DNS Resolution" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                    <TextBlock Text="{x:Bind ViewModel.DnsStatus, Mode=OneWay}" Style="{ThemeResource BodyTextBlockStyle}" FontWeight="Bold" />
                                </StackPanel>
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal" Spacing="12">
                                <FontIcon Glyph="&#xF137;" FontSize="20" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Center" />
                                <StackPanel>
                                    <TextBlock Text="IP Address Stack" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                    <TextBlock Text="{x:Bind ViewModel.IpStatus, Mode=OneWay}" Style="{ThemeResource BodyTextBlockStyle}" FontWeight="Bold" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Row 0, Col 1: Ping / Speed Indicators -->
                <Border Grid.Row="0" Grid.Column="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="20">
                    <StackPanel Spacing="12">
                        <TextBlock Text="Signal &amp; Speed Quality" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="Bold" />
                        
                        <Grid ColumnSpacing="8">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
                                <TextBlock Text="{x:Bind FormatMs(ViewModel.LatencyMs), Mode=OneWay}" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="ExtraBold" Foreground="{ThemeResource SystemAccentColor}" HorizontalAlignment="Center" />
                                <TextBlock Text="Latency" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
                                <TextBlock Text="{x:Bind FormatPercent(ViewModel.PacketLossPercent), Mode=OneWay}" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="ExtraBold" Foreground="{ThemeResource SystemAccentColor}" HorizontalAlignment="Center" />
                                <TextBlock Text="Packet Loss" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Grid>

                        <MenuFlyoutSeparator />

                        <StackPanel Spacing="6">
                            <TextBlock Text="Internet Speed Test" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                            <Grid>
                                <TextBlock Text="{x:Bind FormatMbps(ViewModel.DownloadSpeedMbps), Mode=OneWay}" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="Bold" HorizontalAlignment="Left" />
                                <Button Content="Test Speed" Style="{StaticResource DefaultButtonStyle}" Click="OnSpeedTestClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" HorizontalAlignment="Right" Padding="12,4" CornerRadius="4" />
                            </Grid>
                            <ProgressBar Value="{x:Bind ViewModel.DownloadSpeedMbps, Mode=OneWay}" Maximum="100" Height="4" Foreground="{ThemeResource SystemAccentColor}" CornerRadius="2" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Row 1, Col 0: Diagnostics Panel Console -->
                <Border Grid.Row="1" Grid.Column="0" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Diagnostics Terminal" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="Bold" Margin="0,0,0,12" />

                        <Grid Grid.Row="1" ColumnSpacing="12" Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="HostInput" Text="{x:Bind ViewModel.TestHost, Mode=TwoWay}" PlaceholderText="Enter Domain or IP (e.g. google.com)" CornerRadius="6" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <Button Content="Ping" Click="OnPingClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="4" />
                                <Button Content="Trace" Click="OnTraceClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="4" />
                                <Button Content="DNS Lookup" Click="OnDnsLookupClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="4" />
                            </StackPanel>
                        </Grid>

                        <TextBox Grid.Row="2" Text="{x:Bind ViewModel.ConsoleOutput, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" FontFamily="Consolas" FontSize="12" Background="{ThemeResource ControlAltFillColorSecondaryBrush}" BorderThickness="0" CornerRadius="6" ScrollViewer.VerticalScrollBarVisibility="Auto" Height="280" />
                    </Grid>
                </Border>

                <!-- Row 1, Col 1: Repair Center Toolkit -->
                <Border Grid.Row="1" Grid.Column="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Network Repair Toolkit" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="Bold" Margin="0,0,0,12" />

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="10">
                                <Button Content="Flush DNS Cache" Click="OnRepairClick" Tag="dns" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="6" />
                                <Button Content="Reset Winsock Catalog" Click="OnRepairClick" Tag="winsock" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="6" />
                                <Button Content="Reset TCP/IP Stack" Click="OnRepairClick" Tag="tcpip" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="6" />
                                <Button Content="Release / Renew IP" Click="OnRepairClick" Tag="iprenew" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="6" />
                                <Button Content="Restart Active Adapter" Click="OnRepairClick" Tag="adapter" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="6" />
                                <Button Content="Reset Windows Firewall" Click="OnRepairClick" Tag="firewall" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="6" />
                                <Button Content="Reset Proxy Settings" Click="OnRepairClick" Tag="proxy" HorizontalAlignment="Stretch" HorizontalContentAlignment="Left" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="6" />
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>

                <!-- Port Scanner Row 2, Col 0 -->
                <Border Grid.Row="2" Grid.Column="0" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Port Scanner" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="Bold" Margin="0,0,0,12" />
                        
                        <Grid Grid.Row="1" ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="2*" />
                                <ColumnDefinition Width="3*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox Text="{x:Bind ViewModel.PortScannerHost, Mode=TwoWay}" PlaceholderText="Host IP (e.g. localhost)" Header="Target IP" CornerRadius="6" />
                            <TextBox Grid.Column="1" Text="{x:Bind ViewModel.PortScannerPorts, Mode=TwoWay}" PlaceholderText="e.g. 80, 443, 21, 22" Header="Ports to Scan" CornerRadius="6" />
                            <Button Grid.Column="2" Content="Scan Ports" Click="OnScanPortsClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" VerticalAlignment="Bottom" Padding="16,8" CornerRadius="6" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
