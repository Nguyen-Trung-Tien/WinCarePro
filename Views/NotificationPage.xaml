<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinCarePro.Views.NotificationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:database="using:WinCarePro.Database"
    xmlns:models="using:WinCarePro.Models"
    xmlns:local="using:WinCarePro.Views"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <StackPanel Spacing="4">
                <TextBlock Text="Notifications &amp; Activity Log" FontSize="26" FontWeight="ExtraBold" CharacterSpacing="-0.5" />
                <TextBlock Text="Review system notifications, update alerts, and detailed operation history logs." FontSize="13" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
            </StackPanel>
        </Grid>

        <!-- Main Content (Pivot tabs) -->
        <Pivot Grid.Row="1" Margin="0,8,0,0">
            <!-- Tab 1: System Alerts -->
            <PivotItem Header="System Alerts">
                <Grid Margin="0,16,0,0" RowSpacing="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Alert Controls -->
                    <Border Grid.Row="0" Style="{StaticResource ModernCardStyle}" Padding="16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="System Notifications" FontWeight="Bold" FontSize="14"/>
                                <TextBlock Text="Critical alerts, warnings, and system status updates." FontSize="12.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                            </StackPanel>
                            <Button Grid.Column="1" Content="Clear Alerts" Click="OnClearNotificationsClick" Style="{ThemeResource DefaultButtonStyle}" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- System Notifications List -->
                    <Border Grid.Row="1" Style="{StaticResource ModernCardStyle}" Padding="12">
                        <Grid>
                            <ListView x:Name="NotificationsListView" SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="models:NotificationItem">
                                        <Grid Padding="4,10" BorderThickness="0,0,0,1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="180" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Status Indicator -->
                                            <Border Background="{x:Bind Level, Converter={StaticResource StatusToBrushConverter}}" CornerRadius="3" Width="6" Height="36" Margin="0,0,16,0" VerticalAlignment="Center"/>

                                            <!-- Text Stack -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4" Margin="0,0,16,0">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{x:Bind Title}" FontWeight="Bold" FontSize="13.5"/>
                                                    <!-- NEW Badge -->
                                                    <Border Visibility="{x:Bind local:NotificationPage.IsUnreadVisibility(IsRead), Mode=OneWay}" Background="#FFEF4444" CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                                                        <TextBlock Text="NEW" FontSize="9" FontWeight="Bold" Foreground="White"/>
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{x:Bind Message}" FontSize="12" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" LineHeight="18"/>
                                            </StackPanel>

                                            <!-- Level Badge -->
                                            <Border Grid.Column="2" BorderBrush="{x:Bind Level, Converter={StaticResource StatusToBrushConverter}}" BorderThickness="1" Background="{ThemeResource ControlAltFillColorSecondaryBrush}" CornerRadius="6" Padding="10,4" HorizontalAlignment="Left" VerticalAlignment="Center" Margin="0,0,16,0">
                                                <TextBlock Text="{x:Bind Level}" Foreground="{x:Bind Level, Converter={StaticResource StatusToBrushConverter}}" FontWeight="Bold" FontSize="10"/>
                                            </Border>

                                            <!-- Timestamp -->
                                            <TextBlock Grid.Column="3" Text="{x:Bind CreatedAtFormatted}" FontSize="12" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                            <!-- Empty State -->
                            <StackPanel x:Name="NotificationsEmptyState" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="12" Visibility="Collapsed">
                                <FontIcon Glyph="&#xE930;" FontSize="36" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                <TextBlock Text="All clear! No new notifications." FontSize="13" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                            </StackPanel>
                        </Grid>
                    </Border>
                </Grid>
            </PivotItem>

            <!-- Tab 2: Activity Log -->
            <PivotItem Header="Activity Log">
                <Grid Margin="0,16,0,0" RowSpacing="16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Filters -->
                    <Border Grid.Row="0" Style="{StaticResource ModernCardStyle}" Padding="16">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="180" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="SearchBox" PlaceholderText="Search logs by action or status..." TextChanged="OnSearchChanged" VerticalAlignment="Center"/>
                            <ComboBox x:Name="ModuleFilter" Grid.Column="1" HorizontalAlignment="Stretch" Header="Filter by Module" SelectionChanged="OnFilterChanged" VerticalAlignment="Center">
                                <ComboBoxItem Content="All Modules" IsSelected="True"/>
                                <ComboBoxItem Content="Dashboard"/>
                                <ComboBoxItem Content="Junk Cleaner"/>
                                <ComboBoxItem Content="Registry Cleaner"/>
                                <ComboBoxItem Content="Startup Manager"/>
                                <ComboBoxItem Content="Disk Analyzer"/>
                                <ComboBoxItem Content="Network Service"/>
                                <ComboBoxItem Content="Security Shield"/>
                                <ComboBoxItem Content="Uninstaller"/>
                                <ComboBoxItem Content="Driver Manager"/>
                                <ComboBoxItem Content="System Optimizer"/>
                                <ComboBoxItem Content="Repair Tools"/>
                            </ComboBox>
                            <Button Grid.Column="2" Content="Refresh" Click="OnRefreshClick" VerticalAlignment="Bottom"/>
                            <Button Grid.Column="3" Content="Clear Logs" Click="OnClearOldLogsClick" Style="{ThemeResource DefaultButtonStyle}" VerticalAlignment="Bottom"/>
                            <Button Grid.Column="4" Content="Export Logs" Click="OnExportLogsClick" Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" VerticalAlignment="Bottom"/>
                        </Grid>
                    </Border>

                    <!-- Logs List -->
                    <Border Grid.Row="1" Style="{StaticResource ModernCardStyle}" Padding="12">
                        <ListView x:Name="LogsListView" SelectionMode="None">
                            <ListView.ItemContainerTransitions>
                                <TransitionCollection>
                                    <AddDeleteThemeTransition />
                                    <RepositionThemeTransition />
                                </TransitionCollection>
                            </ListView.ItemContainerTransitions>
                            <ListView.HeaderTemplate>
                                <DataTemplate>
                                    <Grid Padding="12,8" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="1.2*" />
                                            <ColumnDefinition Width="1.8*" />
                                            <ColumnDefinition Width="4*" />
                                            <ColumnDefinition Width="1.5*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Category" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" TextWrapping="Wrap" />
                                        <TextBlock Grid.Column="1" Text="Check Name" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" TextWrapping="Wrap" />
                                        <TextBlock Grid.Column="2" Text="Description" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" TextWrapping="Wrap" />
                                        <TextBlock Grid.Column="3" Text="Status" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Left" TextWrapping="Wrap" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.HeaderTemplate>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="database:LogEntry">
                                    <Grid Padding="4,8" BorderThickness="0,0,0,1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="180" />
                                        </Grid.ColumnDefinitions>

                                        <!-- Status Icon/Badge -->
                                        <Border Background="{x:Bind Status, Converter={StaticResource StatusToBrushConverter}}" CornerRadius="3" Width="6" Height="20" Margin="0,0,12,0" VerticalAlignment="Center"/>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind Action}" FontWeight="Bold" FontSize="13"/>
                                        </StackPanel>

                                        <TextBlock Grid.Column="2" Text="{x:Bind Module}" FontSize="12" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="3" Text="{x:Bind Status}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="4" Text="{x:Bind CreatedAtFormatted}" FontSize="12" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Border>
                </Grid>
            </PivotItem>
        </Pivot>
    </Grid>
</Page>
