<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinCarePro.Views.NotificationPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:database="using:WinCarePro.Database"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="4">
                <TextBlock Text="System Notifications &amp; Activity Log" FontSize="26" FontWeight="ExtraBold" CharacterSpacing="-0.5" />
                <TextBlock Text="Review system optimization history, database events, and diagnostic alerts." FontSize="13" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button Content="Clear Old Logs" Click="OnClearOldLogsClick" Style="{ThemeResource DefaultButtonStyle}"/>
                <Button Content="Export Logs" Click="OnExportLogsClick" Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White"/>
            </StackPanel>
        </Grid>

        <!-- Main Content Area -->
        <Grid Grid.Row="1" RowSpacing="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Filters -->
            <Border Grid.Row="0" Style="{StaticResource ModernCardStyle}" Padding="16">
                <Grid ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="SearchBox" PlaceholderText="Search logs by action or status..." TextChanged="OnSearchChanged" />
                    <ComboBox x:Name="ModuleFilter" Grid.Column="1" HorizontalAlignment="Stretch" Header="Filter by Module" SelectionChanged="OnFilterChanged">
                        <ComboBoxItem Content="All Modules" IsSelected="True"/>
                        <ComboBoxItem Content="Dashboard"/>
                        <ComboBoxItem Content="Junk Cleaner"/>
                        <ComboBoxItem Content="Registry Cleaner"/>
                        <ComboBoxItem Content="Startup Manager"/>
                        <ComboBoxItem Content="Disk Analyzer"/>
                        <ComboBoxItem Content="Network Service"/>
                        <ComboBoxItem Content="Security Shield"/>
                        <ComboBoxItem Content="Uninstaller"/>
                        <ComboBoxItem Content="Driver Manager"/>
                        <ComboBoxItem Content="System Optimizer"/>
                        <ComboBoxItem Content="Repair Tools"/>
                    </ComboBox>
                    <Button Grid.Column="2" Content="Refresh" Click="OnRefreshClick" VerticalAlignment="Bottom"/>
                </Grid>
            </Border>

            <!-- Logs List -->
            <Border Grid.Row="1" Style="{StaticResource ModernCardStyle}" Padding="12">
                <ListView x:Name="LogsListView" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="database:LogEntry">
                            <Grid Padding="4,8" BorderThickness="0,0,0,1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="180" />
                                </Grid.ColumnDefinitions>
                                
                                <!-- Status Icon/Badge -->
                                <Border Background="{x:Bind Status, Converter={StaticResource StatusToBrushConverter}}" CornerRadius="3" Width="6" Height="20" Margin="0,0,12,0" VerticalAlignment="Center"/>
                                
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind Action}" FontWeight="Bold" FontSize="13"/>
                                </StackPanel>
                                
                                <TextBlock Grid.Column="2" Text="{x:Bind Module}" FontSize="12" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="{x:Bind Status}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="4" Text="{x:Bind CreatedAtFormatted}" FontSize="12" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>
        </Grid>
    </Grid>
</Page>
