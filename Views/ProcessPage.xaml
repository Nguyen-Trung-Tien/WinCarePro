<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinCarePro.Views.ProcessPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:WinCarePro.Models"
    xmlns:local="using:WinCarePro.Views"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.ChildrenTransitions>
            <TransitionCollection>
                <EntranceThemeTransition FromHorizontalOffset="0" FromVerticalOffset="15" />
            </TransitionCollection>
        </Grid.ChildrenTransitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            
            <StackPanel>
                <TextBlock Text="System Process Manager" Style="{ThemeResource TitleTextBlockStyle}" FontWeight="Bold" />
                <TextBlock Text="Monitor running applications, track real-time resource footprints, and end misbehaving tasks." Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <TextBox Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay}" PlaceholderText="Search processes..." Width="240" CornerRadius="6" />
                <Button Content="Refresh" Style="{StaticResource AccentButtonStyle}" Click="OnRefreshClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" Padding="16,8" CornerRadius="6" />
            </StackPanel>
        </Grid>

        <!-- Process Grid -->
        <Border Grid.Row="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="12" Padding="16">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                
                <ListView Grid.Row="0" ItemsSource="{x:Bind ViewModel.Processes, Mode=OneWay}" SelectionMode="None">
                    <ListView.ItemContainerTransitions>
                        <TransitionCollection>
                            <AddDeleteThemeTransition />
                            <RepositionThemeTransition />
                        </TransitionCollection>
                    </ListView.ItemContainerTransitions>
                    <ListView.HeaderTemplate>
                        <DataTemplate>
                            <Grid Padding="12,6" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="180" />
                                </Grid.ColumnDefinitions>
                                
                                <Button Content="Name (PID)" Click="OnHeaderClick" Tag="Name" FontWeight="SemiBold" Style="{StaticResource TextBlockButtonStyle}" Padding="0" />
                                <Button Grid.Column="1" Content="CPU" Click="OnHeaderClick" Tag="CpuUsage" FontWeight="SemiBold" Style="{StaticResource TextBlockButtonStyle}" Padding="0" />
                                <Button Grid.Column="2" Content="Memory" Click="OnHeaderClick" Tag="RamUsageBytes" FontWeight="SemiBold" Style="{StaticResource TextBlockButtonStyle}" Padding="0" />
                                <Button Grid.Column="3" Content="Disk" Click="OnHeaderClick" Tag="DiskUsageMb" FontWeight="SemiBold" Style="{StaticResource TextBlockButtonStyle}" Padding="0" />
                                <Button Grid.Column="4" Content="Network" Click="OnHeaderClick" Tag="NetworkUsageKb" FontWeight="SemiBold" Style="{StaticResource TextBlockButtonStyle}" Padding="0" />
                                <TextBlock Grid.Column="5" Text="Publisher" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" VerticalAlignment="Center" />
                                <TextBlock Grid.Column="6" Text="Actions" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Grid>
                        </DataTemplate>
                    </ListView.HeaderTemplate>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:ProcessInfo">
                            <Grid Padding="12" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="200" />
                                    <ColumnDefinition Width="100" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="180" />
                                </Grid.ColumnDefinitions>

                                <TextBlock Text="{x:Bind DisplayName}" FontWeight="SemiBold" VerticalAlignment="Center" Style="{ThemeResource CaptionTextBlockStyle}" />
                                
                                <TextBlock Grid.Column="1" Text="{x:Bind local:ProcessPage.FormatCpu(CpuUsage), Mode=OneWay}" VerticalAlignment="Center" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{x:Bind local:ProcessPage.GetCpuColor(CpuUsage), Mode=OneWay}" FontWeight="SemiBold" />
                                
                                <TextBlock Grid.Column="2" Text="{x:Bind RamUsageFormatted}" VerticalAlignment="Center" Style="{ThemeResource CaptionTextBlockStyle}" />
                                <TextBlock Grid.Column="3" Text="{x:Bind DiskUsageFormatted}" VerticalAlignment="Center" Style="{ThemeResource CaptionTextBlockStyle}" />
                                <TextBlock Grid.Column="4" Text="{x:Bind NetworkUsageFormatted}" VerticalAlignment="Center" Style="{ThemeResource CaptionTextBlockStyle}" />
                                
                                <TextBlock Grid.Column="5" Text="{x:Bind Publisher}" VerticalAlignment="Center" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="NoWrap" />

                                <StackPanel Grid.Column="6" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                    <Button Content="End Task" Click="OnEndTaskClick" Tag="{x:Bind Id}" CornerRadius="4" FontSize="11" Padding="8,4" />
                                    <Button Content="End Tree" Click="OnEndTreeClick" Tag="{x:Bind Id}" CornerRadius="4" FontSize="11" Padding="8,4" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
                
                <TextBlock Grid.Row="1" Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" Margin="0,8,0,0" />
            </Grid>
        </Border>
    </Grid>
</Page>
