<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinCarePro.Views.ProcessPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:WinCarePro.Models"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="ProcessSearch" PlaceholderText="Search running processes..." Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay}" VerticalAlignment="Center" Width="280" Height="32" CornerRadius="6"/>
            <Button Grid.Column="1" Content="Refresh Thread Count" Click="OnRefreshProcessesClick" HorizontalAlignment="Right" VerticalAlignment="Center"/>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource ModernCardStyle}" Padding="12">
            <ListView ItemsSource="{x:Bind ViewModel.Processes, Mode=OneWay}" SelectionMode="None">
                <ListView.HeaderTemplate>
                    <DataTemplate>
                        <Grid Padding="12,6" BorderThickness="0,0,0,1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="90" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Process Module (Right-click to control)" FontWeight="Bold" FontSize="11.5"/>
                            <TextBlock Grid.Column="1" Text="CPU Usage" FontWeight="Bold" FontSize="11.5" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Column="2" Text="Memory (RAM)" FontWeight="Bold" FontSize="11.5" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Column="3" Text="Disk I/O" FontWeight="Bold" FontSize="11.5" HorizontalAlignment="Right"/>
                        </Grid>
                    </DataTemplate>
                </ListView.HeaderTemplate>
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:ProcessInfo">
                        <Grid Padding="12,6" BorderThickness="0,0,0,1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" ContextRequested="ProcessRow_ContextRequested" Background="Transparent">
                            <FlyoutBase.AttachedFlyout>
                                <MenuFlyout>
                                    <MenuFlyoutItem Text="End Task" Foreground="#FFE81123" Click="OnEndTaskContextClick"/>
                                    <MenuFlyoutItem Text="End Process Tree" Click="OnEndProcessTreeContextClick"/>
                                    <MenuFlyoutItem Text="Open File Location" Click="OnOpenLocationContextClick"/>
                                    <MenuFlyoutItem Text="Search Process Online" Click="OnSearchOnlineContextClick"/>
                                </MenuFlyout>
                            </FlyoutBase.AttachedFlyout>
                            
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="80" />
                                <ColumnDefinition Width="100" />
                                <ColumnDefinition Width="90" />
                            </Grid.ColumnDefinitions>
                            
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{x:Bind Name}" FontWeight="Bold" FontSize="12.5"/>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="{x:Bind Id}" FontSize="10.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                    <TextBlock Text="{x:Bind Publisher}" FontSize="10.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                </StackPanel>
                            </StackPanel>
                            
                            <TextBlock Grid.Column="1" Text="{x:Bind CpuUsageFormatted}" FontSize="12.5" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Column="2" Text="{x:Bind RamUsageFormatted}" FontSize="12.5" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                            <TextBlock Grid.Column="3" Text="{x:Bind DiskUsageFormatted}" FontSize="12.5" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </Border>
    </Grid>
</Page>
