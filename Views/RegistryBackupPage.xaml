<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinCarePro.Views.RegistryBackupPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:WinCarePro.Models"
    xmlns:engines="using:WinCarePro.Engines"
    xmlns:local="using:WinCarePro.Views"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.ChildrenTransitions>
            <TransitionCollection>
                <EntranceThemeTransition FromHorizontalOffset="0" FromVerticalOffset="15" />
            </TransitionCollection>
        </Grid.ChildrenTransitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <StackPanel Spacing="4">
                <TextBlock Text="Registry Diagnostics &amp; Snapshots" FontSize="28" FontWeight="ExtraBold" Foreground="{ThemeResource SystemControlPageTextBaseHighBrush}" />
                <TextBlock Text="Scan registry trees for broken keys, export hive backups, and manage Windows System Restore snapshots." FontSize="14" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
            </StackPanel>
        </Grid>

        <!-- Pivot Tabs -->
        <Pivot Grid.Row="1">
            <!-- Registry Scanner Tab -->
            <PivotItem Header="Registry Scanner">
                <Border Style="{StaticResource ModernCardStyle}" CornerRadius="0,16,16,16" Padding="20" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,16">
                            <Button Content="Scan Registry" Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" Click="OnScanRegistryClick" IsEnabled="{x:Bind IsNot(ViewModel.IsScanningRegistry), Mode=OneWay}" Padding="20,10" CornerRadius="8" FontWeight="Bold" />
                            <Button Content="Fix Selected" Style="{StaticResource DefaultButtonStyle}" Click="OnFixRegistryClick" IsEnabled="{x:Bind CanFix(ViewModel.RegistryIssues.Count, ViewModel.IsBusy), Mode=OneWay}" Padding="20,10" CornerRadius="8" Foreground="#FF3B82F6" BorderBrush="#333B82F6" FontWeight="Bold" />
                        </StackPanel>

                        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.RegistryIssues, Mode=OneWay}" SelectionMode="None">
                            <ListView.ItemContainerTransitions>
                                <TransitionCollection>
                                    <AddDeleteThemeTransition />
                                    <RepositionThemeTransition />
                                </TransitionCollection>
                            </ListView.ItemContainerTransitions>
                            <ListView.HeaderTemplate>
                                <DataTemplate>
                                    <Grid Padding="12,8" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="180" />
                                            <ColumnDefinition Width="350" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Select" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="1" Text="Category" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" Margin="12,0,0,0" />
                                        <TextBlock Grid.Column="2" Text="Registry Key Path" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="3" Text="Diagnostics Details" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.HeaderTemplate>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:RegistryIssue">
                                    <Grid Padding="12,10" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="180" />
                                            <ColumnDefinition Width="350" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <CheckBox IsChecked="{x:Bind IsSelected, Mode=TwoWay}" VerticalAlignment="Center" />
                                        
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center" Margin="12,0,0,0">
                                            <Border Width="24" Height="24" Background="#15FF8B00" CornerRadius="6" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <FontIcon Glyph="&#xE945;" Foreground="Orange" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="{x:Bind Section}" FontWeight="SemiBold" FontSize="12.5" VerticalAlignment="Center" />
                                        </StackPanel>
                                        
                                        <TextBlock Grid.Column="2" Text="{x:Bind KeyPath}" VerticalAlignment="Center" TextWrapping="NoWrap" FontSize="11.5" FontFamily="Consolas" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" Margin="0,0,12,0" />
                                        <TextBlock Grid.Column="3" Text="{x:Bind Description}" VerticalAlignment="Center" TextWrapping="Wrap" FontSize="12.5" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </PivotItem>

            <!-- Registry Backup Tab -->
            <PivotItem Header="Registry Backups">
                <Border Style="{StaticResource ModernCardStyle}" CornerRadius="0,16,16,16" Padding="20" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <Grid ColumnSpacing="28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="3*" />
                        </Grid.ColumnDefinitions>

                        <!-- Creator -->
                        <StackPanel Grid.Column="0" Spacing="16">
                            <TextBlock Text="Create Registry Backup" FontSize="18" FontWeight="Bold" />
                            <TextBlock Text="Exports your Current User registry keys. Safely restore them if program settings get corrupted." FontSize="13" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" LineHeight="18" />
                            
                            <TextBox Header="Backup Filename Name" Text="{x:Bind ViewModel.BackupName, Mode=TwoWay}" CornerRadius="6" />
                            <Button Content="Create Backup File" Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" Click="OnCreateBackupClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="8" Padding="16,10" FontWeight="Bold" />
                        </StackPanel>

                        <!-- List & Restore -->
                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Available Registry Backup Files" FontSize="18" FontWeight="Bold" Margin="0,0,0,16" />
                            
                            <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.RegistryBackups, Mode=OneWay}" SelectionMode="None">
                                <ListView.ItemContainerTransitions>
                                    <TransitionCollection>
                                        <AddDeleteThemeTransition />
                                        <RepositionThemeTransition />
                                    </TransitionCollection>
                                </ListView.ItemContainerTransitions>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="models:RegistryBackupItem">
                                        <Grid Padding="8,10" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center" Spacing="2">
                                                <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" FontSize="13" />
                                                <TextBlock Text="{x:Bind FilePath}" FontSize="10.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="NoWrap" FontFamily="Consolas" />
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="Restore Backup" Click="OnRestoreBackupClick" Tag="{x:Bind FilePath}" IsEnabled="{Binding DataContext.IsNotBusy, ElementName=RootPage}" Style="{StaticResource DefaultButtonStyle}" CornerRadius="6" FontSize="11" Padding="12,6" Foreground="{ThemeResource SystemAccentColor}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" FontWeight="Bold" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Grid>
                </Border>
            </PivotItem>

            <!-- System Restore Points Tab -->
            <PivotItem Header="System Restore Snapshots">
                <Border Style="{StaticResource ModernCardStyle}" CornerRadius="0,16,16,16" Padding="20" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <Grid ColumnSpacing="28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="3*" />
                        </Grid.ColumnDefinitions>

                        <!-- Creator -->
                        <StackPanel Grid.Column="0" Spacing="16">
                            <TextBlock Text="Create Restore Point" FontSize="18" FontWeight="Bold" />
                            <TextBlock Text="Create a system state snapshot. Recommended before applying major Windows changes or driver updates." FontSize="13" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" LineHeight="18" />

                            <TextBox Header="Restore Point Description" Text="{x:Bind ViewModel.RestorePointName, Mode=TwoWay}" CornerRadius="6" />
                            <Button Content="Create System Point" Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" Click="OnCreateRestorePointClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="8" Padding="16,10" FontWeight="Bold" />

                            <MenuFlyoutSeparator Margin="0,12" />
                            <TextBlock Text="Recovery Wizard" FontSize="18" FontWeight="Bold" />
                            <TextBlock Text="Launch the official Windows System Restore recovery wizard to roll back your entire computer." FontSize="13" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" LineHeight="18" />
                            <Button Content="Launch Restore Wizard" Click="OnLaunchWizardClick" Style="{StaticResource DefaultButtonStyle}" CornerRadius="8" Padding="16,10" Foreground="{ThemeResource SystemAccentColor}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" FontWeight="Bold" />
                        </StackPanel>

                        <!-- List -->
                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="System Restore Points History" FontSize="18" FontWeight="Bold" Margin="0,0,0,16" />

                            <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.RestorePoints, Mode=OneWay}" SelectionMode="None">
                                <ListView.ItemContainerTransitions>
                                     <TransitionCollection>
                                         <AddDeleteThemeTransition />
                                         <RepositionThemeTransition />
                                     </TransitionCollection>
                                 </ListView.ItemContainerTransitions>
                                <ListView.HeaderTemplate>
                                    <DataTemplate>
                                        <Grid Padding="12,8" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="160" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Sequence" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                            <TextBlock Grid.Column="1" Text="Description" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                            <TextBlock Grid.Column="2" Text="Created Date" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.HeaderTemplate>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="engines:RestorePointInfo">
                                        <Grid Padding="12,10" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="100" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="160" />
                                            </Grid.ColumnDefinitions>
                                            
                                            <Border Width="24" Height="24" Background="#157F56D9" CornerRadius="12" HorizontalAlignment="Left" VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind SequenceNumber}" FontSize="11" Foreground="#FF7F56D9" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            
                                            <TextBlock Grid.Column="1" Text="{x:Bind Description}" FontWeight="SemiBold" VerticalAlignment="Center" FontSize="12.5" />
                                            <TextBlock Grid.Column="2" Text="{x:Bind CreatedTime}" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Grid>
                </Border>
            </PivotItem>
        </Pivot>
        
        <TextBlock Grid.Row="1" Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" VerticalAlignment="Bottom" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" Margin="0,0,0,8" />
    </Grid>
</Page>
