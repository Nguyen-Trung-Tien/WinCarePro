<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinCarePro.Views.RegistryBackupPage"
    x:Name="RootPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:WinCarePro.Models"
    xmlns:engines="using:WinCarePro.Engines"
    xmlns:local="using:WinCarePro.Views"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Registry Diagnostics &amp; Snapshots" Style="{ThemeResource TitleTextBlockStyle}" FontWeight="Bold" />
            <TextBlock Text="Scan registry trees for broken keys, export hive backups, and manage Windows System Restore snapshots." Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
        </StackPanel>

        <!-- Pivot Tabs -->
        <Pivot Grid.Row="1">
            <!-- Registry Scanner Tab -->
            <PivotItem Header="Registry Scanner">
                <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="0,12,12,12" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,16">
                            <Button Content="Scan Registry" Style="{StaticResource AccentButtonStyle}" Click="OnScanRegistryClick" IsEnabled="{x:Bind IsNot(ViewModel.IsScanningRegistry), Mode=OneWay}" Padding="16,8" CornerRadius="6" />
                            <Button Content="Fix Selected" Style="{StaticResource DefaultButtonStyle}" Click="OnFixRegistryClick" IsEnabled="{x:Bind CanFix(ViewModel.RegistryIssues.Count, ViewModel.IsBusy), Mode=OneWay}" Padding="16,8" CornerRadius="6" />
                        </StackPanel>

                        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.RegistryIssues, Mode=OneWay}" SelectionMode="None">
                            <ListView.HeaderTemplate>
                                <DataTemplate>
                                    <Grid Padding="12,6" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="350" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Select" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="1" Text="Category" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" Margin="12,0,0,0" />
                                        <TextBlock Grid.Column="2" Text="Registry Key Path" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="3" Text="Diagnostics Details" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.HeaderTemplate>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:RegistryIssue">
                                    <Grid Padding="12" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="350" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <CheckBox IsChecked="{x:Bind IsSelected, Mode=TwoWay}" VerticalAlignment="Center" />
                                        
                                        <TextBlock Grid.Column="1" Text="{x:Bind Section}" FontWeight="SemiBold" VerticalAlignment="Center" Style="{ThemeResource CaptionTextBlockStyle}" Margin="12,0,0,0" />
                                        <TextBlock Grid.Column="2" Text="{x:Bind KeyPath}" VerticalAlignment="Center" TextWrapping="NoWrap" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" Margin="0,0,12,0" />
                                        <TextBlock Grid.Column="3" Text="{x:Bind Description}" VerticalAlignment="Center" TextWrapping="Wrap" Style="{ThemeResource CaptionTextBlockStyle}" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </PivotItem>

            <!-- Registry Backup Tab -->
            <PivotItem Header="Registry Backups">
                <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="0,12,12,12" Padding="16">
                    <Grid ColumnSpacing="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="3*" />
                        </Grid.ColumnDefinitions>

                        <!-- Creator -->
                        <StackPanel Grid.Column="0" Spacing="16">
                            <TextBlock Text="Create Registry Backup" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="Bold" />
                            <TextBlock Text="Exports your Current User registry keys. Safely restore them if program settings get corrupted." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" />
                            
                            <TextBox Header="Backup Filename Name" Text="{x:Bind ViewModel.BackupName, Mode=TwoWay}" CornerRadius="6" />
                            <Button Content="Create Backup File" Style="{StaticResource AccentButtonStyle}" Click="OnCreateBackupClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="6" Padding="12,6" />
                        </StackPanel>

                        <!-- List & Restore -->
                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Available Registry Backup Files" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="Bold" Margin="0,0,0,12" />
                            
                            <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.RegistryBackups, Mode=OneWay}" SelectionMode="None">
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="models:RegistryBackupItem">
                                        <Grid Padding="8,12" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind Name}" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                                <TextBlock Text="{x:Bind FilePath}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" FontSize="10" TextWrapping="NoWrap" />
                                            </StackPanel>
                                            <Button Grid.Column="1" Content="Restore Backup" Click="OnRestoreBackupClick" Tag="{x:Bind FilePath}" IsEnabled="{Binding DataContext.IsNotBusy, ElementName=RootPage}" CornerRadius="4" FontSize="11" Padding="8,4" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Grid>
                </Border>
            </PivotItem>

            <!-- System Restore Points Tab -->
            <PivotItem Header="System Restore Snapshots">
                <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="0,12,12,12" Padding="16">
                    <Grid ColumnSpacing="24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*" />
                            <ColumnDefinition Width="3*" />
                        </Grid.ColumnDefinitions>

                        <!-- Creator -->
                        <StackPanel Grid.Column="0" Spacing="16">
                            <TextBlock Text="Create Restore Point" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="Bold" />
                            <TextBlock Text="Create a system state snapshot. Recommended before applying major Windows changes or driver updates." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" />

                            <TextBox Header="Restore Point Description" Text="{x:Bind ViewModel.RestorePointName, Mode=TwoWay}" CornerRadius="6" />
                            <Button Content="Create System Point" Style="{StaticResource AccentButtonStyle}" Click="OnCreateRestorePointClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="6" Padding="12,6" />

                            <MenuFlyoutSeparator Margin="0,12" />
                            <TextBlock Text="Recovery Wizard" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="Bold" />
                            <TextBlock Text="Launch the official Windows System Restore recovery wizard to roll back your entire computer." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" />
                            <Button Content="Launch Restore Wizard" Click="OnLaunchWizardClick" CornerRadius="6" Padding="12,6" />
                        </StackPanel>

                        <!-- List -->
                        <Grid Grid.Column="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="System Restore Points History" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="Bold" Margin="0,0,0,12" />

                            <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.RestorePoints, Mode=OneWay}" SelectionMode="None">
                                <ListView.HeaderTemplate>
                                    <DataTemplate>
                                        <Grid Padding="12,6" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="150" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="Sequence" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                            <TextBlock Grid.Column="1" Text="Description" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                            <TextBlock Grid.Column="2" Text="Created Date" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.HeaderTemplate>
                                <ListView.ItemTemplate>
                                    <DataTemplate x:DataType="engines:RestorePointInfo">
                                        <Grid Padding="12" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="150" />
                                            </Grid.ColumnDefinitions>
                                            
                                            <TextBlock Text="{x:Bind SequenceNumber}" VerticalAlignment="Center" Style="{ThemeResource CaptionTextBlockStyle}" />
                                            <TextBlock Grid.Column="1" Text="{x:Bind Description}" FontWeight="SemiBold" VerticalAlignment="Center" Style="{ThemeResource CaptionTextBlockStyle}" />
                                            <TextBlock Grid.Column="2" Text="{x:Bind CreatedTime}" VerticalAlignment="Center" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                        </Grid>
                                    </DataTemplate>
                                </ListView.ItemTemplate>
                            </ListView>
                        </Grid>
                    </Grid>
                </Border>
            </PivotItem>
        </Pivot>
        
        <TextBlock Grid.Row="1" Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" VerticalAlignment="Bottom" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" Margin="0,0,0,8" />
    </Grid>
</Page>
