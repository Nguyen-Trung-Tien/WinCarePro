<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinCarePro.Views.RepairPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:WinCarePro.ViewModels"
    mc:Ignorable="d">

    <Grid Padding="24" ColumnSpacing="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2.2*" />
            <ColumnDefinition Width="2.8*" />
        </Grid.ColumnDefinitions>

        <!-- Left: Diagnostics Actions -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12">
                <Border Style="{StaticResource ModernCardStyle}" Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock Text="SFC Component Verification" FontSize="15" FontWeight="Bold" />
                        <TextBlock Text="Scans and restores system file indices against the local Windows components store." FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                            <Button Content="SFC Scan" Click="OnSfcScanClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="4" Padding="12,5" />
                            <Button Content="SFC Scan &amp; Repair" Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" Click="OnSfcRepairClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="4" Padding="12,5" FontWeight="Bold" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource ModernCardStyle}" Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock Text="DISM OS Image Verification" FontSize="15" FontWeight="Bold" />
                        <TextBlock Text="Validates OS image components against official cloud-based Windows Update feeds." FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" />
                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                            <Button Content="DISM Check" Click="OnDismCheckClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="4" Padding="12,5" />
                            <Button Content="DISM Restore Health" Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" Click="OnDismRestoreClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="4" Padding="12,5" FontWeight="Bold" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource ModernCardStyle}" Padding="16">
                    <StackPanel Spacing="8">
                        <TextBlock Text="Scheduled Automations" FontSize="15" FontWeight="Bold" />
                        <TextBlock Text="Stop update loops, flush local download cache directories, and reconstruct database schemas." FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" />
                        <Button Content="Reset Windows Update Components" Click="OnResetUpdateClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="4" Padding="12,6" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <!-- Services Restore -->
                <Border Style="{StaticResource ModernCardStyle}" Padding="16">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Services Restoration Registry" FontSize="15" FontWeight="Bold" />
                        <TextBlock Text="Restore background core update services to standard boot setups." FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />

                        <ItemsControl ItemsSource="{x:Bind ViewModel.Services, Mode=OneWay}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate x:DataType="vm:RepairServiceItem">
                                    <Grid Padding="0,4" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox IsChecked="{x:Bind IsSelected, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,8,0" MinWidth="20" />
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind DisplayName}" FontWeight="SemiBold" FontSize="11.5" />
                                            <TextBlock Text="{x:Bind Name}" FontSize="9.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="2" Text="{x:Bind Status}" FontSize="11" FontWeight="Bold" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                            <Button Content="Restore Selected Services" Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" Click="OnRestoreServicesClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="4" Padding="12,5" FontWeight="Bold" />
                        </StackPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>

        <!-- Right: Terminal Console Output -->
        <Grid Grid.Column="1" RowSpacing="12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Style="{StaticResource ModernCardStyle}" Padding="12">
                <StackPanel Spacing="6">
                    <Grid>
                        <TextBlock Text="Operation Progress" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" HorizontalAlignment="Left" />
                        <TextBlock Text="{x:Bind ViewModel.RepairProgressPercent, Mode=OneWay}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/>
                    </Grid>
                    <ProgressBar Value="{x:Bind ViewModel.RepairProgressPercent, Mode=OneWay}" Maximum="100" Height="6" CornerRadius="3" Foreground="{StaticResource PrimaryAccentGradient}" />
                </StackPanel>
            </Border>

            <Grid Grid.Row="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="#1E293B" CornerRadius="8,8,0,0" Padding="12,8" BorderBrush="#447F56D9" BorderThickness="1,1,1,0">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Ellipse Width="8" Height="8" Fill="#FFEF4444" />
                        <Ellipse Width="8" Height="8" Fill="#FFF59E0B" />
                        <Ellipse Width="8" Height="8" Fill="#FF10B981" />
                        <TextBlock Text="ANSI Syntax Log Console" FontSize="11.5" FontWeight="Bold" Foreground="#94A3B8" Margin="8,0,0,0"/>
                    </StackPanel>
                </Border>

                <TextBox Grid.Row="1" Text="{x:Bind ViewModel.ConsoleLog, Mode=OneWay}" Style="{StaticResource DarkTerminalStyle}" CornerRadius="0,0,8,8" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" ScrollViewer.VerticalScrollBarVisibility="Auto" />
            </Grid>
        </Grid>
    </Grid>
</Page>
