<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinCarePro.Views.RepairPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:WinCarePro.ViewModels"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" /> <!-- Header Section -->
            <RowDefinition Height="Auto" /> <!-- Stats Banner Section -->
            <RowDefinition Height="*" />    <!-- Main Operations Area -->
        </Grid.RowDefinitions>

        <!-- 1. Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="4">
                <TextBlock Text="System Repair Center" FontSize="26" FontWeight="ExtraBold" CharacterSpacing="-0.5" />
                <TextBlock Text="Diagnose registry policies, check Windows components integrity, fix core services, and restore network settings." FontSize="13" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
            </StackPanel>
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" Click="OnScanDiagnosticsClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="8" Padding="16,8" FontWeight="Bold">
                    <Button.ContentTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE721;" FontSize="14" />
                                <TextBlock Text="Scan Diagnostics" VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </Button.ContentTemplate>
                </Button>
                <Button Click="OnFixSelectedClick" IsEnabled="{x:Bind CanFixSelected(ViewModel.DiscoveredIssuesCount, ViewModel.IsBusy), Mode=OneWay}" CornerRadius="8" Padding="16,8">
                    <Button.ContentTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE77F;" FontSize="14" />
                                <TextBlock Text="Fix Selected" VerticalAlignment="Center" />
                            </StackPanel>
                        </DataTemplate>
                    </Button.ContentTemplate>
                </Button>
            </StackPanel>
        </Grid>

        <!-- 2. Statistics Grid Section -->
        <Grid Grid.Row="1" Margin="0,0,0,16" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Card 1: Core Services Status -->
            <Border Grid.Column="0" Style="{StaticResource QuickStatCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE713;" FontSize="24" Foreground="#FF7F56D9" Margin="0,0,12,0" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Services Active" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                        <StackPanel Orientation="Horizontal" Spacing="4">
                            <TextBlock Text="{x:Bind ViewModel.ServicesHealthyCount, Mode=OneWay}" FontSize="18" FontWeight="ExtraBold" />
                            <TextBlock Text="/ 5" FontSize="12" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Card 2: Registry Policy Bans -->
            <Border Grid.Column="1" Style="{StaticResource QuickStatCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xEDA2;" FontSize="24" Foreground="#FFEF4444" Margin="0,0,12,0" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="Policy Bans Found" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.RegistryRestrictionsCount, Mode=OneWay}" FontSize="18" FontWeight="ExtraBold" Foreground="{x:Bind GetRestrictionColor(ViewModel.RegistryRestrictionsCount), Mode=OneWay}" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Card 3: DNS Query Response -->
            <Border Grid.Column="2" Style="{StaticResource QuickStatCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE774;" FontSize="24" Foreground="#FF3B82F6" Margin="0,0,12,0" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="DNS Query Ping" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                        <TextBlock Text="{x:Bind ViewModel.NetworkPingStatus, Mode=OneWay}" FontSize="18" FontWeight="ExtraBold" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Card 4: Health Score -->
            <Border Grid.Column="3" Style="{StaticResource QuickStatCardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE73E;" FontSize="24" Foreground="{x:Bind GetScoreColor(ViewModel.HealthScore), Mode=OneWay}" Margin="0,0,12,0" VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="System Security Score" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                        <TextBlock Text="{x:Bind GetScoreText(ViewModel.HealthScore), Mode=OneWay}" FontSize="16" FontWeight="ExtraBold" Foreground="{x:Bind GetScoreColor(ViewModel.HealthScore), Mode=OneWay}" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- 3. Main Content Area -->
        <Grid Grid.Row="2" ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*" />
                <ColumnDefinition Width="0.8*" />
            </Grid.ColumnDefinitions>

            <!-- Left: Diagnostics Actions -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="0,0,8,0">
                <StackPanel Spacing="16">

                    <!-- Diagnostic Scans Prompt -->
                    <Border Visibility="{x:Bind ViewModel.HasDiagnosticsRun, Mode=OneWay, Converter={StaticResource InverseBooleanToVisibilityConverter}}" Style="{StaticResource ModernCardStyle}" Padding="24" Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}">
                        <StackPanel Spacing="16" HorizontalAlignment="Center" Padding="0,32">
                            <Border Width="64" Height="64" CornerRadius="32" Background="{StaticResource PrimaryAccentGradient}" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE721;" FontSize="28" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                            </Border>
                            <StackPanel Spacing="6" HorizontalAlignment="Center">
                                <TextBlock Text="Run System Diagnostics Scan" FontSize="16" FontWeight="Bold" HorizontalAlignment="Center" />
                                <TextBlock Text="Scan Windows configuration databases, network health, and core service registry startup properties." FontSize="12" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"/>
                            </StackPanel>
                            <Button Content="Scan Now" Click="OnScanDiagnosticsClick" Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" FontWeight="Bold" HorizontalAlignment="Center" Padding="20,8" CornerRadius="8" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}"/>
                        </StackPanel>
                    </Border>

                    <!-- Diagnostic Issues Cockpit -->
                    <Border Visibility="{x:Bind ViewModel.HasDiagnosticsRun, Mode=OneWay, Converter={StaticResource BooleanToVisibilityConverter}}" Style="{StaticResource ModernCardStyle}" Padding="16">
                        <StackPanel Spacing="12">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel Spacing="2">
                                    <TextBlock Text="Diagnostics Findings" FontSize="15" FontWeight="Bold" />
                                    <TextBlock Text="Issues detected in system registry policies, updates and background processes." FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                </StackPanel>
                                <Border Grid.Column="1" Padding="8,4" CornerRadius="6" Background="{x:Bind GetScoreColor(ViewModel.HealthScore), Mode=OneWay}" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind GetScoreText(ViewModel.HealthScore), Mode=OneWay}" FontSize="12" FontWeight="Bold" Foreground="White" />
                                </Border>
                            </Grid>

                            <MenuFlyoutSeparator />

                            <!-- Issues List -->
                            <ItemsControl ItemsSource="{x:Bind ViewModel.DiscoveredIssues, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:DiagnosticIssueItem">
                                        <Grid Padding="0,8" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            
                                            <CheckBox IsChecked="{x:Bind IsSelected, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,12,0" MinWidth="20" IsEnabled="{x:Bind IsNotFixed, Mode=OneWay}" />
                                            
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="{x:Bind Title}" FontWeight="SemiBold" FontSize="12.5" />
                                                    <Border Padding="6,1" CornerRadius="4" Background="{ThemeResource SystemControlBackgroundBaseLowBrush}">
                                                        <TextBlock Text="{x:Bind Category}" FontSize="9" FontWeight="Bold" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                                    </Border>
                                                </StackPanel>
                                                <TextBlock Text="{x:Bind Description}" FontSize="10.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" />
                                            </StackPanel>

                                            <Border Grid.Column="2" Margin="12,0" VerticalAlignment="Center" CornerRadius="4" Padding="6,2" Background="{x:Bind SeverityBrush, Mode=OneWay}">
                                                <TextBlock Text="{x:Bind Severity}" FontSize="9.5" FontWeight="Bold" Foreground="White" />
                                            </Border>

                                            <TextBlock Grid.Column="3" Text="{x:Bind Status}" FontSize="11" FontWeight="Bold" Foreground="{x:Bind StatusBrush, Mode=OneWay}" VerticalAlignment="Center" Margin="8,0,4,0" Width="60" TextAlignment="Right"/>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Repair Actions -->
                            <Button Content="Auto-Repair Selected Issues" Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" Click="OnFixSelectedClick" IsEnabled="{x:Bind CanFixSelected(ViewModel.DiscoveredIssuesCount, ViewModel.IsBusy), Mode=OneWay}" CornerRadius="8" Padding="16,8" FontWeight="Bold" HorizontalAlignment="Right" />
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Manual Troubleshooting Tools" FontSize="16" FontWeight="ExtraBold" Margin="0,8,0,0"/>

                    <!-- SFC & DISM integrity Scans -->
                    <Border Style="{StaticResource ModernCardStyle}" Padding="16">
                        <StackPanel Spacing="8">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xF16A;" FontSize="18" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Center"/>
                                <TextBlock Text="SFC Component Verification" FontSize="15" FontWeight="Bold" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Text="Scans and restores system file indices against the local Windows components store." FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" />
                            <Grid ColumnSpacing="8" Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Content="SFC Scan" Click="OnSfcScanClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="4" Padding="12,5" HorizontalAlignment="Stretch" />
                                <Button Grid.Column="1" Content="SFC Repair" Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" Click="OnSfcRepairClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="4" Padding="12,5" FontWeight="Bold" HorizontalAlignment="Stretch" />
                                <Button Grid.Column="2" Content="DISM Check" Click="OnDismCheckClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="4" Padding="12,5" HorizontalAlignment="Stretch" />
                                <Button Grid.Column="3" Content="DISM Restore" Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" Click="OnDismRestoreClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="4" Padding="12,5" FontWeight="Bold" HorizontalAlignment="Stretch" />
                            </Grid>
                        </StackPanel>
                    </Border>

                    <!-- Advanced Safeguards & Policies -->
                    <Border Style="{StaticResource ModernCardStyle}" Padding="16">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            
                            <!-- Col 1: System Policies & Extensions -->
                            <StackPanel Grid.Column="0" Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xEDA2;" FontSize="18" Foreground="Tomato" VerticalAlignment="Center"/>
                                    <TextBlock Text="Registry &amp; Policies" FontSize="15" FontWeight="Bold" VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Text="Restore standard policies allowing Task Manager, Command Prompt, Registry Editor and fix file links." FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" />
                                <Button Content="Repair Registry Policies" Click="OnRepairRegistryPoliciesClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="4" Padding="12,6" HorizontalAlignment="Stretch" />
                            </StackPanel>

                            <!-- Col 2: Safekeep Restore Points -->
                            <StackPanel Grid.Column="1" Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xEC7A;" FontSize="18" Foreground="MediumAquamarine" VerticalAlignment="Center"/>
                                    <TextBlock Text="System Protection" FontSize="15" FontWeight="Bold" VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Text="Create a system restore point checkpoint immediately. Safely undo any system modifications." FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" />
                                <Button Content="Create Restore Point" Click="OnCreateRestorePointClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="4" Padding="12,6" HorizontalAlignment="Stretch" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Windows Update & Network Repair -->
                    <Border Style="{StaticResource ModernCardStyle}" Padding="16">
                        <Grid ColumnSpacing="12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            
                            <!-- Col 1: Windows Update Cache -->
                            <StackPanel Grid.Column="0" Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE736;" FontSize="18" Foreground="Crimson" VerticalAlignment="Center"/>
                                    <TextBlock Text="Windows Update Fixer" FontSize="15" FontWeight="Bold" VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Text="Resets update databases, stops loops, flushes temporary system download cache files, and restarts services." FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" />
                                <Button Content="Reset Update Components" Click="OnResetUpdateClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="4" Padding="12,6" HorizontalAlignment="Stretch" />
                            </StackPanel>

                            <!-- Col 2: Network Stack Fixer -->
                            <StackPanel Grid.Column="1" Spacing="8">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE774;" FontSize="18" Foreground="DodgerBlue" VerticalAlignment="Center"/>
                                    <TextBlock Text="Network Stack Reset" FontSize="15" FontWeight="Bold" VerticalAlignment="Center" />
                                </StackPanel>
                                <TextBlock Text="Flushes DNS resolver logs, registers DNS names, releases/renews network adapter IP leases and resets Winsock catalog." FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" />
                                <Button Content="Flush DNS &amp; Winsock Reset" Click="OnRepairNetworkStackClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="4" Padding="12,6" HorizontalAlignment="Stretch" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <!-- Services Restore Checklist -->
                    <Border Style="{StaticResource ModernCardStyle}" Padding="16">
                        <StackPanel Spacing="10">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE713;" FontSize="18" Foreground="Gold" VerticalAlignment="Center"/>
                                <TextBlock Text="Services Restoration Registry" FontSize="15" FontWeight="Bold" VerticalAlignment="Center" />
                            </StackPanel>
                            <TextBlock Text="Restore background core update services to standard boot setups." FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />

                            <ItemsControl ItemsSource="{x:Bind ViewModel.Services, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:RepairServiceItem">
                                        <Grid Padding="0,4" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <CheckBox IsChecked="{x:Bind IsSelected, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,8,0" MinWidth="20" />
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{x:Bind DisplayName}" FontWeight="SemiBold" FontSize="11.5" />
                                                <TextBlock Text="{x:Bind Name}" FontSize="9.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="2" Text="{x:Bind Status}" FontSize="11" FontWeight="Bold" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                <Button Content="Restore Selected Services" Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" Click="OnRestoreServicesClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="4" Padding="12,5" FontWeight="Bold" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Right: Terminal Console Output -->
            <Grid Grid.Column="1" RowSpacing="12">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Style="{StaticResource ModernCardStyle}" Padding="12">
                    <StackPanel Spacing="6">
                        <Grid>
                            <TextBlock Text="Operation Progress" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" HorizontalAlignment="Left" />
                            <TextBlock Text="{x:Bind GetProgressText(ViewModel.RepairProgressPercent), Mode=OneWay}" FontSize="11" FontWeight="Bold" HorizontalAlignment="Right"/>
                        </Grid>
                        <ProgressBar Value="{x:Bind ViewModel.RepairProgressPercent, Mode=OneWay}" Maximum="100" Height="6" CornerRadius="3" Foreground="{StaticResource PrimaryAccentGradient}" />
                    </StackPanel>
                </Border>

                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#1E293B" CornerRadius="8,8,0,0" Padding="12,8" BorderBrush="#447F56D9" BorderThickness="1,1,1,0">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <Ellipse Width="8" Height="8" Fill="#FFEF4444" />
                            <Ellipse Width="8" Height="8" Fill="#FFF59E0B" />
                            <Ellipse Width="8" Height="8" Fill="#FF10B981" />
                            <TextBlock Text="ANSI Syntax Log Console" FontSize="11.5" FontWeight="Bold" Foreground="#94A3B8" Margin="8,0,0,0"/>
                        </StackPanel>
                    </Border>

                    <TextBox x:Name="ConsoleLogTextBox" Grid.Row="1" Text="{x:Bind ViewModel.ConsoleLog, Mode=OneWay}" Style="{StaticResource DarkTerminalStyle}" CornerRadius="0,0,8,8" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" ScrollViewer.VerticalScrollBarVisibility="Auto" />
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
