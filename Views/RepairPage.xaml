<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinCarePro.Views.RepairPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:vm="using:WinCarePro.ViewModels"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.ChildrenTransitions>
            <TransitionCollection>
                <EntranceThemeTransition FromHorizontalOffset="0" FromVerticalOffset="20" />
            </TransitionCollection>
        </Grid.ChildrenTransitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <StackPanel>
                <TextBlock Text="Windows OS Repair Center" FontSize="28" FontWeight="ExtraBold" CharacterSpacing="-10" />
                <TextBlock Text="Diagnose and repair corrupted Windows image files, service configurations, and update components." Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" Margin="0,4,0,0" />
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1" ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.2*" />
                <ColumnDefinition Width="2.8*" />
            </Grid.ColumnDefinitions>

            <!-- Repair Actions List -->
            <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
                <StackPanel Spacing="16" Margin="0,0,4,0">
                    <!-- SFC Card -->
                    <Border Style="{StaticResource ModernCardStyle}" Padding="18">
                        <StackPanel Spacing="10">
                            <TextBlock Text="System File Checker (SFC)" FontSize="16" FontWeight="Bold" />
                            <TextBlock Text="Scans and restores corrupted Windows system files from local component store." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" LineHeight="14" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="Scan Only" Click="OnSfcScanClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="6" Padding="12,6" />
                                <Button Content="Scan &amp; Repair" Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" Click="OnSfcRepairClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="6" Padding="14,6" FontWeight="SemiBold" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- DISM Card -->
                    <Border Style="{StaticResource ModernCardStyle}" Padding="18">
                        <StackPanel Spacing="10">
                            <TextBlock Text="DISM Deployment Imaging" FontSize="16" FontWeight="Bold" />
                            <TextBlock Text="Validates operating system image components and repairs corruption against official Windows Update source." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" LineHeight="14" />
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="Check" Click="OnDismCheckClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="6" Padding="10,6" />
                                <Button Content="Scan" Click="OnDismScanClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="6" Padding="10,6" />
                                <Button Content="Restore Health" Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" Click="OnDismRestoreClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="6" Padding="14,6" FontWeight="SemiBold" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Windows Update Troubleshooter -->
                    <Border Style="{StaticResource ModernCardStyle}" Padding="18">
                        <StackPanel Spacing="10">
                            <TextBlock Text="Windows Update Repair" FontSize="16" FontWeight="Bold" />
                            <TextBlock Text="Stops update services, purges SoftwareDistribution cache download directory, and restores update registries." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" LineHeight="14" />
                            <Button Content="Reset Update Components" Click="OnResetUpdateClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="6" Padding="14,8" />
                        </StackPanel>
                    </Border>

                    <!-- Services Configuration -->
                    <Border Style="{StaticResource ModernCardStyle}" Padding="18">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Services Restoration" FontSize="16" FontWeight="Bold" />
                            <TextBlock Text="Selectively restore and enable core Windows services to default configurations." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" LineHeight="14" />
                            
                            <!-- Services Checklist -->
                            <ItemsControl ItemsSource="{x:Bind ViewModel.Services, Mode=OneWay}" Margin="0,4,0,8">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="vm:RepairServiceItem" xmlns:vm="using:WinCarePro.ViewModels">
                                        <Grid Padding="0,6" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            
                                            <CheckBox IsChecked="{x:Bind IsSelected, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,8,0" MinWidth="24" />
                                            
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,8,0">
                                                <TextBlock Text="{x:Bind DisplayName}" FontWeight="SemiBold" FontSize="12.5" />
                                                <TextBlock Text="{x:Bind Name}" FontSize="10.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                            </StackPanel>
                                            
                                            <StackPanel Grid.Column="2" VerticalAlignment="Center" HorizontalAlignment="Right" Spacing="1">
                                                <TextBlock Text="{x:Bind Status}" FontSize="11" FontWeight="Bold" Foreground="{ThemeResource SystemAccentColor}" HorizontalAlignment="Right" />
                                                <TextBlock Text="{x:Bind StartupType}" FontSize="10" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" HorizontalAlignment="Right" />
                                            </StackPanel>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <Button Content="Select All" Click="OnSelectAllServicesClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="6" FontSize="11" Padding="8,4" />
                                <Button Content="Deselect All" Click="OnDeselectAllServicesClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="6" FontSize="11" Padding="8,4" />
                                <Button Content="Restore Selected" Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" Click="OnRestoreServicesClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="6" FontSize="11" Padding="10,4" FontWeight="Bold" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </ScrollViewer>

            <!-- Console Output & Progress -->
            <Grid Grid.Column="1" RowSpacing="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Style="{StaticResource ModernCardStyle}" Padding="14">
                    <StackPanel Spacing="8">
                        <Grid>
                            <TextBlock Text="Progress Status" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" HorizontalAlignment="Left" />
                            <TextBlock Text="{x:Bind FormatPercent(ViewModel.ProgressPercent), Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}" FontWeight="Bold" HorizontalAlignment="Right" />
                        </Grid>
                        <ProgressBar Value="{x:Bind ViewModel.ProgressPercent, Mode=OneWay}" Maximum="100" Height="8" Foreground="{StaticResource PrimaryAccentGradient}" CornerRadius="4" />
                    </StackPanel>
                </Border>

                <!-- Professional Console Layout -->
                <Grid Grid.Row="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    
                    <!-- Title Bar -->
                    <Border Grid.Row="0" Background="#1E293B" CornerRadius="12,12,0,0" Padding="12,10" BorderBrush="#447F56D9" BorderThickness="1.5,1.5,1.5,0">
                        <Grid>
                            <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                                <Ellipse Width="10" Height="10" Fill="#FFEF4444" />
                                <Ellipse Width="10" Height="10" Fill="#FFF59E0B" />
                                <Ellipse Width="10" Height="10" Fill="#FF10B981" />
                                <TextBlock Text="System Repair Terminal" FontSize="11" FontWeight="Bold" Foreground="#94A3B8" Margin="8,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>
                            <FontIcon Glyph="&#xE756;" FontSize="12" Foreground="#94A3B8" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <TextBox Grid.Row="1" Text="{x:Bind ViewModel.ConsoleLog, Mode=OneWay}" Style="{StaticResource DarkTerminalStyle}" CornerRadius="0,0,12,12" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" ScrollViewer.VerticalScrollBarVisibility="Auto" />
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
