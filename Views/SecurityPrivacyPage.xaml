<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinCarePro.Views.SecurityPrivacyPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.ChildrenTransitions>
            <TransitionCollection>
                <EntranceThemeTransition FromHorizontalOffset="0" FromVerticalOffset="15" />
            </TransitionCollection>
        </Grid.ChildrenTransitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="4">
                <TextBlock Text="Security &amp; Privacy Center" FontSize="28" FontWeight="ExtraBold" Foreground="{ThemeResource SystemControlPageTextBaseHighBrush}" />
                <TextBlock Text="Audit antivirus protection, configure tracking parameters, and flush identity metadata." FontSize="14" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
            </StackPanel>
            <Button Grid.Column="1" Content="Perform Audit" Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" Click="OnRefreshClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" VerticalAlignment="Center" Padding="20,10" CornerRadius="8" FontWeight="Bold" />
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <Grid RowSpacing="24" ColumnSpacing="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>

                <!-- Col 1: Security Monitoring & Warnings -->
                <StackPanel Grid.Row="0" Grid.Column="0" Spacing="24">
                    <!-- Security Auditing Details -->
                    <Border Style="{StaticResource ModernCardStyle}" Padding="24">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            
                            <TextBlock Grid.Row="0" Text="Protection Status" FontSize="18" FontWeight="Bold" Margin="0,0,0,20" />
                            
                            <Grid Grid.Row="1" RowSpacing="20" ColumnSpacing="24">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal" Spacing="12">
                                    <Border Width="40" Height="40" Background="#157F56D9" CornerRadius="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE73A;" FontSize="18" Foreground="#FF7F56D9" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Antivirus Software" FontSize="11.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                        <TextBlock Text="{x:Bind ViewModel.AntivirusStatus, Mode=OneWay}" FontSize="13.5" FontWeight="Bold" />
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal" Spacing="12">
                                    <Border Width="40" Height="40" Background="#153B82F6" CornerRadius="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE7F4;" FontSize="18" Foreground="#FF3B82F6" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="Windows Firewall" FontSize="11.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                        <TextBlock Text="{x:Bind ViewModel.FirewallStatus, Mode=OneWay}" FontSize="13.5" FontWeight="Bold" />
                                    </StackPanel>
                                </StackPanel>

                                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal" Spacing="12">
                                    <Border Width="40" Height="40" Background="#1510B981" CornerRadius="8" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <FontIcon Glyph="&#xE8A5;" FontSize="18" Foreground="#FF10B981" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="BitLocker Encryption" FontSize="11.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                        <TextBlock Text="{x:Bind ViewModel.BitLockerStatus, Mode=OneWay}" FontSize="13.5" FontWeight="Bold" />
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Auditing Logs warnings -->
                    <Border Style="{StaticResource ModernCardStyle}" Padding="24">
                        <StackPanel Spacing="16">
                            <TextBlock Text="Vulnerability Audits" FontSize="18" FontWeight="Bold" />
                            
                            <!-- If no warnings -->
                            <TextBlock Text="No immediate security threats detected. Antivirus shield is active." FontSize="13" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" Visibility="{x:Bind GetVisibility(ViewModel.AuditWarnings.Count), Mode=OneWay}" />
                            
                            <ItemsControl ItemsSource="{x:Bind ViewModel.AuditWarnings, Mode=OneWay}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate x:DataType="x:String">
                                        <Border BorderBrush="#20EF4444" BorderThickness="1" Background="#10EF4444" CornerRadius="8" Margin="0,0,0,8" Padding="14">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <FontIcon Glyph="&#xE7BA;" FontSize="14" Foreground="#EF4444" VerticalAlignment="Center" Margin="0,0,12,0" />
                                                <TextBlock Grid.Column="1" Text="{x:Bind}" TextWrapping="Wrap" FontSize="12.5" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#EF4444" />
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Col 2: Privacy Controls and Cleaners -->
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="16,0,0,0" Spacing="24">
                    <!-- Privacy Switches -->
                    <Border Style="{StaticResource ModernCardStyle}" Padding="24">
                        <StackPanel Spacing="20">
                            <TextBlock Text="Privacy Toggles" FontSize="18" FontWeight="Bold" Margin="0,0,0,4" />
                            
                            <ToggleSwitch Header="Personalized Advertising ID" IsOn="{x:Bind ViewModel.AdvertisingIdEnabled, Mode=TwoWay}" CornerRadius="6" FontSize="12.5" />
                            <ToggleSwitch Header="Diagnostics Telemetry Logs" IsOn="{x:Bind ViewModel.TelemetryEnabled, Mode=TwoWay}" CornerRadius="6" FontSize="12.5" />
                            <ToggleSwitch Header="Clipboard Cloud History" IsOn="{x:Bind ViewModel.ClipboardHistoryEnabled, Mode=TwoWay}" CornerRadius="6" FontSize="12.5" />
                            <ToggleSwitch Header="Restrict Implicit Search tracking" IsOn="{x:Bind ViewModel.RestrictTrackingEnabled, Mode=TwoWay}" CornerRadius="6" FontSize="12.5" />
                        </StackPanel>
                    </Border>

                    <!-- Quick Cleaners -->
                    <Border Style="{StaticResource ModernCardStyle}" Padding="24">
                        <StackPanel Spacing="16">
                            <TextBlock Text="Privacy Quick Cleaners" FontSize="18" FontWeight="Bold" />
                            <TextBlock Text="Purge immediate activity data caching locally." FontSize="13" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" Margin="0,0,0,4"/>
                            
                            <Button Content="Purge Clipboard History" Click="OnClearClipboardClick" HorizontalAlignment="Stretch" CornerRadius="8" Padding="12,10" FontWeight="Bold" Margin="0,0,0,8" />
                            <Button Content="Clear Recent Files &amp; Explorer MRUs" Click="OnClearRecentClick" HorizontalAlignment="Stretch" CornerRadius="8" Padding="12,10" FontWeight="Bold" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </ScrollViewer>
        <TextBlock Grid.Row="1" Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" VerticalAlignment="Bottom" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" Margin="0,0,0,8" />
    </Grid>
</Page>
