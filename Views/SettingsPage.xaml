<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinCarePro.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.ChildrenTransitions>
            <TransitionCollection>
                <EntranceThemeTransition FromHorizontalOffset="0" FromVerticalOffset="15" />
            </TransitionCollection>
        </Grid.ChildrenTransitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <StackPanel Spacing="4">
                <TextBlock Text="Settings &amp; Configuration" FontSize="28" FontWeight="ExtraBold" Foreground="{ThemeResource SystemControlPageTextBaseHighBrush}" />
                <TextBlock Text="Personalize application UI preferences and logs storage thresholds." FontSize="14" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="24" MaxWidth="600" HorizontalAlignment="Left">
                
                <!-- Operations configuration -->
                <Border Style="{StaticResource ModernCardStyle}" Padding="24" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="20">
                        <TextBlock Text="Maintenance Automation" FontSize="18" FontWeight="Bold" />
                        
                        <ToggleSwitch x:Name="AutoScanToggle" Toggled="OnAutoScanToggled" Header="Automated Maintenance Scan" CornerRadius="6" FontSize="12.5" />
                        
                        <StackPanel Spacing="8">
                            <TextBlock Text="Default Reports Export Format" FontSize="12.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                            <ComboBox x:Name="ReportFormatCombo" SelectionChanged="OnReportFormatChanged" SelectedIndex="0" CornerRadius="6" Width="180" Height="32">
                                <ComboBoxItem Content="Plain Text Document (.txt)" Tag="TXT" />
                                <ComboBoxItem Content="JSON Data (.json)" Tag="JSON" />
                            </ComboBox>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Data Management -->
                <Border Style="{StaticResource ModernCardStyle}" Padding="24" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="Local Database Management" FontSize="18" FontWeight="Bold" />
                        <TextBlock Text="Delete old log files and reports registered in the SQLite tables." FontSize="13" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" LineHeight="18" />
                        
                        <Button Content="Purge Database Logs History" Click="OnPurgeDatabaseClick" Style="{StaticResource DefaultButtonStyle}" Foreground="#EF4444" BorderBrush="#33EF4444" CornerRadius="8" Padding="16,10" FontWeight="Bold" HorizontalAlignment="Left" />
                    </StackPanel>
                </Border>

                <!-- About WinCare Pro & Updates -->
                <Border Style="{StaticResource ModernCardStyle}" Padding="24" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <StackPanel Spacing="16">
                        <TextBlock Text="WinCare Pro" FontSize="18" FontWeight="Bold" />
                        
                        <Grid RowSpacing="8" ColumnSpacing="20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            
                            <TextBlock Text="Version:" FontSize="12.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                            <TextBlock Grid.Column="1" x:Name="AppVersionLabel" Text="Version 1.0.0" FontSize="12.5" FontWeight="SemiBold" />
                            
                            <TextBlock Grid.Row="1" Text="Author:" FontSize="12.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="Nguyen Trung Tien" FontSize="12.5" FontWeight="SemiBold" />

                            <TextBlock Grid.Row="2" Text="Description:" FontSize="12.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="All-in-One Windows Maintenance, Optimization, and Repair Suite." FontSize="12.5" FontWeight="SemiBold" TextWrapping="Wrap" />
                        </Grid>
                        
                        <MenuFlyoutSeparator Margin="0,4" />
                        
                        <TextBlock Text="Software Updates" FontSize="14" FontWeight="Bold" />
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Button x:Name="CheckUpdatesBtn" Content="Check for Updates" Click="OnCheckUpdatesClick" Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" CornerRadius="8" Padding="16,10" FontWeight="Bold" />
                            <ProgressRing x:Name="UpdateProgressRing" IsActive="False" Width="20" Height="20" VerticalAlignment="Center" />
                            <TextBlock x:Name="UpdateStatusLabel" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" VerticalAlignment="Center" />
                        </StackPanel>
                        
                        <ProgressBar x:Name="UpdateProgressBar" Visibility="Collapsed" Maximum="100" Value="0" Height="6" CornerRadius="3" Margin="0,4,0,0" />
                        
                        <MenuFlyoutSeparator Margin="0,4" />
                        
                        <TextBlock Text="Powered by WinUI 3, .NET 10.0, and SQLite." FontSize="12" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                        <TextBlock Text="© 2026 WinCare Pro Studio. All rights reserved." FontSize="12" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                    </StackPanel>
                </Border>
                
                <TextBlock x:Name="StatusLabel" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
