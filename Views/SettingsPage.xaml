<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinCarePro.Views.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="24" x:Name="SettingsRootGrid">
        <VisualStateManager.VisualStateGroups>
            <VisualStateGroup x:Name="LayoutVisualStates">
                <!-- Wide Layout: Viewport Width >= 768px -->
                <VisualState x:Name="WideState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="768" />
                    </VisualState.StateTriggers>
                </VisualState>
                <!-- Narrow Layout: Viewport Width < 768px -->
                <VisualState x:Name="NarrowState">
                    <VisualState.StateTriggers>
                        <AdaptiveTrigger MinWindowWidth="0" />
                    </VisualState.StateTriggers>
                    <VisualState.Setters>
                        <Setter Target="SidebarBorder.(Grid.Row)" Value="0" />
                        <Setter Target="SidebarBorder.(Grid.Column)" Value="0" />
                        <Setter Target="SidebarBorder.(Grid.RowSpan)" Value="1" />
                        <Setter Target="SidebarBorder.(Grid.ColumnSpan)" Value="2" />
                        <Setter Target="SidebarBorder.BorderThickness" Value="0,0,0,1" />
                        <Setter Target="SidebarBorder.Padding" Value="0,0,0,12" />
                        
                        <Setter Target="SettingsNavStackPanel.Orientation" Value="Horizontal" />
                        <Setter Target="SettingsNavList.ScrollViewer.HorizontalScrollBarVisibility" Value="Auto" />
                        <Setter Target="SettingsNavList.ScrollViewer.VerticalScrollBarVisibility" Value="Disabled" />
                        
                        <Setter Target="ContentScrollViewer.(Grid.Row)" Value="1" />
                        <Setter Target="ContentScrollViewer.(Grid.Column)" Value="0" />
                        <Setter Target="ContentScrollViewer.(Grid.RowSpan)" Value="1" />
                        <Setter Target="ContentScrollViewer.(Grid.ColumnSpan)" Value="2" />
                        <Setter Target="ContentScrollViewer.Padding" Value="0,16,0,0" />
                    </VisualState.Setters>
                </VisualState>
            </VisualStateGroup>
        </VisualStateManager.VisualStateGroups>

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" x:Name="Row0" />
            <RowDefinition Height="*" x:Name="Row1" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" x:Name="Col0" /> <!-- Secondary Sidebar -->
            <ColumnDefinition Width="*" x:Name="Col1" />   <!-- Content Area -->
        </Grid.ColumnDefinitions>

        <!-- Vertical Navigation Panel (Secondary Sidebar) -->
        <Border x:Name="SidebarBorder" Grid.Column="0" Grid.Row="0" Grid.RowSpan="2" Grid.ColumnSpan="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,1,0" Padding="0,0,16,0">
            <ListView x:Name="SettingsNavList" SelectedIndex="0" SelectionChanged="SettingsNavList_SelectionChanged" SelectionMode="Single">
                <ListView.ItemsPanel>
                    <ItemsPanelTemplate>
                        <ItemsStackPanel x:Name="SettingsNavStackPanel" Orientation="Vertical" />
                    </ItemsPanelTemplate>
                </ListView.ItemsPanel>
                
                <ListViewItem Height="40" Padding="8,0" CornerRadius="4">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE713;" FontSize="16" Width="20" Foreground="{ThemeResource SystemAccentColor}" />
                        <TextBlock Text="General Configuration" VerticalAlignment="Center" FontSize="13"/>
                    </StackPanel>
                </ListViewItem>
                <ListViewItem Height="40" Padding="8,0" CornerRadius="4">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE790;" FontSize="16" Width="20" Foreground="{ThemeResource SystemAccentColor}" />
                        <TextBlock Text="Appearance &amp; Theme" VerticalAlignment="Center" FontSize="13"/>
                    </StackPanel>
                </ListViewItem>
                <ListViewItem Height="40" Padding="8,0" CornerRadius="4">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE812;" FontSize="16" Width="20" Foreground="{ThemeResource SystemAccentColor}" />
                        <TextBlock Text="Auto Cleanup Scheduler" VerticalAlignment="Center" FontSize="13"/>
                    </StackPanel>
                </ListViewItem>
                <ListViewItem Height="40" Padding="8,0" CornerRadius="4">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xEA8F;" FontSize="16" Width="20" Foreground="{ThemeResource SystemAccentColor}" />
                        <TextBlock Text="Monitoring &amp; Alert" VerticalAlignment="Center" FontSize="13"/>
                    </StackPanel>
                </ListViewItem>
                <ListViewItem Height="40" Padding="8,0" CornerRadius="4">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE727;" FontSize="16" Width="20" Foreground="{ThemeResource SystemAccentColor}" />
                        <TextBlock Text="Safety &amp; Rollback" VerticalAlignment="Center" FontSize="13"/>
                    </StackPanel>
                </ListViewItem>
                <ListViewItem Height="40" Padding="8,0" CornerRadius="4">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE7B4;" FontSize="16" Width="20" Foreground="{ThemeResource SystemAccentColor}" />
                        <TextBlock Text="Advanced Developer" VerticalAlignment="Center" FontSize="13"/>
                    </StackPanel>
                </ListViewItem>
                <ListViewItem Height="40" Padding="8,0" CornerRadius="4">
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <FontIcon Glyph="&#xE946;" FontSize="16" Width="20" Foreground="{ThemeResource SystemAccentColor}" />
                        <TextBlock Text="About &amp; Developer" VerticalAlignment="Center" FontSize="13"/>
                    </StackPanel>
                </ListViewItem>
            </ListView>
        </Border>

        <!-- Content Area -->
        <ScrollViewer x:Name="ContentScrollViewer" Grid.Column="1" Grid.Row="0" Grid.RowSpan="2" Grid.ColumnSpan="1" Padding="20,0,0,0" VerticalScrollBarVisibility="Auto">
            <Grid>
                <!-- Section 1: General Configuration -->
                <StackPanel Spacing="20" Visibility="{x:Bind GetSectionVisibility(SettingsNavList.SelectedIndex, 0), Mode=OneWay}">
                    <TextBlock Text="General Configurations" FontSize="18" FontWeight="Bold" />
                    
                    <Border Style="{StaticResource ModernCardStyle}" Padding="20">
                        <StackPanel Spacing="16">
                            <StackPanel Spacing="6">
                                <TextBlock Text="Language Selection" FontSize="12.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                <ComboBox x:Name="LanguageComboBox" SelectedIndex="0" Width="160" CornerRadius="4" SelectionChanged="OnLanguageSelectionChanged">
                                    <ComboBoxItem Content="English"/>
                                    <ComboBoxItem Content="Tiếng Việt"/>
                                </ComboBox>
                            </StackPanel>

                            <ToggleSwitch x:Name="AutoScanToggle" Toggled="OnAutoScanToggled" Header="Launch WinCare Pro automatically upon OS startup" CornerRadius="4" FontSize="12.5"/>
                            <ToggleSwitch x:Name="MinimizeToTrayToggle" Toggled="OnSettingsChanged" Header="Minimize application to System Tray instead of closing" IsOn="True" CornerRadius="4" FontSize="12.5"/>
                        </StackPanel>
                    </Border>

                    <!-- Update policy -->
                    <Border Style="{StaticResource ModernCardStyle}" Padding="20">
                        <StackPanel Spacing="16">
                            <TextBlock Text="Software Update Policies" FontSize="14" FontWeight="Bold" />
                            <TextBlock Text="Configure version checking and background installation options." FontSize="11.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                            
                            <ToggleSwitch x:Name="AutoUpdateToggle" Toggled="OnSettingsChanged" Header="Check for updates automatically in the background" IsOn="True" CornerRadius="4" FontSize="12.5"/>
                            <ToggleSwitch x:Name="AutoInstallUpdatesToggle" Toggled="OnSettingsChanged" Header="Auto download &amp; install updates silently (Requires background check)" IsOn="False" CornerRadius="4" FontSize="12.5"/>
                            <ToggleSwitch x:Name="BetaUpdatesToggle" Toggled="OnSettingsChanged" Header="Enroll in the pre-release channel (Beta updates)" IsOn="False" CornerRadius="4" FontSize="12.5"/>

                            <MenuFlyoutSeparator />

                            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,4,0,0">
                                <Button x:Name="CheckUpdatesBtn" Content="Check for Updates Now" Click="OnCheckUpdatesClick" Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" CornerRadius="6" Padding="12,6" FontWeight="Bold" />
                                <ProgressRing x:Name="UpdateProgressRing" IsActive="False" Width="20" Height="20" VerticalAlignment="Center" />
                                <TextBlock x:Name="UpdateStatusLabel" FontSize="12.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" VerticalAlignment="Center" />
                            </StackPanel>
                            
                            <ProgressBar x:Name="UpdateProgressBar" Visibility="Collapsed" Maximum="100" Value="0" Height="6" CornerRadius="3" Foreground="{StaticResource PrimaryAccentGradient}" />
                        </StackPanel>
                    </Border>

                    <!-- Storage footprint manager -->
                    <Border Style="{StaticResource ModernCardStyle}" Padding="20">
                        <StackPanel Spacing="16">
                            <TextBlock Text="Database &amp; Storage Footprint" FontSize="14" FontWeight="Bold" />
                            <TextBlock Text="Clean log files, diagnostic assessment reports, and temporary installation caches." FontSize="11.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                            
                            <!-- DB statistics cards -->
                            <Grid ColumnSpacing="12" Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Grid.Column="0" Style="{StaticResource QuickStatCardStyle}" Padding="12">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="Activity Logs" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                        <TextBlock x:Name="LogsDbSizeLabel" Text="Calculating..." FontSize="13" FontWeight="Bold"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Style="{StaticResource QuickStatCardStyle}" Padding="12">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="Reports Files" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                        <TextBlock x:Name="ReportsDbSizeLabel" Text="Calculating..." FontSize="13" FontWeight="Bold"/>
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Style="{StaticResource QuickStatCardStyle}" Padding="12">
                                    <StackPanel Spacing="2">
                                        <TextBlock Text="Updates Cache" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                        <TextBlock x:Name="CacheDbSizeLabel" Text="Calculating..." FontSize="13" FontWeight="Bold"/>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <StackPanel Spacing="8" Margin="0,8,0,0">
                                <CheckBox x:Name="PurgeLogsCheckbox" Content="Purge SQLite Activity History Logs" IsChecked="True" FontSize="12.5"/>
                                <CheckBox x:Name="PurgeReportsCheckbox" Content="Wipe Saved Diagnostic Report Files" IsChecked="True" FontSize="12.5"/>
                                <CheckBox x:Name="PurgeCacheCheckbox" Content="Clear Temporary Updates Installation Cache" IsChecked="True" FontSize="12.5"/>
                            </StackPanel>

                            <StackPanel Orientation="Horizontal" Spacing="12" Margin="0,8,0,0">
                                <Button Content="Purge Selected Storage" Click="OnPurgeDatabaseClick" Foreground="#FFE81123" CornerRadius="6" Padding="14,6" FontWeight="Bold"/>
                                <ProgressRing x:Name="PurgeProgressRing" IsActive="False" Width="20" Height="20" VerticalAlignment="Center" />
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Section 2: Appearance & Personalization -->
                <StackPanel Spacing="20" Visibility="{x:Bind GetSectionVisibility(SettingsNavList.SelectedIndex, 1), Mode=OneWay}">
                    <TextBlock Text="Appearance &amp; Theme Customization" FontSize="18" FontWeight="Bold" />
                    
                    <Border Style="{StaticResource ModernCardStyle}" Padding="20">
                        <StackPanel Spacing="16">
                            <TextBlock Text="Application Color Theme Mode" FontSize="13" FontWeight="Bold" />
                            
                            <!-- Elegant segmented cards for theme selection -->
                            <Grid ColumnSpacing="16" Margin="0,4,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                
                                <Border x:Name="LightThemeCard" Grid.Column="0" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1.5" CornerRadius="10" Padding="16" PointerPressed="OnLightModeCardClick" Style="{StaticResource QuickStatCardStyle}">
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <FontIcon Glyph="&#xE706;" FontSize="20" Foreground="#FFF59E0B" />
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Light Theme" FontWeight="Bold" FontSize="13" />
                                            <TextBlock Text="Clean and bright interface" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                                
                                <Border x:Name="DarkThemeCard" Grid.Column="1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1.5" CornerRadius="10" Padding="16" PointerPressed="OnDarkModeCardClick" Style="{StaticResource QuickStatCardStyle}">
                                    <StackPanel Orientation="Horizontal" Spacing="12">
                                        <FontIcon Glyph="&#xE708;" FontSize="20" Foreground="#FF8B5CF6" />
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Dark Theme" FontWeight="Bold" FontSize="13" />
                                            <TextBlock Text="Deep dark and elegant tones" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <MenuFlyoutSeparator />

                            <TextBlock Text="Window Accent Colors Palette" FontSize="13" FontWeight="Bold" />
                            <StackPanel Orientation="Horizontal" Spacing="12" x:Name="AccentSelectorPanel">
                                <Ellipse x:Name="AccentDefault" Width="28" Height="28" Fill="#FF7F56D9" PointerPressed="OnAccentClick" Tag="Default"/>
                                <Ellipse x:Name="AccentGreen" Width="28" Height="28" Fill="#FF10B981" PointerPressed="OnAccentClick" Tag="Green"/>
                                <Ellipse x:Name="AccentPurple" Width="28" Height="28" Fill="#FF8B5CF6" PointerPressed="OnAccentClick" Tag="Purple"/>
                                <Ellipse x:Name="AccentPink" Width="28" Height="28" Fill="#FFEC4899" PointerPressed="OnAccentClick" Tag="Pink"/>
                                <Ellipse x:Name="AccentAmber" Width="28" Height="28" Fill="#FFF59E0B" PointerPressed="OnAccentClick" Tag="Amber"/>
                            </StackPanel>

                            <MenuFlyoutSeparator />

                            <StackPanel Spacing="6">
                                <TextBlock Text="Mica Acrylic Background Transparency Level" FontSize="12.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                <Slider x:Name="TransparencySlider" ValueChanged="OnTransparencyChanged" Minimum="0" Maximum="100" Value="80" Width="300" HorizontalAlignment="Left"/>
                            </StackPanel>

                            <ToggleSwitch x:Name="EnableAnimationsToggle" Toggled="OnSettingsChanged" Header="Enable UI fluid translation animations" IsOn="True" CornerRadius="4" FontSize="12.5"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Section 3: Optimization & Automation Scheduler -->
                <StackPanel Spacing="20" Visibility="{x:Bind GetSectionVisibility(SettingsNavList.SelectedIndex, 2), Mode=OneWay}">
                    <TextBlock Text="Auto Maintenance Task Schedulers" FontSize="18" FontWeight="Bold" />
                    
                    <Border Style="{StaticResource ModernCardStyle}" Padding="20">
                        <StackPanel Spacing="16">
                            <StackPanel Spacing="6">
                                <Grid Width="300" HorizontalAlignment="Left">
                                    <TextBlock Text="Automated Cleanup Trigger Size" FontSize="12.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                    <TextBlock x:Name="CleanupSizeLabel" Text="5.0 GB" FontSize="12.5" FontWeight="Bold" HorizontalAlignment="Right"/>
                                </Grid>
                                <Slider x:Name="AutoCleanupSlider" ValueChanged="OnAutoCleanupSliderChanged" Minimum="1" Maximum="50" Value="5" StepFrequency="0.5" Width="300" HorizontalAlignment="Left"/>
                            </StackPanel>

                            <ToggleSwitch x:Name="TriggerSmartBoostToggle" Toggled="OnSettingsChanged" Header="Trigger Smart Boost optimization if free RAM falls below 10%" IsOn="True" CornerRadius="4" FontSize="12.5"/>
                            
                            <StackPanel Spacing="6">
                                <TextBlock Text="Maintenance Frequency" FontSize="12.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                <ComboBox x:Name="MaintenanceFrequencyComboBox" SelectionChanged="OnMaintenanceFrequencyChanged" SelectedIndex="1" Width="160" CornerRadius="4">
                                    <ComboBoxItem Content="Daily run"/>
                                    <ComboBoxItem Content="Weekly scan"/>
                                    <ComboBoxItem Content="Monthly execution"/>
                                </ComboBox>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Section 4: Telemetry & Alert Policy -->
                <StackPanel Spacing="20" Visibility="{x:Bind GetSectionVisibility(SettingsNavList.SelectedIndex, 3), Mode=OneWay}">
                    <TextBlock Text="Telemetry &amp; Notifications Configuration" FontSize="18" FontWeight="Bold" />
                    
                    <!-- Notification manager policies -->
                    <Border Style="{StaticResource ModernCardStyle}" Padding="20">
                        <StackPanel Spacing="16">
                            <TextBlock Text="Notification Center Policy" FontSize="14" FontWeight="Bold" />
                            <ToggleSwitch x:Name="ShowNotificationsToggle" Toggled="OnSettingsChanged" Header="Show dynamic in-app Toast Notifications" IsOn="True" CornerRadius="4" FontSize="12.5"/>
                            
                            <StackPanel Spacing="6">
                                <Grid Width="300" HorizontalAlignment="Left">
                                    <TextBlock Text="PC Health Rating Severity Trigger Limit" FontSize="12.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                    <TextBlock x:Name="NotificationThresholdLabel" Text="10%" FontSize="12.5" FontWeight="Bold" HorizontalAlignment="Right"/>
                                </Grid>
                                <Slider x:Name="NotificationThresholdSlider" ValueChanged="OnNotificationThresholdSliderChanged" Minimum="5" Maximum="30" Value="10" StepFrequency="1" Width="300" HorizontalAlignment="Left"/>
                            </StackPanel>

                            <ToggleSwitch x:Name="NotifyOnLowHealthToggle" Toggled="OnSettingsChanged" Header="Notify when system overall health score drops below threshold" IsOn="True" CornerRadius="4" FontSize="12.5"/>
                            <ToggleSwitch x:Name="NotifyOnMaintenanceToggle" Toggled="OnSettingsChanged" Header="Notify when system automated cleaners finish runs" IsOn="True" CornerRadius="4" FontSize="12.5"/>
                            <ToggleSwitch x:Name="ShowUpdateNotificationsToggle" Toggled="OnSettingsChanged" Header="Notify when newer packages updates are available" IsOn="True" CornerRadius="4" FontSize="12.5"/>
                            <ToggleSwitch x:Name="NotificationSoundToggle" Toggled="OnSettingsChanged" Header="Play subtle system audio alert upon notification arrival" IsOn="True" CornerRadius="4" FontSize="12.5"/>
                        </StackPanel>
                    </Border>

                    <Border Style="{StaticResource ModernCardStyle}" Padding="20">
                        <StackPanel Spacing="16">
                            <TextBlock Text="Sensors Telemetry" FontSize="14" FontWeight="Bold" />
                            <StackPanel Spacing="6">
                                <TextBlock Text="Sensors Telemetry Update Interval" FontSize="12.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                <ComboBox x:Name="TelemetryIntervalComboBox" SelectionChanged="OnSettingsChanged" SelectedIndex="1" Width="120" CornerRadius="4">
                                    <ComboBoxItem Content="0.5 seconds"/>
                                    <ComboBoxItem Content="1.0 seconds"/>
                                    <ComboBoxItem Content="2.0 seconds"/>
                                    <ComboBoxItem Content="5.0 seconds"/>
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Spacing="6">
                                <TextBlock Text="Performance history duration logger" FontSize="12.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                <ComboBox x:Name="PerformanceHistoryComboBox" SelectionChanged="OnSettingsChanged" SelectedIndex="0" Width="120" CornerRadius="4">
                                    <ComboBoxItem Content="7 Days logs"/>
                                    <ComboBoxItem Content="30 Days logs"/>
                                    <ComboBoxItem Content="90 Days logs"/>
                                </ComboBox>
                            </StackPanel>

                            <ToggleSwitch x:Name="EnableHardwareSensorsToggle" Toggled="OnSettingsChanged" Header="Enable continuous low-overhead hardware sensors scanning thread" IsOn="True" CornerRadius="4" FontSize="12.5"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Section 5: Safety & Data Security -->
                <StackPanel Spacing="20" Visibility="{x:Bind GetSectionVisibility(SettingsNavList.SelectedIndex, 4), Mode=OneWay}">
                    <TextBlock Text="Rollback &amp; Safety Registries" FontSize="18" FontWeight="Bold" />
                    
                    <Border Style="{StaticResource ModernCardStyle}" Padding="20">
                        <StackPanel Spacing="16">
                            <ToggleSwitch x:Name="CreateRestorePointToggle" Toggled="OnSettingsChanged" Header="Automatically create a System Restore Point before major updates" IsOn="True" CornerRadius="4" FontSize="12.5"/>
                            <ToggleSwitch x:Name="BackupRegistryToggle" Toggled="OnSettingsChanged" Header="Automatically backup system registry hive partitions" IsOn="True" CornerRadius="4" FontSize="12.5"/>
                            
                            <StackPanel Spacing="8">
                                <TextBlock Text="Modification Confirmation Alerts Level" FontSize="12.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                <Grid Width="300" HorizontalAlignment="Left">
                                    <Slider x:Name="AlertsLevelSlider" ValueChanged="OnSettingsChanged" Minimum="1" Maximum="3" Value="2" TickFrequency="1" SnapsTo="Ticks"/>
                                </Grid>
                                <TextBlock Text="Medium: Prompts warnings before major file tree mutations." FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Section 6: Advanced Developer Configurations -->
                <StackPanel Spacing="20" Visibility="{x:Bind GetSectionVisibility(SettingsNavList.SelectedIndex, 5), Mode=OneWay}">
                    <TextBlock Text="Advanced &amp; Sandbox Options" FontSize="18" FontWeight="Bold" />
                    
                    <Border Style="{StaticResource ModernCardStyle}" Padding="20">
                        <StackPanel Spacing="16">
                            <ToggleSwitch x:Name="EnableVerboseLogsToggle" Toggled="OnSettingsChanged" Header="Enable verbose debug logs trace files" CornerRadius="4" FontSize="12.5"/>
                            
                            <StackPanel Spacing="8">
                                <TextBlock Text="Plugin &amp; Sandbox Modules Manager" FontSize="13" FontWeight="Bold" />
                                <TextBlock Text="No custom plugins are currently loaded." FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                <Button Content="Browse Verified plugins" CornerRadius="4"/>
                            </StackPanel>

                            <MenuFlyoutSeparator />

                            <ToggleSwitch x:Name="EnableExperimentalAiToggle" Toggled="OnSettingsChanged" Header="Enable experimental AI diagnostics auto-remediations (Pre-release)" CornerRadius="4" FontSize="12.5"/>
                        </StackPanel>
                    </Border>
                    
                    <!-- Advanced diagnostic logs pane -->
                    <Border Style="{StaticResource ModernCardStyle}" Padding="20">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Diagnostics Trace Log Reader" FontSize="14" FontWeight="Bold" />
                            <TextBlock Text="Real-time application framework execution events." FontSize="11.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                            <Grid ColumnSpacing="8" Margin="0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Button Content="All Logs" Click="OnFilterTraceAllClick" FontSize="11" Padding="12,4" Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" />
                                <Button Grid.Column="1" Content="Warnings" Click="OnFilterTraceWarnClick" FontSize="11" Padding="12,4"/>
                                <Button Grid.Column="2" Content="Errors" Click="OnFilterTraceErrClick" FontSize="11" Padding="12,4"/>
                                <Button Grid.Column="3" Content="Clear Console" Click="OnClearTraceClick" HorizontalAlignment="Right" FontSize="11" Padding="12,4"/>
                            </Grid>
                            <TextBox x:Name="TraceLogTextBox" Height="180" Style="{StaticResource DarkTerminalStyle}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" ScrollViewer.VerticalScrollBarVisibility="Auto"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Section 7: About & Developer Info -->
                <StackPanel Spacing="20" Visibility="{x:Bind GetSectionVisibility(SettingsNavList.SelectedIndex, 6), Mode=OneWay}">
                    <TextBlock Text="About WinCare Pro" FontSize="18" FontWeight="Bold" />
                    
                    <Border Style="{StaticResource ModernCardStyle}" Padding="24">
                        <StackPanel Spacing="16">
                            <!-- Logo and name -->
                            <StackPanel Orientation="Horizontal" Spacing="16">
                                <Border Width="64" Height="64" Background="{StaticResource PrimaryAccentGradient}" CornerRadius="16" VerticalAlignment="Center">
                                    <FontIcon Glyph="&#xE909;" FontSize="32" Foreground="White" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                </Border>
                                <StackPanel VerticalAlignment="Center" Spacing="2">
                                    <TextBlock Text="WinCare Pro" FontSize="20" FontWeight="ExtraBold" />
                                    <TextBlock Text="System Optimizer &amp; Security Shield" FontSize="12.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                    <TextBlock Text="Version 1.2.0 (Stable Release)" FontSize="11.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                </StackPanel>
                            </StackPanel>

                            <MenuFlyoutSeparator />

                            <!-- Developer info -->
                            <Grid RowSpacing="12" ColumnSpacing="16" Margin="0,8">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- Author row -->
                                <TextBlock Grid.Row="0" Grid.Column="0" Text="Author:" FontWeight="SemiBold" FontSize="13" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" VerticalAlignment="Center"/>
                                <TextBlock Grid.Row="0" Grid.Column="1" Text="Nguyen Trung Tien" FontSize="13" FontWeight="Bold" VerticalAlignment="Center"/>

                                <!-- Contact row -->
                                <TextBlock Grid.Row="1" Grid.Column="0" Text="Contact Support:" FontWeight="SemiBold" FontSize="13" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" VerticalAlignment="Center"/>
                                <HyperlinkButton Grid.Row="1" Grid.Column="1" Content="trungtiennguyen910@gmail.com" NavigateUri="mailto:trungtiennguyen910@gmail.com" Padding="0" VerticalAlignment="Center"/>
                            </Grid>

                            <MenuFlyoutSeparator />

                            <!-- Code repository -->
                            <StackPanel Spacing="8">
