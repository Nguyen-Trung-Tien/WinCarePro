<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinCarePro.Views.StartupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:WinCarePro.Models"
    xmlns:local="using:WinCarePro.Views"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.ChildrenTransitions>
            <TransitionCollection>
                <EntranceThemeTransition FromHorizontalOffset="0" FromVerticalOffset="15" />
            </TransitionCollection>
        </Grid.ChildrenTransitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="4">
                <TextBlock Text="Startup, Tasks &amp; Services" FontSize="28" FontWeight="ExtraBold" Foreground="{ThemeResource SystemControlPageTextBaseHighBrush}" />
                <TextBlock Text="Manage items running automatically on system boot. Accelerate startup and clean service overhead." FontSize="14" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
            </StackPanel>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button Content="Refresh List" Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" Click="OnRefreshClick" IsEnabled="{x:Bind IsNot(ViewModel.IsLoading), Mode=OneWay}" Padding="20,10" CornerRadius="8" FontWeight="Bold" />
            </StackPanel>
        </Grid>

        <!-- Pivot Tabs -->
        <Pivot Grid.Row="1">
            <!-- Startup Applications Tab -->
            <PivotItem Header="Startup Apps">
                <Border Style="{StaticResource ModernCardStyle}" CornerRadius="0,16,16,16" Padding="20" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        
                        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.StartupApps, Mode=OneWay}" SelectionMode="None">
                            <ListView.ItemContainerTransitions>
                                <TransitionCollection>
                                    <AddDeleteThemeTransition />
                                    <RepositionThemeTransition />
                                </TransitionCollection>
                            </ListView.ItemContainerTransitions>
                            <ListView.HeaderTemplate>
                                <DataTemplate>
                                    <Grid Padding="12,8" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="220" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="100" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Application Name" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="1" Text="Source" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="2" Text="Registry Command Path" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="3" Text="Enable Status" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="4" Text="Action" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.HeaderTemplate>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:StartupEntry">
                                    <Grid Padding="12,10" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="220" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="100" />
                                        </Grid.ColumnDefinitions>
                                        
                                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <Border Width="24" Height="24" Background="#157F56D9" CornerRadius="6" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <FontIcon Glyph="&#xE71D;" Foreground="#FF7F56D9" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="{x:Bind Name}" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12.5" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{x:Bind SourceFormatted}" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                        <TextBlock Grid.Column="2" Text="{x:Bind Command}" VerticalAlignment="Center" TextWrapping="NoWrap" FontSize="11.5" FontFamily="Consolas" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" Margin="0,0,12,0" />
                                        
                                        <ToggleSwitch Grid.Column="3" IsOn="{x:Bind IsEnabled, Mode=OneWay}" Toggled="OnStartupToggled" OffContent="Disabled" OnContent="Enabled" VerticalAlignment="Center" FontSize="11.5" />
                                        
                                        <Button Grid.Column="4" Content="Delete" Click="OnDeleteStartupClick" Style="{StaticResource DefaultButtonStyle}" Foreground="#EF4444" BorderBrush="#33EF4444" CornerRadius="6" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="12,5" FontSize="11" FontWeight="Bold" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </PivotItem>

            <!-- Services Manager Tab -->
            <PivotItem Header="Background Services">
                <Border Style="{StaticResource ModernCardStyle}" CornerRadius="0,16,16,16" Padding="20" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Services, Mode=OneWay}" SelectionMode="None">
                            <ListView.ItemContainerTransitions>
                                <TransitionCollection>
                                    <AddDeleteThemeTransition />
                                    <RepositionThemeTransition />
                                </TransitionCollection>
                            </ListView.ItemContainerTransitions>
                            <ListView.HeaderTemplate>
                                <DataTemplate>
                                    <Grid Padding="12,8" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200" />
                                            <ColumnDefinition Width="250" />
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Service ID" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="1" Text="Display Description" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="2" Text="State" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="3" Text="Startup Configuration" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="4" Text="Operations" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.HeaderTemplate>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:ServiceEntry">
                                    <Grid Padding="12,10" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200" />
                                            <ColumnDefinition Width="250" />
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <Border Width="24" Height="24" Background="#153B82F6" CornerRadius="6" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <FontIcon Glyph="&#xE817;" Foreground="#FF3B82F6" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="{x:Bind Name}" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12.5" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{x:Bind DisplayName}" VerticalAlignment="Center" TextWrapping="NoWrap" FontSize="12" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" Margin="0,0,12,0" />
                                        
                                        <Border Grid.Column="2" Background="{x:Bind local:StartupPage.GetServiceBg(Status), Mode=OneWay}" CornerRadius="6" Padding="10,5" HorizontalAlignment="Left" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="{x:Bind local:StartupPage.GetServiceIcon(Status), Mode=OneWay}" Foreground="{x:Bind local:StartupPage.GetServiceColor(Status), Mode=OneWay}" FontSize="11" VerticalAlignment="Center" />
                                                <TextBlock Text="{x:Bind Status}" Foreground="{x:Bind local:StartupPage.GetServiceColor(Status), Mode=OneWay}" FontWeight="Bold" FontSize="11" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Border>

                                        <ComboBox Grid.Column="3" SelectedIndex="{x:Bind local:StartupPage.GetStartupIndex(StartupType), Mode=OneWay}" SelectionChanged="OnServiceStartupChanged" VerticalAlignment="Center" CornerRadius="6" FontSize="11.5" Height="32">
                                            <ComboBoxItem Content="Automatic" />
                                            <ComboBoxItem Content="Manual" />
                                            <ComboBoxItem Content="Disabled" />
                                        </ComboBox>

                                        <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <Button Content="Start" Click="OnServiceControlClick" Tag="Start" IsEnabled="{x:Bind local:StartupPage.CanStartService(Status), Mode=OneWay}" CornerRadius="6" FontSize="11" Padding="10,5" Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" FontWeight="Bold" />
                                            <Button Content="Stop" Click="OnServiceControlClick" Tag="Stop" IsEnabled="{x:Bind local:StartupPage.CanStopService(Status, CanStop), Mode=OneWay}" CornerRadius="6" FontSize="11" Padding="10,5" Foreground="#EF4444" BorderBrush="#33EF4444" FontWeight="Bold" />
                                            <Button Content="Restart" Click="OnServiceControlClick" Tag="Restart" IsEnabled="{x:Bind local:StartupPage.CanStopService(Status, CanStop), Mode=OneWay}" CornerRadius="6" FontSize="11" Padding="10,5" Foreground="{ThemeResource SystemAccentColor}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" FontWeight="Bold" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </PivotItem>

            <!-- Scheduled Tasks Tab -->
            <PivotItem Header="Scheduled Tasks">
                <Border Style="{StaticResource ModernCardStyle}" CornerRadius="0,16,16,16" Padding="20" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.ScheduledTasks, Mode=OneWay}" SelectionMode="None">
                            <ListView.ItemContainerTransitions>
                                <TransitionCollection>
                                    <AddDeleteThemeTransition />
                                    <RepositionThemeTransition />
                                </TransitionCollection>
                            </ListView.ItemContainerTransitions>
                            <ListView.HeaderTemplate>
                                <DataTemplate>
                                    <Grid Padding="12,8" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="100" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Task Name" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="1" Text="Hierarchy Directory" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="2" Text="Trigger Command Action" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="3" Text="Enable Status" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="4" Text="Operations" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.HeaderTemplate>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:ScheduledTaskEntry">
                                    <Grid Padding="12,10" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="100" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <Border Width="24" Height="24" Background="#158B5CF6" CornerRadius="6" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <FontIcon Glyph="&#xE81C;" Foreground="#FF8B5CF6" FontSize="11" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                            </Border>
                                            <TextBlock Text="{x:Bind Name}" VerticalAlignment="Center" FontWeight="SemiBold" FontSize="12.5" />
                                        </StackPanel>
                                        <TextBlock Grid.Column="1" Text="{x:Bind Path}" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                        <TextBlock Grid.Column="2" Text="{x:Bind Action}" VerticalAlignment="Center" TextWrapping="NoWrap" FontSize="11.5" FontFamily="Consolas" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" Margin="0,0,12,0" />

                                        <ToggleSwitch Grid.Column="3" IsOn="{x:Bind IsEnabled, Mode=OneWay}" Toggled="OnTaskToggled" OffContent="Disabled" OnContent="Enabled" VerticalAlignment="Center" FontSize="11.5" />

                                        <Button Grid.Column="4" Content="Delete" Click="OnDeleteTaskClick" Style="{StaticResource DefaultButtonStyle}" Foreground="#EF4444" BorderBrush="#33EF4444" CornerRadius="6" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="12,5" FontSize="11" FontWeight="Bold" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </PivotItem>
        </Pivot>
        
        <TextBlock Grid.Row="1" Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" VerticalAlignment="Bottom" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" Margin="0,0,0,8" />
    </Grid>
</Page>
