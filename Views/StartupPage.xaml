<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinCarePro.Views.StartupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:WinCarePro.Models"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Margin="0,0,0,16" Style="{StaticResource ModernCardStyle}" Padding="16">
            <Grid>
                <TextBlock Text="Startup programs registered in Windows. Disable high-impact apps to speed up boot delay times." FontSize="12.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" VerticalAlignment="Center"/>
                <Button Content="Reload Configuration" Click="OnReloadStartupClick" HorizontalAlignment="Right" VerticalAlignment="Center" IsEnabled="{x:Bind IsNot(ViewModel.IsLoading), Mode=OneWay}"/>
            </Grid>
        </Border>

        <Grid Grid.Row="1" ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Startup Programs -->
            <Border Grid.Column="0" Style="{StaticResource ModernCardStyle}" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Startup Applications" FontSize="15" FontWeight="Bold" Margin="0,0,0,12" />
                    
                    <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.StartupApps, Mode=OneWay}" SelectionMode="None">
                        <ListView.HeaderTemplate>
                            <DataTemplate>
                                <Grid Padding="8,4" BorderThickness="0,0,0,1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Application" FontWeight="Bold" FontSize="11"/>
                                    <TextBlock Grid.Column="1" Text="Source" FontWeight="Bold" FontSize="11"/>
                                    <TextBlock Grid.Column="2" Text="State" FontWeight="Bold" FontSize="11" HorizontalAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.HeaderTemplate>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:StartupEntry">
                                <Grid Padding="4,6" BorderThickness="0,0,0,1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="80" />
                                        <ColumnDefinition Width="60" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind Name}" FontWeight="Bold" FontSize="12"/>
                                        <TextBlock Text="{x:Bind Path}" FontSize="9.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="NoWrap" MaxWidth="150" />
                                    </StackPanel>
                                    <TextBlock Grid.Column="1" Text="{x:Bind SourceFormatted}" FontSize="11" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" VerticalAlignment="Center" />
                                    <ToggleSwitch Grid.Column="2" IsOn="{x:Bind IsEnabled, Mode=OneWay}" Toggled="OnStartupToggled" CornerRadius="4" MinWidth="0" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- Services Registry list -->
            <Border Grid.Column="1" Style="{StaticResource ModernCardStyle}" Padding="16">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="Active Background Services" FontSize="15" FontWeight="Bold" Margin="0,0,0,12" />

                    <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Services, Mode=OneWay}" SelectionMode="None">
                        <ListView.HeaderTemplate>
                            <DataTemplate>
                                <Grid Padding="8,4" BorderThickness="0,0,0,1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="100" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Service Name" FontWeight="Bold" FontSize="11"/>
                                    <TextBlock Grid.Column="1" Text="Startup / Control" FontWeight="Bold" FontSize="11" HorizontalAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.HeaderTemplate>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:ServiceEntry">
                                <Grid Padding="4,6" BorderThickness="0,0,0,1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind DisplayName}" FontWeight="Bold" FontSize="11.5"/>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="{x:Bind Status}" FontSize="10" Foreground="{ThemeResource SystemAccentColor}" />
                                            <TextBlock Text="{x:Bind StartupType}" FontSize="10" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                        <Button Content="Start" FontSize="10" Padding="6,2" Click="OnServiceControlClick" Tag="Start" />
                                        <Button Content="Stop" FontSize="10" Padding="6,2" Click="OnServiceControlClick" Tag="Stop" IsEnabled="{x:Bind CanStop}" />
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
