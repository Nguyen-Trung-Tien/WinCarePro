<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinCarePro.Views.StartupPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:WinCarePro.Models"
    xmlns:local="using:WinCarePro.Views"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Startup, Tasks &amp; Services" Style="{ThemeResource TitleTextBlockStyle}" FontWeight="Bold" />
                <TextBlock Text="Manage items running automatically on system boot. Accelerate startup and clean service overhead." Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
            </StackPanel>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Button Content="Refresh List" Style="{StaticResource AccentButtonStyle}" Click="OnRefreshClick" IsEnabled="{x:Bind IsNot(ViewModel.IsLoading), Mode=OneWay}" Padding="16,8" CornerRadius="6" />
            </StackPanel>
        </Grid>

        <!-- Pivot Tabs -->
        <Pivot Grid.Row="1">
            <!-- Startup Applications Tab -->
            <PivotItem Header="Startup Apps">
                <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="0,12,12,12" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        
                        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.StartupApps, Mode=OneWay}" SelectionMode="None">
                            <ListView.HeaderTemplate>
                                <DataTemplate>
                                    <Grid Padding="12,6" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="100" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Application Name" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="1" Text="Source" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="2" Text="Registry Command Path" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="3" Text="Enable Status" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="4" Text="Action" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.HeaderTemplate>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:StartupEntry">
                                    <Grid Padding="12" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="100" />
                                        </Grid.ColumnDefinitions>
                                        
                                        <TextBlock Text="{x:Bind Name}" VerticalAlignment="Center" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind SourceFormatted}" VerticalAlignment="Center" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                        <TextBlock Grid.Column="2" Text="{x:Bind Command}" VerticalAlignment="Center" TextWrapping="NoWrap" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" Margin="0,0,12,0" />
                                        
                                        <ToggleSwitch Grid.Column="3" IsOn="{x:Bind IsEnabled, Mode=OneWay}" Toggled="OnStartupToggled" OffContent="Disabled" OnContent="Enabled" VerticalAlignment="Center" FontSize="11" />
                                        
                                        <Button Grid.Column="4" Content="Delete" Click="OnDeleteStartupClick" Foreground="Red" CornerRadius="4" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="8,4" FontSize="11" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </PivotItem>

            <!-- Services Manager Tab -->
            <PivotItem Header="Background Services">
                <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="0,12,12,12" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Services, Mode=OneWay}" SelectionMode="None">
                            <ListView.HeaderTemplate>
                                <DataTemplate>
                                    <Grid Padding="12,6" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200" />
                                            <ColumnDefinition Width="250" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Service ID" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="1" Text="Display Description" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="2" Text="State" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="3" Text="Startup Configuration" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="4" Text="Operations" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.HeaderTemplate>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:ServiceEntry">
                                    <Grid Padding="12" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200" />
                                            <ColumnDefinition Width="250" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{x:Bind Name}" VerticalAlignment="Center" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind DisplayName}" VerticalAlignment="Center" TextWrapping="NoWrap" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" Margin="0,0,12,0" />
                                        
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="6">
                                            <FontIcon Glyph="&#xF5B0;" Foreground="{x:Bind local:StartupPage.GetServiceColor(Status), Mode=OneWay}" FontSize="12" />
                                            <TextBlock Text="{x:Bind Status}" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        </StackPanel>

                                        <ComboBox Grid.Column="3" SelectedIndex="{x:Bind local:StartupPage.GetStartupIndex(StartupType), Mode=OneWay}" SelectionChanged="OnServiceStartupChanged" VerticalAlignment="Center" CornerRadius="4" FontSize="11">
                                            <ComboBoxItem Content="Automatic" />
                                            <ComboBoxItem Content="Manual" />
                                            <ComboBoxItem Content="Disabled" />
                                        </ComboBox>

                                        <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="6" HorizontalAlignment="Center">
                                            <Button Content="Start" Click="OnServiceControlClick" Tag="Start" IsEnabled="{x:Bind local:StartupPage.CanStartService(Status), Mode=OneWay}" CornerRadius="4" FontSize="11" Padding="8,4" />
                                            <Button Content="Stop" Click="OnServiceControlClick" Tag="Stop" IsEnabled="{x:Bind local:StartupPage.CanStopService(Status, CanStop), Mode=OneWay}" CornerRadius="4" FontSize="11" Padding="8,4" />
                                            <Button Content="Restart" Click="OnServiceControlClick" Tag="Restart" IsEnabled="{x:Bind local:StartupPage.CanStopService(Status, CanStop), Mode=OneWay}" CornerRadius="4" FontSize="11" Padding="8,4" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </PivotItem>

            <!-- Scheduled Tasks Tab -->
            <PivotItem Header="Scheduled Tasks">
                <Border BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="0,12,12,12" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.ScheduledTasks, Mode=OneWay}" SelectionMode="None">
                            <ListView.HeaderTemplate>
                                <DataTemplate>
                                    <Grid Padding="12,6" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="100" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Task Name" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="1" Text="Hierarchy Directory" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="2" Text="Trigger Command Action" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="3" Text="Enable Status" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="4" Text="Operations" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.HeaderTemplate>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:ScheduledTaskEntry">
                                    <Grid Padding="12" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="200" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="100" />
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Text="{x:Bind Name}" VerticalAlignment="Center" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind Path}" VerticalAlignment="Center" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                        <TextBlock Grid.Column="2" Text="{x:Bind Action}" VerticalAlignment="Center" TextWrapping="NoWrap" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" Margin="0,0,12,0" />

                                        <ToggleSwitch Grid.Column="3" IsOn="{x:Bind IsEnabled, Mode=OneWay}" Toggled="OnTaskToggled" OffContent="Disabled" OnContent="Enabled" VerticalAlignment="Center" FontSize="11" />

                                        <Button Grid.Column="4" Content="Delete" Click="OnDeleteTaskClick" Foreground="Red" CornerRadius="4" VerticalAlignment="Center" HorizontalAlignment="Center" Padding="8,4" FontSize="11" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>
            </PivotItem>
        </Pivot>
        
        <TextBlock Grid.Row="1" Text="{x:Bind ViewModel.StatusText, Mode=OneWay}" VerticalAlignment="Bottom" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" Margin="0,0,0,8" />
    </Grid>
</Page>
