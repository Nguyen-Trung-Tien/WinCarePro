<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinCarePro.Views.SystemOptimizerPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:WinCarePro.Models"
    xmlns:local="using:WinCarePro.Views"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="System Speed Optimizer" Style="{ThemeResource TitleTextBlockStyle}" FontWeight="Bold" />
            <TextBlock Text="Optimize system response times, trim RAM memory footprints, and configure Windows registry performance tweaks." Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
        </StackPanel>

        <Grid Grid.Row="1" ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <!-- Left column: RAM Booster & Registry Tweaks -->
            <Grid Grid.Column="0" RowSpacing="20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- RAM Optimizer Card -->
                <Border Grid.Row="0" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0" Spacing="8">
                            <TextBlock Text="RAM Physical Memory Booster" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="Bold" />
                            <TextBlock Text="Clean active application worksets and reclaim unused pages of memory." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                            
                            <!-- RAM Info -->
                            <StackPanel Margin="0,8,0,0" Spacing="4">
                                <Grid>
                                    <TextBlock Text="Active RAM Footprint" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" HorizontalAlignment="Left" />
                                    <TextBlock Text="{x:Bind FormatPercent(ViewModel.RamLoad), Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}" FontWeight="Bold" HorizontalAlignment="Right" />
                                </Grid>
                                <ProgressBar Value="{x:Bind ViewModel.RamLoad, Mode=OneWay}" Maximum="100" Height="8" Foreground="{ThemeResource SystemAccentColor}" CornerRadius="4" />
                                <TextBlock Text="{x:Bind ViewModel.RamUsageFormatted, Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" HorizontalAlignment="Left" Margin="0,2,0,0" />
                            </StackPanel>
                        </StackPanel>

                        <!-- Boost Button -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="24,0,0,0" Spacing="8">
                            <Button Style="{StaticResource AccentButtonStyle}" Click="OnBoostRamClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" Width="150" Height="44" CornerRadius="6">
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <FontIcon Glyph="&#xE7BA;" FontSize="16" />
                                    <TextBlock Text="Boost RAM" FontWeight="SemiBold" />
                                </StackPanel>
                            </Button>
                            <ProgressRing IsActive="{x:Bind ViewModel.IsBoosting, Mode=OneWay}" Width="20" Height="20" HorizontalAlignment="Center" />
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Registry Tweaks Card -->
                <Border Grid.Row="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,12">
                            <StackPanel HorizontalAlignment="Left">
                                <TextBlock Text="System Performance Tweaks" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="Bold" />
                                <TextBlock Text="Safe OS adjustments to accelerate boot-up, shutdown, and interface responsiveness." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                            </StackPanel>
                            <TextBlock Text="{x:Bind ViewModel.OptimizationsCountText, Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}" FontWeight="Bold" HorizontalAlignment="Right" VerticalAlignment="Bottom" Foreground="{ThemeResource SystemAccentColor}" />
                        </Grid>

                        <!-- Tweaks ListView -->
                        <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Tweaks, Mode=OneWay}" SelectionMode="None">
                            <ListView.HeaderTemplate>
                                <DataTemplate>
                                    <Grid Padding="12,6" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="130" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="110" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="" Grid.Column="0" />
                                        <TextBlock Text="Category" Grid.Column="1" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Text="Tweak Details" Grid.Column="2" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Text="Value" Grid.Column="3" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Center" />
                                        <TextBlock Text="Status" Grid.Column="4" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Right" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.HeaderTemplate>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:SystemTweak">
                                    <Grid Padding="12" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="130" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="110" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox Grid.Column="0" IsChecked="{x:Bind IsSelected, Mode=TwoWay}" MinWidth="32" VerticalAlignment="Center" />
                                        <TextBlock Grid.Column="1" Text="{x:Bind Category}" Style="{ThemeResource CaptionTextBlockStyle}" VerticalAlignment="Center" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                        <StackPanel Grid.Column="2" Spacing="2" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind Name}" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                            <TextBlock Text="{x:Bind Description}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="3" VerticalAlignment="Center" HorizontalAlignment="Center">
                                            <TextBlock Text="{x:Bind CurrentValue}" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Center" />
                                            <TextBlock Text="{x:Bind RecommendedValue}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" HorizontalAlignment="Center" Margin="0,2,0,0" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Right" Spacing="6">
                                            <FontIcon Glyph="{x:Bind local:SystemOptimizerPage.GetTweakStatusIcon(IsOptimized), Mode=OneWay}" Foreground="{x:Bind local:SystemOptimizerPage.GetTweakStatusColor(IsOptimized), Mode=OneWay}" FontSize="12" />
                                            <TextBlock Text="{x:Bind local:SystemOptimizerPage.GetTweakStatusLabel(IsOptimized), Mode=OneWay}" Foreground="{x:Bind local:SystemOptimizerPage.GetTweakStatusColor(IsOptimized), Mode=OneWay}" FontWeight="SemiBold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>

                        <!-- Action buttons -->
                        <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="12" Margin="0,16,0,0" HorizontalAlignment="Left">
                            <Button Style="{StaticResource AccentButtonStyle}" Content="Apply Selected Tweaks" Click="OnApplyTweaksClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="4" Padding="16,8" />
                            <Button Content="Restore Defaults" Click="OnRevertTweaksClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="4" Padding="16,8" />
                            <Button Content="Scan Now" Click="OnScanTweaksClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="4" Padding="16,8" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <!-- Right column: Delivery Optimization & Logs Console -->
            <Grid Grid.Column="1" RowSpacing="16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Status Progress -->
                <Border Grid.Row="0" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="12">
                    <StackPanel Spacing="8">
                        <Grid>
                            <TextBlock Text="Optimization Progress" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" HorizontalAlignment="Left" />
                            <TextBlock Text="{x:Bind FormatPercent(ViewModel.ProgressPercent), Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}" FontWeight="Bold" HorizontalAlignment="Right" />
                        </Grid>
                        <ProgressBar Value="{x:Bind ViewModel.ProgressPercent, Mode=OneWay}" Maximum="100" Height="6" Foreground="{ThemeResource SystemAccentColor}" CornerRadius="3" />
                        <TextBlock Text="{x:Bind ViewModel.ProgressMessage, Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>

                <!-- Delivery Optimization Cache Cleaner -->
                <Border Grid.Row="1" BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Padding="16">
                    <StackPanel Spacing="10">
                        <TextBlock Text="Delivery Optimization Cleanup" Style="{ThemeResource SubtitleTextBlockStyle}" FontWeight="Bold" />
                        <TextBlock Text="Clear Windows Delivery Optimization peer update caches. Safe to purge at any time." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" />
                        
                        <Grid Margin="0,4,0,0">
                            <TextBlock Text="Cleanable cache size:" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" VerticalAlignment="Center" />
                            <TextBlock Text="{x:Bind ViewModel.CleanableDoSize, Mode=OneWay}" FontWeight="Bold" Style="{ThemeResource BodyTextBlockStyle}" HorizontalAlignment="Right" VerticalAlignment="Center" Foreground="{ThemeResource SystemAccentColor}" />
                        </Grid>
                        <Button Content="Clean Cache Directory" Click="OnCleanDoCacheClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}" CornerRadius="4" Margin="0,4,0,0" />
                    </StackPanel>
                </Border>

                <!-- Logs Box -->
                <TextBox Grid.Row="2" Text="{x:Bind ViewModel.LogConsole, Mode=OneWay}" IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap" FontFamily="Consolas" FontSize="11" Background="{ThemeResource ControlAltFillColorSecondaryBrush}" BorderThickness="0" CornerRadius="8" ScrollViewer.VerticalScrollBarVisibility="Auto" />
            </Grid>
        </Grid>
    </Grid>
</Page>
