<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinCarePro.Views.UninstallPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:WinCarePro.Models"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <TextBox x:Name="AppSearch" PlaceholderText="Search installed applications..." Text="{x:Bind ViewModel.SearchText, Mode=TwoWay}" CornerRadius="6" Width="280" Height="32" HorizontalAlignment="Left" VerticalAlignment="Center"/>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button Content="Scan Registry Apps" Click="OnReloadAppsClick" IsEnabled="{x:Bind IsNot(ViewModel.IsBusy), Mode=OneWay}"/>
                <Button Content="{x:Bind ViewModel.LeftoversSizeFormatted, Mode=OneWay}" Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" Click="OnCleanLeftoversClick" Visibility="{x:Bind GetLeftoversVisibility(ViewModel.UninstallStep), Mode=OneWay}"/>
            </StackPanel>
        </Grid>

        <Grid Grid.Row="1">
            <!-- Step 0: App list -->
            <Border Style="{StaticResource ModernCardStyle}" Padding="12" Visibility="{x:Bind GetStepListVisibility(ViewModel.UninstallStep), Mode=OneWay}">
                <ListView ItemsSource="{x:Bind ViewModel.FilteredApps, Mode=OneWay}" SelectionMode="None">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="models:InstalledAppInfo">
                            <Grid Padding="4,8" BorderThickness="0,0,0,1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="150" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <CheckBox IsChecked="{x:Bind IsSelected, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,12,0" MinWidth="20" />
                                
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="{x:Bind DisplayName}" FontWeight="Bold" FontSize="13"/>
                                    <TextBlock Text="{x:Bind Publisher}" FontSize="10.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                </StackPanel>

                                <TextBlock Grid.Column="2" Text="{x:Bind SizeFormatted}" FontSize="12.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="0,0,24,0"/>

                                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="4" VerticalAlignment="Center">
                                    <Button Content="Uninstall" FontSize="10" Padding="8,3" Click="OnSingleUninstallClick" Foreground="#FFE81123"/>
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>

            <!-- Step 1: Progress overlay -->
            <Border Style="{StaticResource ModernCardStyle}" Padding="24" HorizontalAlignment="Center" VerticalAlignment="Center" Width="400" Visibility="{x:Bind GetStepProgressVisibility(ViewModel.UninstallStep), Mode=OneWay}">
                <StackPanel Spacing="16" HorizontalAlignment="Center">
                    <ProgressRing IsActive="True" Width="50" Height="50" HorizontalAlignment="Center"/>
                    <TextBlock Text="{x:Bind ViewModel.ProgressMessage, Mode=OneWay}" FontSize="13" TextWrapping="Wrap" HorizontalAlignment="Center" TextAlignment="Center"/>
                    <ProgressBar Value="{x:Bind ViewModel.ProgressPercent, Mode=OneWay}" Maximum="100" Height="6" CornerRadius="3" Foreground="{StaticResource PrimaryAccentGradient}" Width="300" HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Step 2: Leftovers review -->
            <Grid Visibility="{x:Bind GetStepLeftoversVisibility(ViewModel.UninstallStep), Mode=OneWay}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Leftovers Scanner Discovery" FontSize="15" FontWeight="Bold" Margin="0,0,0,12" />

                <Border Grid.Row="1" Style="{StaticResource ModernCardStyle}" Padding="12">
                    <ListView ItemsSource="{x:Bind ViewModel.Leftovers, Mode=OneWay}" SelectionMode="None">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:LeftoverItem">
                                <Grid Padding="4,6" BorderThickness="0,0,0,1" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="100" />
                                    </Grid.ColumnDefinitions>
                                    <CheckBox IsChecked="{x:Bind IsSelected, Mode=TwoWay}" VerticalAlignment="Center" Margin="0,0,12,0" MinWidth="20" />
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{x:Bind DisplayName}" FontWeight="Bold" FontSize="12"/>
                                        <TextBlock Text="{x:Bind Path}" FontSize="9.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                    </StackPanel>
                                    <TextBlock Grid.Column="2" Text="{x:Bind SizeFormatted}" FontSize="12.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" VerticalAlignment="Center" HorizontalAlignment="Right"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Border>

                <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8" Margin="0,12,0,0" HorizontalAlignment="Right">
                    <Button Content="Cancel &amp; Back" Click="OnCancelLeftoversClick"/>
                    <Button Content="Wipe Leftovers" Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" Click="OnDeleteLeftoversClick" FontWeight="Bold"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Page>
