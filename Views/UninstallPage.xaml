<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinCarePro.Views.UninstallPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:WinCarePro.Models"
    xmlns:local="using:WinCarePro.Views"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.ChildrenTransitions>
            <TransitionCollection>
                <EntranceThemeTransition FromHorizontalOffset="0" FromVerticalOffset="20" />
            </TransitionCollection>
        </Grid.ChildrenTransitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="4">
                <TextBlock Text="Professional App Uninstaller" FontSize="28" FontWeight="ExtraBold" CharacterSpacing="-10" />
                <TextBlock Text="Completely uninstall desktop applications and remove residual leftovers, folders, and registry configurations." Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
            </StackPanel>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <Button Content="Refresh List" Click="OnRefreshClick" IsEnabled="{x:Bind IsNot(ViewModel.IsScanning), Mode=OneWay}" Padding="18,9" CornerRadius="8" FontWeight="SemiBold" />
            </StackPanel>
        </Grid>

        <!-- Main Body -->
        <Grid Grid.Row="1">
            <!-- STEP 0: Application List View -->
            <Grid Visibility="{x:Bind local:UninstallPage.StepToVisibility(ViewModel.CurrentStep, 0), Mode=OneWay}" ColumnSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>

                <!-- Installed Apps List Card -->
                <Border Grid.Column="0" Style="{StaticResource ModernCardStyle}" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        
                        <TextBlock Grid.Row="0" Text="Installed Programs" FontSize="18" FontWeight="Bold" Margin="0,0,0,8" />
                        
                        <!-- Search Bar -->
                        <TextBox Grid.Row="1" PlaceholderText="Search applications or publishers..." Text="{x:Bind ViewModel.SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,16" CornerRadius="8" Height="36">
                            <TextBox.Header>
                                <Grid Width="1" Height="1" />
                            </TextBox.Header>
                        </TextBox>

                        <ListView Grid.Row="2" ItemsSource="{x:Bind ViewModel.FilteredApps, Mode=OneWay}" SelectionMode="None">
                            <ListView.ItemContainerTransitions>
                                <TransitionCollection>
                                    <AddDeleteThemeTransition />
                                    <RepositionThemeTransition />
                                </TransitionCollection>
                            </ListView.ItemContainerTransitions>
                            <ListView.HeaderTemplate>
                                <DataTemplate>
                                    <Grid Padding="12,8" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="100" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="Application Title" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="1" Text="Publisher" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="2" Text="Version" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="3" Text="Size" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                        <TextBlock Grid.Column="4" Text="Operation" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Center" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.HeaderTemplate>
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:InstalledAppInfo">
                                    <Grid Padding="8,10" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="150" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="100" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <Grid Width="32" Height="32" Margin="0,0,4,0" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <Image Source="{x:Bind IconImageSource, Mode=OneWay}" 
                                                       Visibility="{x:Bind IconVisibility, Mode=OneWay}"
                                                       Width="32"
                                                       Height="32"
                                                       Stretch="Uniform" />
                                                
                                                <Border Width="32" Height="32" Background="{x:Bind IconBackground, Mode=OneWay}" CornerRadius="8"
                                                        Visibility="{x:Bind FallbackVisibility, Mode=OneWay}">
                                                    <FontIcon Glyph="{x:Bind DefaultIconGlyph, Mode=OneWay}" 
                                                              Foreground="{x:Bind IconForeground, Mode=OneWay}" 
                                                              FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                            <TextBlock Text="{x:Bind DisplayName}" FontWeight="Bold" FontSize="13" VerticalAlignment="Center" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                        </StackPanel>

                                        <TextBlock Grid.Column="1" Text="{x:Bind Publisher}" VerticalAlignment="Center" FontSize="12.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="2" Text="{x:Bind Version}" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis"/>
                                        <TextBlock Grid.Column="3" Text="{x:Bind SizeFormatted}" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}"/>
                                        
                                        <Button Grid.Column="4" Content="Uninstall" Click="OnUninstallClick" Tag="{x:Bind}" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="12,5" CornerRadius="6" FontSize="11" Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" FontWeight="Bold" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>

                <!-- Information Panel -->
                <Grid Grid.Column="1" RowSpacing="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource ModernCardStyle}" Padding="20">
                        <StackPanel Spacing="16" HorizontalAlignment="Center">
                            <TextBlock Text="System Summary" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" />
                            
                            <Border Width="56" Height="56" Background="#15EF4444" CornerRadius="28" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE75C;" FontSize="24" Foreground="Red" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Border>

                            <StackPanel Spacing="4">
                                <TextBlock Text="Tracked Installed Apps" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" HorizontalAlignment="Center" />
                                <TextBlock Text="{x:Bind ViewModel.FilteredApps.Count, Mode=OneWay}" FontSize="36" FontWeight="ExtraBold" Foreground="{ThemeResource SystemAccentColor}" HorizontalAlignment="Center" />
                            </StackPanel>

                            <TextBlock Text="{x:Bind ViewModel.ProgressMessage, Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" HorizontalAlignment="Center" TextAlignment="Center" />
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource ModernCardStyle}" Padding="20">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0" Text="Uninstaller Guidance" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
                            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                <StackPanel Spacing="12">
                                    <TextBlock Text="• Click the 'Uninstall' button on any application to start the advanced cleanup pipeline." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" LineHeight="16" />
                                    <TextBlock Text="• Step 1: Launches standard application uninstaller. Follow its instructions to remove primary files." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" LineHeight="16" />
                                    <TextBlock Text="• Step 2: WinCare scans deeper for directories and registry configurations left behind." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" LineHeight="16" />
                                    <TextBlock Text="• Deleting residuals helps reclaim locked storage space and avoids registry bloat that can slow down Windows." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" LineHeight="16" />
                                </StackPanel>
                            </ScrollViewer>
                        </Grid>
                    </Border>
                </Grid>
            </Grid>

            <!-- STEP 1: Progress Tracking View -->
            <Grid Visibility="{x:Bind local:UninstallPage.StepToVisibility(ViewModel.CurrentStep, 1), Mode=OneWay}">
                <Border Style="{StaticResource ModernCardStyle}" Padding="32" HorizontalAlignment="Center" VerticalAlignment="Center" Width="480">
                    <StackPanel Spacing="24" HorizontalAlignment="Stretch">
                        <ProgressRing Width="64" Height="64" IsActive="True" Foreground="{StaticResource PrimaryAccentGradient}" HorizontalAlignment="Center" />
                        
                        <StackPanel Spacing="8">
                            <TextBlock Text="{x:Bind ViewModel.SelectedApp.DisplayName, Mode=OneWay}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" TextAlignment="Center" />
                            <TextBlock Text="Uninstall &amp; Leftovers Scrubber" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" HorizontalAlignment="Center" />
                        </StackPanel>

                        <ProgressBar Value="{x:Bind ViewModel.ProgressPercent, Mode=OneWay}" Maximum="100" Height="8" CornerRadius="4" Foreground="{StaticResource PrimaryAccentGradient}" />
                        
                        <TextBlock Text="{x:Bind ViewModel.ProgressMessage, Mode=OneWay}" Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" />
                    </StackPanel>
                </Border>
            </Grid>

            <!-- STEP 2: Leftovers Review View -->
            <Grid Visibility="{x:Bind local:UninstallPage.StepToVisibility(ViewModel.CurrentStep, 2), Mode=OneWay}" ColumnSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="3*" />
                    <ColumnDefinition Width="2*" />
                </Grid.ColumnDefinitions>

                <!-- Scanned Leftovers Card -->
                <Border Grid.Column="0" Style="{StaticResource ModernCardStyle}" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Leftovers Discovery" FontSize="18" FontWeight="Bold" Margin="0,0,0,8" />
                        
                        <!-- Actions Toolbar -->
                        <Grid Grid.Row="1" Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock VerticalAlignment="Center" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}">
                                Check items you want to permanently delete.
                            </TextBlock>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                                <Button Content="Select All" Click="OnSelectAllLeftovers" Padding="12,4" CornerRadius="6" FontSize="11" />
                                <Button Content="Deselect All" Click="OnDeselectAllLeftovers" Padding="12,4" CornerRadius="6" FontSize="11" />
                            </StackPanel>
                        </Grid>

                        <!-- Leftovers List -->
                        <ListView Grid.Row="2" ItemsSource="{x:Bind ViewModel.Leftovers, Mode=OneWay}" SelectionMode="None">
                            <ListView.ItemTemplate>
                                <DataTemplate x:DataType="models:LeftoverItem">
                                    <Grid Padding="8,8" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="100" />
                                        </Grid.ColumnDefinitions>

                                        <CheckBox IsChecked="{x:Bind IsSelected, Mode=TwoWay}" VerticalAlignment="Center" MinWidth="24" />

                                        <Border Grid.Column="1" Width="28" Height="28" Background="{ThemeResource ControlAltFillColorSecondaryBrush}" CornerRadius="6" HorizontalAlignment="Center" VerticalAlignment="Center">
                                            <FontIcon Glyph="{x:Bind local:UninstallPage.GetLeftoverIcon(Type)}" Foreground="{x:Bind local:UninstallPage.GetLeftoverColor(Type)}" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                                        </Border>

                                        <StackPanel Grid.Column="2" Spacing="2" Margin="8,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{x:Bind Path}" FontSize="12.5" FontWeight="SemiBold" TextWrapping="Wrap" />
                                            <TextBlock Text="{x:Bind DisplayName}" FontSize="10.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                        </StackPanel>

                                        <TextBlock Grid.Column="3" Text="{x:Bind SizeFormatted}" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="12" Foreground="{ThemeResource SystemAccentColor}" FontWeight="Bold" />
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </Grid>
                </Border>

                <!-- Leftovers Confirmation Pane -->
                <Grid Grid.Column="1" RowSpacing="24">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <Border Style="{StaticResource GradientBorderCardStyle}" Padding="24">
                        <StackPanel Spacing="16" HorizontalAlignment="Stretch">
                            <TextBlock Text="Residual Purge" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" />

                            <Border Width="56" Height="56" Background="#157F56D9" CornerRadius="28" HorizontalAlignment="Center">
                                <FontIcon Glyph="&#xE74D;" FontSize="24" Foreground="{ThemeResource SystemAccentColor}" VerticalAlignment="Center" HorizontalAlignment="Center" />
                            </Border>

                            <StackPanel Spacing="4">
                                <TextBlock Text="Cleanable Space Selected" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" HorizontalAlignment="Center" />
                                <TextBlock Text="{x:Bind ViewModel.LeftoversSizeFormatted, Mode=OneWay}" FontSize="32" FontWeight="ExtraBold" Foreground="{ThemeResource SystemAccentColor}" HorizontalAlignment="Center" />
                            </StackPanel>

                            <StackPanel Spacing="10">
                                <Button Content="Purge Selected Leftovers" Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" Click="OnDeleteLeftoversClick" IsEnabled="{x:Bind IsNot(ViewModel.IsCleaningLeftovers), Mode=OneWay}" HorizontalAlignment="Stretch" Padding="14,10" CornerRadius="8" FontWeight="Bold" />
                                <Button Content="Skip residual cleanup" Click="OnCancelLeftoversClick" IsEnabled="{x:Bind IsNot(ViewModel.IsCleaningLeftovers), Mode=OneWay}" HorizontalAlignment="Stretch" Padding="14,10" CornerRadius="8" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <Border Grid.Row="1" Style="{StaticResource ModernCardStyle}" Padding="20">
                        <StackPanel Spacing="12">
                            <TextBlock Text="Critical Warnings" FontSize="16" FontWeight="Bold" Foreground="Orange" />
                            <TextBlock Text="• Deleting residual files removes user configurations, saved caches, and plugin settings." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" LineHeight="15" />
                            <TextBlock Text="• Deleting registry entries cleans up keys created under Software. This is generally safe and helps avoid residual key clutter." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" LineHeight="15" />
                            <TextBlock Text="• Please double-check paths before performing the purge to ensure no shared directories are selected." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" LineHeight="15" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Grid>
        </Grid>
    </Grid>
</Page>
