<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="WinCarePro.Views.UpdaterPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:models="using:WinCarePro.Models"
    xmlns:local="using:WinCarePro.Views"
    mc:Ignorable="d">

    <Grid Padding="24">
        <Grid.ChildrenTransitions>
            <TransitionCollection>
                <EntranceThemeTransition FromHorizontalOffset="0" FromVerticalOffset="15" />
            </TransitionCollection>
        </Grid.ChildrenTransitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

    <Grid Padding="24">
        <Grid.ChildrenTransitions>
            <TransitionCollection>
                <EntranceThemeTransition FromHorizontalOffset="0" FromVerticalOffset="20" />
            </TransitionCollection>
        </Grid.ChildrenTransitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel>
                <TextBlock Text="Software Package Updater" FontSize="28" FontWeight="ExtraBold" CharacterSpacing="-10" />
                <TextBlock Text="Scan and download latest stable updates for system runtimes, browsers, and developer applications." Style="{ThemeResource BodyTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" Margin="0,4,0,0" />
            </StackPanel>
            
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                <ComboBox x:Name="EngineCombo" SelectedIndex="0" SelectionChanged="OnEngineChanged" IsEnabled="{x:Bind IsNot(ViewModel.IsScanning), Mode=OneWay}" CornerRadius="8" Width="240" VerticalAlignment="Center">
                    <ComboBoxItem Content="Windows Package Manager (winget)" Tag="winget" />
                    <ComboBoxItem Content="WinCare Custom Downloader" Tag="direct" />
                </ComboBox>
                <Button Content="Scan Updates" Style="{StaticResource DefaultButtonStyle}" Click="OnScanClick" IsEnabled="{x:Bind IsNot(ViewModel.IsScanning), Mode=OneWay}" Padding="18,9" CornerRadius="8" FontWeight="SemiBold" />
                <Button Content="Update Selected" Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" Click="OnUpdateSelectedClick" IsEnabled="{x:Bind CanUpdate(ViewModel.IsUpdating, ViewModel.Updates.Count), Mode=OneWay}" Padding="18,9" CornerRadius="8" FontWeight="SemiBold" />
                <Button Content="Update All" Click="OnUpdateAllClick" IsEnabled="{x:Bind CanUpdate(ViewModel.IsUpdating, ViewModel.Updates.Count), Mode=OneWay}" Padding="18,9" CornerRadius="8" FontWeight="SemiBold" />
            </StackPanel>
        </Grid>

        <!-- Main Body -->
        <Grid Grid.Row="1" ColumnSpacing="24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <!-- Updates List -->
            <Border Grid.Column="0" Style="{StaticResource ModernCardStyle}" Padding="20">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- Selection Toolbar -->
                    <Grid Grid.Row="0" Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <TextBlock VerticalAlignment="Center" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" FontWeight="SemiBold">
                            <Run Text="{x:Bind ViewModel.SelectedCount, Mode=OneWay}" />
                            <Run Text=" of " />
                            <Run Text="{x:Bind ViewModel.Updates.Count, Mode=OneWay}" />
                            <Run Text=" selected" />
                        </TextBlock>

                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
                            <Button Content="Select All" Click="OnSelectAllClick" Padding="12,4" CornerRadius="6" FontSize="11" IsEnabled="{x:Bind IsNot(ViewModel.IsUpdating), Mode=OneWay}" />
                            <Button Content="Deselect All" Click="OnDeselectAllClick" Padding="12,4" CornerRadius="6" FontSize="11" IsEnabled="{x:Bind IsNot(ViewModel.IsUpdating), Mode=OneWay}" />
                        </StackPanel>
                    </Grid>

                    <ListView Grid.Row="1" ItemsSource="{x:Bind ViewModel.Updates, Mode=OneWay}" SelectionMode="None">
                        <ListView.ItemContainerTransitions>
                            <TransitionCollection>
                                <AddDeleteThemeTransition />
                                <RepositionThemeTransition />
                            </TransitionCollection>
                        </ListView.ItemContainerTransitions>
                        <ListView.HeaderTemplate>
                            <DataTemplate>
                                <Grid Padding="12,8" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Margin="0,0,0,4">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="90" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                    <TextBlock Grid.Column="1" Text="Software Title" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                    <TextBlock Grid.Column="2" Text="Installed" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                    <TextBlock Grid.Column="3" Text="Available" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" />
                                    <TextBlock Grid.Column="4" Text="Status" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Center" />
                                    <TextBlock Grid.Column="5" Text="Action" FontWeight="Bold" Style="{ThemeResource CaptionTextBlockStyle}" HorizontalAlignment="Center" />
                                </Grid>
                            </DataTemplate>
                        </ListView.HeaderTemplate>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:SoftwareUpdateInfo" xmlns:models="using:WinCarePro.Models">
                                <Grid Padding="8,10" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="40" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="100" />
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="90" />
                                    </Grid.ColumnDefinitions>

                                    <CheckBox IsChecked="{x:Bind IsSelected, Mode=TwoWay}" VerticalAlignment="Center" MinWidth="24" />

                                    <!-- App info -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                                        <TextBlock Text="{x:Bind Name}" FontWeight="Bold" FontSize="13" />
                                        <TextBlock Text="{x:Bind Id}" FontSize="10.5" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                    </StackPanel>

                                    <TextBlock Grid.Column="2" Text="{x:Bind InstalledVersion}" VerticalAlignment="Center" FontSize="12" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" />
                                    <TextBlock Grid.Column="3" Text="{x:Bind AvailableVersion}" FontWeight="Bold" VerticalAlignment="Center" FontSize="12.5" Foreground="{ThemeResource SystemAccentColor}" />

                                    <!-- Status with icon -->
                                    <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="4" HorizontalAlignment="Center" VerticalAlignment="Center">
                                        <FontIcon Glyph="{x:Bind local:UpdaterPage.GetStatusIcon(UpdateStatus), Mode=OneWay}" Foreground="{x:Bind local:UpdaterPage.GetStatusColor(UpdateStatus), Mode=OneWay}" FontSize="12" />
                                        <TextBlock Text="{x:Bind UpdateStatus, Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{x:Bind local:UpdaterPage.GetStatusColor(UpdateStatus), Mode=OneWay}" FontWeight="Bold" FontSize="11" />
                                    </StackPanel>

                                    <!-- Per-app Update Button -->
                                    <Button Grid.Column="5" Content="Update" Tag="{x:Bind}" Click="OnUpdateSingleClick" HorizontalAlignment="Center" VerticalAlignment="Center" Padding="12,5" CornerRadius="6" FontSize="11" Style="{StaticResource AccentButtonStyle}" Background="{StaticResource PrimaryAccentGradient}" Foreground="White" FontWeight="Bold" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>

            <!-- Status Indicator Panel -->
            <Grid Grid.Column="1" RowSpacing="24">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Progress Tracker -->
                <Border Style="{StaticResource ModernCardStyle}" Padding="20">
                    <StackPanel Spacing="16" HorizontalAlignment="Center">
                        <TextBlock Text="Installer Operations" FontSize="18" FontWeight="Bold" HorizontalAlignment="Center" />
                        
                        <ProgressBar Value="{x:Bind ViewModel.ProgressPercent, Mode=OneWay}" Maximum="100" Height="8" Foreground="{StaticResource PrimaryAccentGradient}" CornerRadius="4" Width="200" HorizontalAlignment="Center" />
                        <TextBlock Text="{x:Bind ViewModel.ProgressMessage, Mode=OneWay}" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" HorizontalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" />

                        <!-- Summary Stats -->
                        <Grid ColumnSpacing="24" HorizontalAlignment="Center">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Spacing="2" HorizontalAlignment="Center">
                                <TextBlock Text="{x:Bind ViewModel.Updates.Count, Mode=OneWay}" FontSize="24" FontWeight="ExtraBold" HorizontalAlignment="Center" Foreground="{ThemeResource SystemAccentColor}" />
                                <TextBlock Text="Available" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="2" HorizontalAlignment="Center">
                                <TextBlock Text="{x:Bind ViewModel.SelectedCount, Mode=OneWay}" FontSize="24" FontWeight="ExtraBold" HorizontalAlignment="Center" Foreground="{ThemeResource SystemAccentColor}" />
                                <TextBlock Text="Selected" Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Info Card -->
                <Border Grid.Row="1" Style="{StaticResource ModernCardStyle}" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <TextBlock Grid.Row="0" Text="Updater Information" FontSize="18" FontWeight="Bold" Margin="0,0,0,12" />
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <StackPanel Spacing="12">
                                <TextBlock Text="• Choose 'Windows Package Manager' to update via standard Microsoft package catalog (winget)." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" LineHeight="16" />
                                <TextBlock Text="• Choose 'WinCare Custom Downloader' to download official installer files directly and run them silently." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" LineHeight="16" />
                                <TextBlock Text="• Click 'Scan Updates' to discover outdated applications on your system." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" LineHeight="16" />
                                <TextBlock Text="• Use checkboxes to select specific apps, then click 'Update Selected' to batch update." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" LineHeight="16" />
                                <TextBlock Text="• Click the 'Update' button on each row to update a single application individually." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" LineHeight="16" />
                                <TextBlock Text="• Third-party licenses and agreements are accepted automatically during batch operations." Style="{ThemeResource CaptionTextBlockStyle}" Foreground="{ThemeResource SystemControlPageTextBaseMediumBrush}" TextWrapping="Wrap" LineHeight="16" />
                            </StackPanel>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
    </Grid>
</Page>
